  49:polyvec.c     ****                 / KYBER_Q) & 0x3ff;
  50:polyvec.c     **** 
  51:polyvec.c     ****       r[0] = (t[0] >> 0);
  52:polyvec.c     ****       r[1] = (t[0] >> 8) | (t[1] << 2);
  53:polyvec.c     ****       r[2] = (t[1] >> 6) | (t[2] << 4);
  54:polyvec.c     ****       r[3] = (t[2] >> 4) | (t[3] << 6);
  55:polyvec.c     ****       r[4] = (t[3] >> 2);
  56:polyvec.c     ****       r += 5;
  57:polyvec.c     ****     }
  58:polyvec.c     ****   }
