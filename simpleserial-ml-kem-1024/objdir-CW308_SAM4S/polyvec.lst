  22:polyvec.c     ****   uint16_t t[8];
  23:polyvec.c     ****   for(i=0;i<KYBER_K;i++) {
  24:polyvec.c     ****     for(j=0;j<KYBER_N/8;j++) {
  25:polyvec.c     ****       for(k=0;k<8;k++)
  26:polyvec.c     ****         t[k] = ((((uint32_t)a->vec[i].coeffs[8*j+k] << 11) + KYBER_Q/2)
  27:polyvec.c     ****                 /KYBER_Q) & 0x7ff;
  28:polyvec.c     **** 
  29:polyvec.c     ****       r[ 0] = (t[0] >>  0);
  30:polyvec.c     ****       r[ 1] = (t[0] >>  8) | (t[1] << 3);
  31:polyvec.c     ****       r[ 2] = (t[1] >>  5) | (t[2] << 6);
  32:polyvec.c     ****       r[ 3] = (t[2] >>  2);
  33:polyvec.c     ****       r[ 4] = (t[2] >> 10) | (t[3] << 1);
  34:polyvec.c     ****       r[ 5] = (t[3] >>  7) | (t[4] << 4);
  35:polyvec.c     ****       r[ 6] = (t[4] >>  4) | (t[5] << 7);
  36:polyvec.c     ****       r[ 7] = (t[5] >>  1);
  37:polyvec.c     ****       r[ 8] = (t[5] >>  9) | (t[6] << 2);
  38:polyvec.c     ****       r[ 9] = (t[6] >>  6) | (t[7] << 5);
  39:polyvec.c     ****       r[10] = (t[7] >>  3);
  40:polyvec.c     ****       r += 11;
  41:polyvec.c     ****     }
