  13:polyvec.c     **** *              - polyvec *a: pointer to input vector of polynomials
  14:polyvec.c     **** **************************************************/
  15:polyvec.c     **** void polyvec_compress(uint8_t r[KYBER_POLYVECCOMPRESSEDBYTES], polyvec *a)
  16:polyvec.c     **** {
