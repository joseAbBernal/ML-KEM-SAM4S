  11:indcpa.c      **** /*************************************************
  12:indcpa.c      **** * Name:        pack_pk
  13:indcpa.c      **** *
  14:indcpa.c      **** * Description: Serialize the public key as concatenation of the
  15:indcpa.c      **** *              serialized vector of polynomials pk
  16:indcpa.c      **** *              and the public seed used to generate the matrix A.
  17:indcpa.c      **** *
  18:indcpa.c      **** * Arguments:   uint8_t *r:          pointer to the output serialized public key
  19:indcpa.c      **** *              polyvec *pk:         pointer to the input public-key polyvec
  20:indcpa.c      **** *              const uint8_t *seed: pointer to the input public seed
  21:indcpa.c      **** **************************************************/
  22:indcpa.c      **** static void pack_pk(uint8_t r[KYBER_INDCPA_PUBLICKEYBYTES],
  23:indcpa.c      ****                     polyvec *pk,
  24:indcpa.c      ****                     const uint8_t seed[KYBER_SYMBYTES])
  25:indcpa.c      **** {
  26:indcpa.c      ****   size_t i;
  27:indcpa.c      ****   polyvec_tobytes(r, pk);
  28:indcpa.c      ****   for(i=0;i<KYBER_SYMBYTES;i++)
  29:indcpa.c      ****     r[i+KYBER_POLYVECBYTES] = seed[i];
  30:indcpa.c      **** }
  31:indcpa.c      **** 
  32:indcpa.c      **** /*************************************************
  33:indcpa.c      **** * Name:        unpack_pk
  34:indcpa.c      **** *
  35:indcpa.c      **** * Description: De-serialize public key from a byte array;
  36:indcpa.c      **** *              approximate inverse of pack_pk
  37:indcpa.c      **** *
  38:indcpa.c      **** * Arguments:   - polyvec *pk:             pointer to output public-key
  39:indcpa.c      **** *                                         polynomial vector
  40:indcpa.c      **** *              - uint8_t *seed:           pointer to output seed to generate
  41:indcpa.c      **** *                                         matrix A
  42:indcpa.c      **** *              - const uint8_t *packedpk: pointer to input serialized public key
  43:indcpa.c      **** **************************************************/
  44:indcpa.c      **** static void unpack_pk(polyvec *pk,
  45:indcpa.c      ****                       uint8_t seed[KYBER_SYMBYTES],
  46:indcpa.c      ****                       const uint8_t packedpk[KYBER_INDCPA_PUBLICKEYBYTES])
  47:indcpa.c      **** {
  48:indcpa.c      ****   size_t i;
  49:indcpa.c      ****   polyvec_frombytes(pk, packedpk);
  50:indcpa.c      ****   for(i=0;i<KYBER_SYMBYTES;i++)
  51:indcpa.c      ****     seed[i] = packedpk[i+KYBER_POLYVECBYTES];
  52:indcpa.c      **** }
  53:indcpa.c      **** 
  54:indcpa.c      **** /*************************************************
  55:indcpa.c      **** * Name:        pack_sk
  56:indcpa.c      **** *
  57:indcpa.c      **** * Description: Serialize the secret key
  58:indcpa.c      **** *
  59:indcpa.c      **** * Arguments:   - uint8_t *r:  pointer to output serialized secret key
  60:indcpa.c      **** *              - polyvec *sk: pointer to input vector of polynomials (secret key)
  61:indcpa.c      **** **************************************************/
  62:indcpa.c      **** static void pack_sk(uint8_t r[KYBER_INDCPA_SECRETKEYBYTES], polyvec *sk)
  63:indcpa.c      **** {
  64:indcpa.c      ****   polyvec_tobytes(r, sk);
  65:indcpa.c      **** }
  66:indcpa.c      **** 
  67:indcpa.c      **** /*************************************************
  68:indcpa.c      **** * Name:        unpack_sk
  69:indcpa.c      **** *
  70:indcpa.c      **** * Description: De-serialize the secret key;
  71:indcpa.c      **** *              inverse of pack_sk
  72:indcpa.c      **** *
  73:indcpa.c      **** * Arguments:   - polyvec *sk:             pointer to output vector of
  74:indcpa.c      **** *                                         polynomials (secret key)
  75:indcpa.c      **** *              - const uint8_t *packedsk: pointer to input serialized secret key
  76:indcpa.c      **** **************************************************/
  77:indcpa.c      **** static void unpack_sk(polyvec *sk,
  78:indcpa.c      ****                       const uint8_t packedsk[KYBER_INDCPA_SECRETKEYBYTES])
  79:indcpa.c      **** {
  80:indcpa.c      ****   polyvec_frombytes(sk, packedsk);
  81:indcpa.c      **** }
  82:indcpa.c      **** 
  83:indcpa.c      **** /*************************************************
  84:indcpa.c      **** * Name:        pack_ciphertext
  85:indcpa.c      **** *
  86:indcpa.c      **** * Description: Serialize the ciphertext as concatenation of the
  87:indcpa.c      **** *              compressed and serialized vector of polynomials b
  88:indcpa.c      **** *              and the compressed and serialized polynomial v
  89:indcpa.c      **** *
  90:indcpa.c      **** * Arguments:   uint8_t *r: pointer to the output serialized ciphertext
  91:indcpa.c      **** *              poly *pk:   pointer to the input vector of polynomials b
  92:indcpa.c      **** *              poly *v:    pointer to the input polynomial v
  93:indcpa.c      **** **************************************************/
  94:indcpa.c      **** static void pack_ciphertext(uint8_t r[KYBER_INDCPA_BYTES],
  95:indcpa.c      ****                             polyvec *b,
  96:indcpa.c      ****                             poly *v)
  97:indcpa.c      **** {
  98:indcpa.c      ****   polyvec_compress(r, b);
  99:indcpa.c      ****   poly_compress(r+KYBER_POLYVECCOMPRESSEDBYTES, v);
 100:indcpa.c      **** }
 101:indcpa.c      **** 
 102:indcpa.c      **** /*************************************************
 103:indcpa.c      **** * Name:        unpack_ciphertext
 104:indcpa.c      **** *
 105:indcpa.c      **** * Description: De-serialize and decompress ciphertext from a byte array;
 106:indcpa.c      **** *              approximate inverse of pack_ciphertext
 107:indcpa.c      **** *
 108:indcpa.c      **** * Arguments:   - polyvec *b:       pointer to the output vector of polynomials b
 109:indcpa.c      **** *              - poly *v:          pointer to the output polynomial v
 110:indcpa.c      **** *              - const uint8_t *c: pointer to the input serialized ciphertext
 111:indcpa.c      **** **************************************************/
 112:indcpa.c      **** static void unpack_ciphertext(polyvec *b,
 113:indcpa.c      ****                               poly *v,
 114:indcpa.c      ****                               const uint8_t c[KYBER_INDCPA_BYTES])
 115:indcpa.c      **** {
 116:indcpa.c      ****   polyvec_decompress(b, c);
 117:indcpa.c      ****   poly_decompress(v, c+KYBER_POLYVECCOMPRESSEDBYTES);
 118:indcpa.c      **** }
