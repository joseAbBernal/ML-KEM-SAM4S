 191:poly.c        **** /*************************************************
 192:poly.c        **** * Name:        poly_tomsg
 193:poly.c        **** *
 194:poly.c        **** * Description: Convert polynomial to 32-byte message
 195:poly.c        **** *
 196:poly.c        **** * Arguments:   - uint8_t *msg: pointer to output message
 197:poly.c        **** *              - poly *a:      pointer to input polynomial
 198:poly.c        **** **************************************************/
 199:poly.c        **** void poly_tomsg(uint8_t msg[KYBER_INDCPA_MSGBYTES], poly *a)
 200:poly.c        **** {
 201:poly.c        ****   unsigned int i,j;
 202:poly.c        ****   uint16_t t;
 203:poly.c        **** 
 204:poly.c        ****   poly_csubq(a);
 205:poly.c        **** 
 206:poly.c        ****   for(i=0;i<KYBER_N/8;i++) {
 207:poly.c        ****     msg[i] = 0;
 208:poly.c        ****     for(j=0;j<8;j++) {
 209:poly.c        ****       t = ((((uint16_t)a->coeffs[8*i+j] << 1) + KYBER_Q/2)/KYBER_Q) & 1;
 210:poly.c        ****       msg[i] |= t << j;
 211:poly.c        ****     }
 212:poly.c        ****   }
 213:poly.c        **** }
