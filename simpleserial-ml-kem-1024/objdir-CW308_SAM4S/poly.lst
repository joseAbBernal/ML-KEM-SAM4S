 122:poly.c        **** /*************************************************
 123:poly.c        **** * Name:        poly_tobytes
 124:poly.c        **** *
 125:poly.c        **** * Description: Serialization of a polynomial
 126:poly.c        **** *
 127:poly.c        **** * Arguments:   - uint8_t *r: pointer to output byte array
 128:poly.c        **** *                            (needs space for KYBER_POLYBYTES bytes)
 129:poly.c        **** *              - poly *a:    pointer to input polynomial
 130:poly.c        **** **************************************************/
 131:poly.c        **** void poly_tobytes(uint8_t r[KYBER_POLYBYTES], poly *a)
 132:poly.c        **** {
 133:poly.c        ****   unsigned int i;
 134:poly.c        ****   uint16_t t0, t1;
 135:poly.c        **** 
 136:poly.c        ****   poly_csubq(a);
 137:poly.c        **** 
 138:poly.c        ****   for(i=0;i<KYBER_N/2;i++) {
 139:poly.c        ****     t0 = a->coeffs[2*i];
 140:poly.c        ****     t1 = a->coeffs[2*i+1];
 141:poly.c        ****     r[3*i+0] = (t0 >> 0);
 142:poly.c        ****     r[3*i+1] = (t0 >> 8) | (t1 << 4);
 143:poly.c        ****     r[3*i+2] = (t1 >> 4);
 144:poly.c        ****   }
 145:poly.c        **** }
