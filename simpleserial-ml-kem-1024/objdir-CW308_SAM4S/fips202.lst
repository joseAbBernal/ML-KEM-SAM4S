 349:fips202.c     **** /*************************************************
 350:fips202.c     **** * Name:        keccak_absorb
 351:fips202.c     **** *
 352:fips202.c     **** * Description: Absorb step of Keccak;
 353:fips202.c     **** *              non-incremental, starts by zeroeing the state.
 354:fips202.c     **** *
 355:fips202.c     **** * Arguments:   - uint64_t *s: pointer to (uninitialized) output Keccak state
 356:fips202.c     **** *              - unsigned int r: rate in bytes (e.g., 168 for SHAKE128)
 357:fips202.c     **** *              - const uint8_t *m: pointer to input to be absorbed into s
 358:fips202.c     **** *              - size_t mlen: length of input in bytes
 359:fips202.c     **** *              - uint8_t p: domain-separation byte for different
 360:fips202.c     **** *                           Keccak-derived functions
 361:fips202.c     **** **************************************************/
 362:fips202.c     **** static void keccak_absorb(uint64_t s[25],
 363:fips202.c     ****                           unsigned int r,
 364:fips202.c     ****                           const uint8_t *m,
 365:fips202.c     ****                           size_t mlen,
 366:fips202.c     ****                           uint8_t p)
 367:fips202.c     **** {
 368:fips202.c     ****   size_t i;
 369:fips202.c     ****   uint8_t t[200] = {0};
 370:fips202.c     **** 
 371:fips202.c     ****   /* Zero state */
 372:fips202.c     ****   for(i=0;i<25;i++)
 373:fips202.c     ****     s[i] = 0;
 374:fips202.c     **** 
 375:fips202.c     ****   while(mlen >= r) {
 376:fips202.c     ****     for(i=0;i<r/8;i++)
 377:fips202.c     ****       s[i] ^= load64(m + 8*i);
 378:fips202.c     **** 
