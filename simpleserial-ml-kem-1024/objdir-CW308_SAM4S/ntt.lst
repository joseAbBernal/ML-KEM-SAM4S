  68:ntt.c         **** /*************************************************
  69:ntt.c         **** * Name:        fqmul
  70:ntt.c         **** *
  71:ntt.c         **** * Description: Multiplication followed by Montgomery reduction
  72:ntt.c         **** *
  73:ntt.c         **** * Arguments:   - int16_t a: first factor
  74:ntt.c         **** *              - int16_t b: second factor
  75:ntt.c         **** *
  76:ntt.c         **** * Returns 16-bit integer congruent to a*b*R^{-1} mod q
  77:ntt.c         **** **************************************************/
  78:ntt.c         **** static int16_t fqmul(int16_t a, int16_t b) {
  79:ntt.c         ****   return montgomery_reduce((int32_t)a*b);
  80:ntt.c         **** }
  81:ntt.c         **** 
