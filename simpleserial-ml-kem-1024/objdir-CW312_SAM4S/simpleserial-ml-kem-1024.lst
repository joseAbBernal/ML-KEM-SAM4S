 301:simpleserial-ml-kem-1024.c **** 
 302:simpleserial-ml-kem-1024.c **** /* Generate keypair - 'k' command */
 303:simpleserial-ml-kem-1024.c **** uint8_t get_key(uint8_t* k, uint8_t len)
 304:simpleserial-ml-kem-1024.c **** {
 305:simpleserial-ml-kem-1024.c ****     trigger_high();
 306:simpleserial-ml-kem-1024.c ****     crypto_kem_keypair(pk, sk);
 307:simpleserial-ml-kem-1024.c ****     trigger_low();
 308:simpleserial-ml-kem-1024.c ****     
 309:simpleserial-ml-kem-1024.c ****     pk_loaded = 1;
 310:simpleserial-ml-kem-1024.c ****     sk_loaded = 1;
 311:simpleserial-ml-kem-1024.c ****     
 312:simpleserial-ml-kem-1024.c ****     /* Return public key */
 313:simpleserial-ml-kem-1024.c ****     simpleserial_put('p', MLKEM_PKBYTES, pk);
 314:simpleserial-ml-kem-1024.c ****     return 0;
 315:simpleserial-ml-kem-1024.c **** }
 316:simpleserial-ml-kem-1024.c **** 
 317:simpleserial-ml-kem-1024.c **** /* Get public key - 'p' command */
 318:simpleserial-ml-kem-1024.c **** uint8_t get_pk(uint8_t* p, uint8_t len)
 319:simpleserial-ml-kem-1024.c **** {
 320:simpleserial-ml-kem-1024.c ****     if (!pk_loaded) {
 321:simpleserial-ml-kem-1024.c ****         return 0x01; /* Error: no pk loaded */
 322:simpleserial-ml-kem-1024.c ****     }
 323:simpleserial-ml-kem-1024.c ****     simpleserial_put('p', MLKEM_PKBYTES, pk);
 324:simpleserial-ml-kem-1024.c ****     return 0;
 325:simpleserial-ml-kem-1024.c **** }
 326:simpleserial-ml-kem-1024.c **** 
 327:simpleserial-ml-kem-1024.c **** /* Get secret key - 's' command */
 328:simpleserial-ml-kem-1024.c **** uint8_t get_sk(uint8_t* s, uint8_t len)
 329:simpleserial-ml-kem-1024.c **** {
 330:simpleserial-ml-kem-1024.c ****     if (!sk_loaded) {
 331:simpleserial-ml-kem-1024.c ****         return 0x01; /* Error: no sk loaded */
 332:simpleserial-ml-kem-1024.c ****     }
 333:simpleserial-ml-kem-1024.c ****     simpleserial_put('s', MLKEM_SKBYTES, sk);
 334:simpleserial-ml-kem-1024.c ****     return 0;
 335:simpleserial-ml-kem-1024.c **** }
 336:simpleserial-ml-kem-1024.c **** 
 337:simpleserial-ml-kem-1024.c **** /* Load public key - 'l' command (variable length) */
 338:simpleserial-ml-kem-1024.c **** uint8_t load_pk(uint8_t* data, uint8_t len)
 339:simpleserial-ml-kem-1024.c **** {
 340:simpleserial-ml-kem-1024.c ****     uint16_t i;
 341:simpleserial-ml-kem-1024.c ****     uint8_t chunk;
 342:simpleserial-ml-kem-1024.c ****     
 343:simpleserial-ml-kem-1024.c ****     if (len < 2) return 0x01;
 344:simpleserial-ml-kem-1024.c ****     
 345:simpleserial-ml-kem-1024.c ****     chunk = data[0];
 346:simpleserial-ml-kem-1024.c ****     
 347:simpleserial-ml-kem-1024.c ****     /* Offset = chunk * 240, but limit to actual data size */
 348:simpleserial-ml-kem-1024.c ****     uint16_t offset = chunk * 240;
 349:simpleserial-ml-kem-1024.c ****     if (offset >= MLKEM_PKBYTES) {
 350:simpleserial-ml-kem-1024.c ****         return 0x02; /* Error: offset too large */
 351:simpleserial-ml-kem-1024.c ****     }
 352:simpleserial-ml-kem-1024.c ****     
 353:simpleserial-ml-kem-1024.c ****     /* Copy data (remaining bytes after chunk number) */
 354:simpleserial-ml-kem-1024.c ****     for (i = 1; i < len && (offset + i - 1) < MLKEM_PKBYTES; i++) {
 355:simpleserial-ml-kem-1024.c ****         pk[offset + i - 1] = data[i];
 356:simpleserial-ml-kem-1024.c ****     }
 357:simpleserial-ml-kem-1024.c ****     
 358:simpleserial-ml-kem-1024.c ****     /* Check if complete */
 359:simpleserial-ml-kem-1024.c ****     if (offset + len - 1 >= MLKEM_PKBYTES) {
 360:simpleserial-ml-kem-1024.c ****         pk_loaded = 1;
 361:simpleserial-ml-kem-1024.c ****     }
 362:simpleserial-ml-kem-1024.c ****     
 363:simpleserial-ml-kem-1024.c ****     return 0;
 364:simpleserial-ml-kem-1024.c **** }
 365:simpleserial-ml-kem-1024.c **** 
 366:simpleserial-ml-kem-1024.c **** /* Load secret key - 'm' command (variable length) */
 367:simpleserial-ml-kem-1024.c **** uint8_t load_sk(uint8_t* data, uint8_t len)
 368:simpleserial-ml-kem-1024.c **** {
 369:simpleserial-ml-kem-1024.c ****     uint16_t i;
 370:simpleserial-ml-kem-1024.c ****     uint8_t chunk;
 371:simpleserial-ml-kem-1024.c ****     
 372:simpleserial-ml-kem-1024.c ****     if (len < 2) return 0x01;
 373:simpleserial-ml-kem-1024.c ****     
 374:simpleserial-ml-kem-1024.c ****     chunk = data[0];
 375:simpleserial-ml-kem-1024.c ****     
 376:simpleserial-ml-kem-1024.c ****     uint16_t offset = chunk * 240;
 377:simpleserial-ml-kem-1024.c ****     if (offset >= MLKEM_SKBYTES) {
 378:simpleserial-ml-kem-1024.c ****         return 0x02;
 379:simpleserial-ml-kem-1024.c ****     }
 380:simpleserial-ml-kem-1024.c ****     
 381:simpleserial-ml-kem-1024.c ****     for (i = 1; i < len && (offset + i - 1) < MLKEM_SKBYTES; i++) {
 382:simpleserial-ml-kem-1024.c ****         sk[offset + i - 1] = data[i];
 383:simpleserial-ml-kem-1024.c ****     }
 384:simpleserial-ml-kem-1024.c ****     
 385:simpleserial-ml-kem-1024.c ****     if (offset + len - 1 >= MLKEM_SKBYTES) {
 386:simpleserial-ml-kem-1024.c ****         sk_loaded = 1;
 387:simpleserial-ml-kem-1024.c ****     }
 388:simpleserial-ml-kem-1024.c ****     
 389:simpleserial-ml-kem-1024.c ****     return 0;
 390:simpleserial-ml-kem-1024.c **** }
 391:simpleserial-ml-kem-1024.c **** 
 392:simpleserial-ml-kem-1024.c **** /* Encapsulate - 'e' command */
 393:simpleserial-ml-kem-1024.c **** uint8_t encaps(uint8_t* ct_in, uint8_t len)
 394:simpleserial-ml-kem-1024.c **** {
 395:simpleserial-ml-kem-1024.c ****     uint16_t i;
 396:simpleserial-ml-kem-1024.c ****     uint8_t chunk;
 397:simpleserial-ml-kem-1024.c ****     
 398:simpleserial-ml-kem-1024.c ****     if (!pk_loaded) {
 399:simpleserial-ml-kem-1024.c ****         return 0x01; /* Error: no pk loaded */
 400:simpleserial-ml-kem-1024.c ****     }
 401:simpleserial-ml-kem-1024.c ****     
 402:simpleserial-ml-kem-1024.c ****     /* If data provided, treat as pk to load */
 403:simpleserial-ml-kem-1024.c ****     if (len > 0) {
 404:simpleserial-ml-kem-1024.c ****         chunk = ct_in[0];
 405:simpleserial-ml-kem-1024.c ****         uint16_t offset = chunk * 240;
 406:simpleserial-ml-kem-1024.c ****         
 407:simpleserial-ml-kem-1024.c ****         if (offset < MLKEM_PKBYTES) {
 408:simpleserial-ml-kem-1024.c ****             for (i = 1; i < len && (offset + i - 1) < MLKEM_PKBYTES; i++) {
 409:simpleserial-ml-kem-1024.c ****                 pk[offset + i - 1] = ct_in[i];
 410:simpleserial-ml-kem-1024.c ****             }
 411:simpleserial-ml-kem-1024.c ****             if (offset + len - 1 >= MLKEM_PKBYTES) {
 412:simpleserial-ml-kem-1024.c ****                 pk_loaded = 1;
 413:simpleserial-ml-kem-1024.c ****             }
 414:simpleserial-ml-kem-1024.c ****             return 0x00;
 415:simpleserial-ml-kem-1024.c ****         }
 416:simpleserial-ml-kem-1024.c ****     }
 417:simpleserial-ml-kem-1024.c ****     
 418:simpleserial-ml-kem-1024.c ****     /* Perform encapsulation */
 419:simpleserial-ml-kem-1024.c ****     trigger_high();
 420:simpleserial-ml-kem-1024.c ****     crypto_kem_enc(ct, ss, pk);
 421:simpleserial-ml-kem-1024.c ****     trigger_low();
 422:simpleserial-ml-kem-1024.c ****     
 423:simpleserial-ml-kem-1024.c ****     ct_loaded = 1;
 424:simpleserial-ml-kem-1024.c ****     
 425:simpleserial-ml-kem-1024.c ****     /* Return ciphertext */
 426:simpleserial-ml-kem-1024.c ****     simpleserial_put('c', MLKEM_CTBYTES, ct);
 427:simpleserial-ml-kem-1024.c ****     return 0;
 428:simpleserial-ml-kem-1024.c **** }
 429:simpleserial-ml-kem-1024.c **** 
 430:simpleserial-ml-kem-1024.c **** /* Load ciphertext for decapsulation - 'c' command (variable length) */
 431:simpleserial-ml-kem-1024.c **** uint8_t load_ct(uint8_t* data, uint8_t len)
 432:simpleserial-ml-kem-1024.c **** {
 433:simpleserial-ml-kem-1024.c ****     uint16_t i;
 434:simpleserial-ml-kem-1024.c ****     uint8_t chunk;
 435:simpleserial-ml-kem-1024.c ****     
 436:simpleserial-ml-kem-1024.c ****     if (len < 2) return 0x01;
 437:simpleserial-ml-kem-1024.c ****     
 438:simpleserial-ml-kem-1024.c ****     chunk = data[0];
 439:simpleserial-ml-kem-1024.c ****     
 440:simpleserial-ml-kem-1024.c ****     uint16_t offset = chunk * 240;
 441:simpleserial-ml-kem-1024.c ****     if (offset >= MLKEM_CTBYTES) {
 442:simpleserial-ml-kem-1024.c ****         return 0x02;
 443:simpleserial-ml-kem-1024.c ****     }
 444:simpleserial-ml-kem-1024.c ****     
 445:simpleserial-ml-kem-1024.c ****     for (i = 1; i < len && (offset + i - 1) < MLKEM_CTBYTES; i++) {
 446:simpleserial-ml-kem-1024.c ****         ct[offset + i - 1] = data[i];
 447:simpleserial-ml-kem-1024.c ****     }
 448:simpleserial-ml-kem-1024.c ****     
 449:simpleserial-ml-kem-1024.c ****     if (offset + len - 1 >= MLKEM_CTBYTES) {
 450:simpleserial-ml-kem-1024.c ****         ct_loaded = 1;
 451:simpleserial-ml-kem-1024.c ****     }
 452:simpleserial-ml-kem-1024.c ****     
 453:simpleserial-ml-kem-1024.c ****     return 0;
 454:simpleserial-ml-kem-1024.c **** }
 455:simpleserial-ml-kem-1024.c **** 
 456:simpleserial-ml-kem-1024.c **** /* Decapsulate - 'd' command */
 457:simpleserial-ml-kem-1024.c **** uint8_t decaps(uint8_t* data, uint8_t len)
 458:simpleserial-ml-kem-1024.c **** {
 459:simpleserial-ml-kem-1024.c ****     uint16_t i;
 460:simpleserial-ml-kem-1024.c ****     uint8_t chunk;
 461:simpleserial-ml-kem-1024.c ****     
 462:simpleserial-ml-kem-1024.c ****     if (!sk_loaded) {
 463:simpleserial-ml-kem-1024.c ****         return 0x01; /* Error: no sk loaded */
 464:simpleserial-ml-kem-1024.c ****     }
 465:simpleserial-ml-kem-1024.c ****     
 466:simpleserial-ml-kem-1024.c ****     /* If data provided, treat as ct to load */
 467:simpleserial-ml-kem-1024.c ****     if (len > 0) {
 468:simpleserial-ml-kem-1024.c ****         chunk = data[0];
 469:simpleserial-ml-kem-1024.c ****         uint16_t offset = chunk * 240;
 470:simpleserial-ml-kem-1024.c ****         
 471:simpleserial-ml-kem-1024.c ****         if (offset < MLKEM_CTBYTES) {
 472:simpleserial-ml-kem-1024.c ****             for (i = 1; i < len && (offset + i - 1) < MLKEM_CTBYTES; i++) {
 473:simpleserial-ml-kem-1024.c ****                 ct[offset + i - 1] = data[i];
 474:simpleserial-ml-kem-1024.c ****             }
 475:simpleserial-ml-kem-1024.c ****             if (offset + len - 1 >= MLKEM_CTBYTES) {
 476:simpleserial-ml-kem-1024.c ****                 ct_loaded = 1;
 477:simpleserial-ml-kem-1024.c ****             }
 478:simpleserial-ml-kem-1024.c ****             
 479:simpleserial-ml-kem-1024.c ****             if (!ct_loaded) {
 480:simpleserial-ml-kem-1024.c ****                 return 0x00; /* ct not complete yet */
 481:simpleserial-ml-kem-1024.c ****             }
 482:simpleserial-ml-kem-1024.c ****         }
 483:simpleserial-ml-kem-1024.c ****     }
 484:simpleserial-ml-kem-1024.c ****     
 485:simpleserial-ml-kem-1024.c ****     if (!ct_loaded) {
 486:simpleserial-ml-kem-1024.c ****         return 0x02; /* Error: no ct loaded */
 487:simpleserial-ml-kem-1024.c ****     }
 488:simpleserial-ml-kem-1024.c ****     
 489:simpleserial-ml-kem-1024.c ****     /* Perform decapsulation */
 490:simpleserial-ml-kem-1024.c ****     trigger_high();
 491:simpleserial-ml-kem-1024.c ****     crypto_kem_dec(ss, ct, sk);
 492:simpleserial-ml-kem-1024.c ****     trigger_low();
 493:simpleserial-ml-kem-1024.c ****     
 494:simpleserial-ml-kem-1024.c ****     /* Return shared secret */
 495:simpleserial-ml-kem-1024.c ****     simpleserial_put('s', MLKEM_SSBYTES, ss);
 496:simpleserial-ml-kem-1024.c ****     return 0;
 497:simpleserial-ml-kem-1024.c **** }
 498:simpleserial-ml-kem-1024.c **** 
 499:simpleserial-ml-kem-1024.c **** /* Reset - 'x' command */
 500:simpleserial-ml-kem-1024.c **** uint8_t reset(uint8_t* x, uint8_t len)
 501:simpleserial-ml-kem-1024.c **** {
 502:simpleserial-ml-kem-1024.c ****     pk_loaded = 0;
 503:simpleserial-ml-kem-1024.c ****     sk_loaded = 0;
 504:simpleserial-ml-kem-1024.c ****     ct_loaded = 0;
 505:simpleserial-ml-kem-1024.c ****     return 0;
 506:simpleserial-ml-kem-1024.c **** }
