   1              	 .cpu cortex-m4
   2              	 .arch armv7e-m
   3              	 .fpu softvfp
   4              	 .eabi_attribute 20,1
   5              	 .eabi_attribute 21,1
   6              	 .eabi_attribute 23,3
   7              	 .eabi_attribute 24,1
   8              	 .eabi_attribute 25,1
   9              	 .eabi_attribute 26,1
  10              	 .eabi_attribute 30,4
  11              	 .eabi_attribute 34,1
  12              	 .eabi_attribute 18,4
  13              	 .file "simpleserial-ml-kem-1024.c"
  14              	 .text
  15              	.Ltext0:
  16              	 .cfi_sections .debug_frame
  17              	 .file 1 "simpleserial-ml-kem-1024.c"
  18              	 .section .text.mlkem_reset,"ax",%progbits
  19              	 .align 1
  20              	 .global mlkem_reset
  21              	 .syntax unified
  22              	 .thumb
  23              	 .thumb_func
  25              	mlkem_reset:
  26              	.LVL0:
  27              	.LFB3:
   1:simpleserial-ml-kem-1024.c **** /*
   2:simpleserial-ml-kem-1024.c ****     ML-KEM-1024 (Kyber1024) SimpleSerial Target
   3:simpleserial-ml-kem-1024.c ****     Adapted for ChipWhisperer
   4:simpleserial-ml-kem-1024.c ****     
   5:simpleserial-ml-kem-1024.c ****     This implements the ML-KEM-1024 key encapsulation mechanism
   6:simpleserial-ml-kem-1024.c ****     with SimpleSerial v1.x and v2.1 support.
   7:simpleserial-ml-kem-1024.c ****     
   8:simpleserial-ml-kem-1024.c ****     Protocol (SS 2.1):
   9:simpleserial-ml-kem-1024.c ****     - Command 0x01: Key generation (keypair)
  10:simpleserial-ml-kem-1024.c ****       - scmd 0x01: Generate keypair, return first chunk of pk
  11:simpleserial-ml-kem-1024.c ****       - scmd 0x02: Get pk chunk (buf[0]=chunk_num, returns 240 bytes)
  12:simpleserial-ml-kem-1024.c ****       - scmd 0x04: Get sk chunk (buf[0]=chunk_num, returns 240 bytes)
  13:simpleserial-ml-kem-1024.c ****       - scmd 0x10: Load pk chunk (buf[0]=chunk_num + 239 bytes data)
  14:simpleserial-ml-kem-1024.c ****       - scmd 0x20: Load sk chunk (buf[0]=chunk_num + 239 bytes data)
  15:simpleserial-ml-kem-1024.c ****     
  16:simpleserial-ml-kem-1024.c ****     - Command 0x02: Encapsulation
  17:simpleserial-ml-kem-1024.c ****       - scmd 0x01: Encapsulate using stored pk, return first chunk of ct
  18:simpleserial-ml-kem-1024.c ****       - scmd 0x02: Get ct chunk (buf[0]=chunk_num, returns 240 bytes)
  19:simpleserial-ml-kem-1024.c ****       - scmd 0x10: Load pk chunk for encapsulation
  20:simpleserial-ml-kem-1024.c ****     
  21:simpleserial-ml-kem-1024.c ****     - Command 0x03: Decapsulation
  22:simpleserial-ml-kem-1024.c ****       - scmd 0x01: Decapsulate using stored sk + ct, return ss (32 bytes)
  23:simpleserial-ml-kem-1024.c ****       - scmd 0x10: Load ct chunk for decapsulation
  24:simpleserial-ml-kem-1024.c ****     
  25:simpleserial-ml-kem-1024.c ****     For SS v1.x:
  26:simpleserial-ml-kem-1024.c ****     - 'k': Generate keypair
  27:simpleserial-ml-kem-1024.c ****     - 'p': Get public key (returns all 1568 bytes)
  28:simpleserial-ml-kem-1024.c ****     - 's': Get secret key (returns all 3168 bytes)
  29:simpleserial-ml-kem-1024.c ****     - 'e': Encapsulate (uses stored pk, returns ct)
  30:simpleserial-ml-kem-1024.c ****     - 'd': Decapsulate (uses stored sk + received ct, returns ss)
  31:simpleserial-ml-kem-1024.c ****     - 'x': Reset/clear stored keys
  32:simpleserial-ml-kem-1024.c **** */
  33:simpleserial-ml-kem-1024.c **** 
  34:simpleserial-ml-kem-1024.c **** #include "hal.h"
  35:simpleserial-ml-kem-1024.c **** #include "simpleserial.h"
  36:simpleserial-ml-kem-1024.c **** #include "api.h"
  37:simpleserial-ml-kem-1024.c **** #include "params.h"
  38:simpleserial-ml-kem-1024.c **** #include <stdint.h>
  39:simpleserial-ml-kem-1024.c **** #include <string.h>
  40:simpleserial-ml-kem-1024.c **** 
  41:simpleserial-ml-kem-1024.c **** /* ML-KEM-1024 sizes */
  42:simpleserial-ml-kem-1024.c **** #define MLKEM_PKBYTES  1568  /* Public key bytes */
  43:simpleserial-ml-kem-1024.c **** #define MLKEM_SKBYTES  3168  /* Secret key bytes */
  44:simpleserial-ml-kem-1024.c **** #define MLKEM_CTBYTES  1568  /* Ciphertext bytes */
  45:simpleserial-ml-kem-1024.c **** #define MLKEM_SSBYTES  32    /* Shared secret bytes */
  46:simpleserial-ml-kem-1024.c **** 
  47:simpleserial-ml-kem-1024.c **** #define CHUNK_SIZE 240       /* Max chunk size for SS 2.1 */
  48:simpleserial-ml-kem-1024.c **** 
  49:simpleserial-ml-kem-1024.c **** /* Storage for keys and ciphertext */
  50:simpleserial-ml-kem-1024.c **** static uint8_t pk[MLKEM_PKBYTES];
  51:simpleserial-ml-kem-1024.c **** static uint8_t sk[MLKEM_SKBYTES];
  52:simpleserial-ml-kem-1024.c **** static uint8_t ct[MLKEM_CTBYTES];
  53:simpleserial-ml-kem-1024.c **** static uint8_t ss[MLKEM_SSBYTES];
  54:simpleserial-ml-kem-1024.c **** 
  55:simpleserial-ml-kem-1024.c **** static int pk_loaded = 0;
  56:simpleserial-ml-kem-1024.c **** static int sk_loaded = 0;
  57:simpleserial-ml-kem-1024.c **** static int ct_loaded = 0;
  58:simpleserial-ml-kem-1024.c **** 
  59:simpleserial-ml-kem-1024.c **** /* Maximum number of chunks */
  60:simpleserial-ml-kem-1024.c **** #define MAX_PK_CHUNKS  ((MLKEM_PKBYTES + CHUNK_SIZE - 1) / CHUNK_SIZE)  /* 7 */
  61:simpleserial-ml-kem-1024.c **** #define MAX_SK_CHUNKS  ((MLKEM_SKBYTES + CHUNK_SIZE - 1) / CHUNK_SIZE)  /* 14 */
  62:simpleserial-ml-kem-1024.c **** #define MAX_CT_CHUNKS  ((MLKEM_CTBYTES + CHUNK_SIZE - 1) / CHUNK_SIZE)  /* 7 */
  63:simpleserial-ml-kem-1024.c **** 
  64:simpleserial-ml-kem-1024.c **** /*******************************************/
  65:simpleserial-ml-kem-1024.c **** /* SimpleSerial v2.1 Command Handler       */
  66:simpleserial-ml-kem-1024.c **** /*******************************************/
  67:simpleserial-ml-kem-1024.c **** 
  68:simpleserial-ml-kem-1024.c **** #if SS_VER == SS_VER_2_1
  69:simpleserial-ml-kem-1024.c **** 
  70:simpleserial-ml-kem-1024.c **** /* Command 0x01: Key Generation */
  71:simpleserial-ml-kem-1024.c **** uint8_t mlkem_keygen(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
  72:simpleserial-ml-kem-1024.c **** {
  73:simpleserial-ml-kem-1024.c ****     uint8_t chunk;
  74:simpleserial-ml-kem-1024.c ****     uint16_t offset;
  75:simpleserial-ml-kem-1024.c ****     uint8_t num_bytes;
  76:simpleserial-ml-kem-1024.c ****     
  77:simpleserial-ml-kem-1024.c ****     if (scmd == 0x01) {
  78:simpleserial-ml-kem-1024.c ****         /* Generate keypair */
  79:simpleserial-ml-kem-1024.c ****         trigger_high();
  80:simpleserial-ml-kem-1024.c ****         crypto_kem_keypair(pk, sk);
  81:simpleserial-ml-kem-1024.c ****         trigger_low();
  82:simpleserial-ml-kem-1024.c ****         
  83:simpleserial-ml-kem-1024.c ****         pk_loaded = 1;
  84:simpleserial-ml-kem-1024.c ****         sk_loaded = 1;
  85:simpleserial-ml-kem-1024.c ****         
  86:simpleserial-ml-kem-1024.c ****         /* Return first chunk of pk (240 bytes or less) */
  87:simpleserial-ml-kem-1024.c ****         num_bytes = (MLKEM_PKBYTES > CHUNK_SIZE) ? CHUNK_SIZE : MLKEM_PKBYTES;
  88:simpleserial-ml-kem-1024.c ****         memcpy(buf, pk, num_bytes);
  89:simpleserial-ml-kem-1024.c ****         return 0;
  90:simpleserial-ml-kem-1024.c ****     }
  91:simpleserial-ml-kem-1024.c ****     else if (scmd == 0x02) {
  92:simpleserial-ml-kem-1024.c ****         /* Get pk chunk */
  93:simpleserial-ml-kem-1024.c ****         if (len < 1) return SS_ERR_LEN;
  94:simpleserial-ml-kem-1024.c ****         chunk = buf[0];
  95:simpleserial-ml-kem-1024.c ****         offset = chunk * CHUNK_SIZE;
  96:simpleserial-ml-kem-1024.c ****         
  97:simpleserial-ml-kem-1024.c ****         if (offset >= MLKEM_PKBYTES) {
  98:simpleserial-ml-kem-1024.c ****             /* Return empty if beyond data */
  99:simpleserial-ml-kem-1024.c ****             return 0;
 100:simpleserial-ml-kem-1024.c ****         }
 101:simpleserial-ml-kem-1024.c ****         
 102:simpleserial-ml-kem-1024.c ****         num_bytes = ((MLKEM_PKBYTES - offset) > CHUNK_SIZE) ? CHUNK_SIZE : (MLKEM_PKBYTES - offset)
 103:simpleserial-ml-kem-1024.c ****         memcpy(buf, pk + offset, num_bytes);
 104:simpleserial-ml-kem-1024.c ****         return 0;
 105:simpleserial-ml-kem-1024.c ****     }
 106:simpleserial-ml-kem-1024.c ****     else if (scmd == 0x04) {
 107:simpleserial-ml-kem-1024.c ****         /* Get sk chunk */
 108:simpleserial-ml-kem-1024.c ****         if (len < 1) return SS_ERR_LEN;
 109:simpleserial-ml-kem-1024.c ****         chunk = buf[0];
 110:simpleserial-ml-kem-1024.c ****         offset = chunk * CHUNK_SIZE;
 111:simpleserial-ml-kem-1024.c ****         
 112:simpleserial-ml-kem-1024.c ****         if (offset >= MLKEM_SKBYTES) {
 113:simpleserial-ml-kem-1024.c ****             return 0;
 114:simpleserial-ml-kem-1024.c ****         }
 115:simpleserial-ml-kem-1024.c ****         
 116:simpleserial-ml-kem-1024.c ****         num_bytes = ((MLKEM_SKBYTES - offset) > CHUNK_SIZE) ? CHUNK_SIZE : (MLKEM_SKBYTES - offset)
 117:simpleserial-ml-kem-1024.c ****         memcpy(buf, sk + offset, num_bytes);
 118:simpleserial-ml-kem-1024.c ****         return 0;
 119:simpleserial-ml-kem-1024.c ****     }
 120:simpleserial-ml-kem-1024.c ****     else if (scmd == 0x10) {
 121:simpleserial-ml-kem-1024.c ****         /* Load pk chunk */
 122:simpleserial-ml-kem-1024.c ****         if (len < 1) return SS_ERR_LEN;
 123:simpleserial-ml-kem-1024.c ****         chunk = buf[0];
 124:simpleserial-ml-kem-1024.c ****         offset = chunk * CHUNK_SIZE;
 125:simpleserial-ml-kem-1024.c ****         
 126:simpleserial-ml-kem-1024.c ****         if (offset >= MLKEM_PKBYTES) {
 127:simpleserial-ml-kem-1024.c ****             return SS_ERR_LEN;
 128:simpleserial-ml-kem-1024.c ****         }
 129:simpleserial-ml-kem-1024.c ****         
 130:simpleserial-ml-kem-1024.c ****         /* Copy data (len-1 bytes of actual data) */
 131:simpleserial-ml-kem-1024.c ****         num_bytes = len - 1;
 132:simpleserial-ml-kem-1024.c ****         if (num_bytes + offset > MLKEM_PKBYTES) {
 133:simpleserial-ml-kem-1024.c ****             num_bytes = MLKEM_PKBYTES - offset;
 134:simpleserial-ml-kem-1024.c ****         }
 135:simpleserial-ml-kem-1024.c ****         memcpy(pk + offset, buf + 1, num_bytes);
 136:simpleserial-ml-kem-1024.c ****         
 137:simpleserial-ml-kem-1024.c ****         /* Check if full pk loaded */
 138:simpleserial-ml-kem-1024.c ****         if (offset + num_bytes >= MLKEM_PKBYTES) {
 139:simpleserial-ml-kem-1024.c ****             pk_loaded = 1;
 140:simpleserial-ml-kem-1024.c ****         }
 141:simpleserial-ml-kem-1024.c ****         return 0;
 142:simpleserial-ml-kem-1024.c ****     }
 143:simpleserial-ml-kem-1024.c ****     else if (scmd == 0x20) {
 144:simpleserial-ml-kem-1024.c ****         /* Load sk chunk */
 145:simpleserial-ml-kem-1024.c ****         if (len < 1) return SS_ERR_LEN;
 146:simpleserial-ml-kem-1024.c ****         chunk = buf[0];
 147:simpleserial-ml-kem-1024.c ****         offset = chunk * CHUNK_SIZE;
 148:simpleserial-ml-kem-1024.c ****         
 149:simpleserial-ml-kem-1024.c ****         if (offset >= MLKEM_SKBYTES) {
 150:simpleserial-ml-kem-1024.c ****             return SS_ERR_LEN;
 151:simpleserial-ml-kem-1024.c ****         }
 152:simpleserial-ml-kem-1024.c ****         
 153:simpleserial-ml-kem-1024.c ****         num_bytes = len - 1;
 154:simpleserial-ml-kem-1024.c ****         if (num_bytes + offset > MLKEM_SKBYTES) {
 155:simpleserial-ml-kem-1024.c ****             num_bytes = MLKEM_SKBYTES - offset;
 156:simpleserial-ml-kem-1024.c ****         }
 157:simpleserial-ml-kem-1024.c ****         memcpy(sk + offset, buf + 1, num_bytes);
 158:simpleserial-ml-kem-1024.c ****         
 159:simpleserial-ml-kem-1024.c ****         /* Check if full sk loaded */
 160:simpleserial-ml-kem-1024.c ****         if (offset + num_bytes >= MLKEM_SKBYTES) {
 161:simpleserial-ml-kem-1024.c ****             sk_loaded = 1;
 162:simpleserial-ml-kem-1024.c ****         }
 163:simpleserial-ml-kem-1024.c ****         return 0;
 164:simpleserial-ml-kem-1024.c ****     }
 165:simpleserial-ml-kem-1024.c ****     
 166:simpleserial-ml-kem-1024.c ****     return SS_ERR_CMD;
 167:simpleserial-ml-kem-1024.c **** }
 168:simpleserial-ml-kem-1024.c **** 
 169:simpleserial-ml-kem-1024.c **** /* Command 0x02: Encapsulation */
 170:simpleserial-ml-kem-1024.c **** uint8_t mlkem_encaps(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
 171:simpleserial-ml-kem-1024.c **** {
 172:simpleserial-ml-kem-1024.c ****     uint8_t chunk;
 173:simpleserial-ml-kem-1024.c ****     uint16_t offset;
 174:simpleserial-ml-kem-1024.c ****     uint8_t num_bytes;
 175:simpleserial-ml-kem-1024.c ****     
 176:simpleserial-ml-kem-1024.c ****     if (!pk_loaded) {
 177:simpleserial-ml-kem-1024.c ****         /* No pk loaded, cannot encapsulate */
 178:simpleserial-ml-kem-1024.c ****         return SS_ERR_CMD;
 179:simpleserial-ml-kem-1024.c ****     }
 180:simpleserial-ml-kem-1024.c ****     
 181:simpleserial-ml-kem-1024.c ****     if (scmd == 0x01) {
 182:simpleserial-ml-kem-1024.c ****         /* Perform encapsulation */
 183:simpleserial-ml-kem-1024.c ****         trigger_high();
 184:simpleserial-ml-kem-1024.c ****         crypto_kem_enc(ct, ss, pk);
 185:simpleserial-ml-kem-1024.c ****         trigger_low();
 186:simpleserial-ml-kem-1024.c ****         
 187:simpleserial-ml-kem-1024.c ****         ct_loaded = 1;
 188:simpleserial-ml-kem-1024.c ****         
 189:simpleserial-ml-kem-1024.c ****         /* Return first chunk of ct */
 190:simpleserial-ml-kem-1024.c ****         num_bytes = (MLKEM_CTBYTES > CHUNK_SIZE) ? CHUNK_SIZE : MLKEM_CTBYTES;
 191:simpleserial-ml-kem-1024.c ****         memcpy(buf, ct, num_bytes);
 192:simpleserial-ml-kem-1024.c ****         return 0;
 193:simpleserial-ml-kem-1024.c ****     }
 194:simpleserial-ml-kem-1024.c ****     else if (scmd == 0x02) {
 195:simpleserial-ml-kem-1024.c ****         /* Get ct chunk */
 196:simpleserial-ml-kem-1024.c ****         if (len < 1) return SS_ERR_LEN;
 197:simpleserial-ml-kem-1024.c ****         chunk = buf[0];
 198:simpleserial-ml-kem-1024.c ****         offset = chunk * CHUNK_SIZE;
 199:simpleserial-ml-kem-1024.c ****         
 200:simpleserial-ml-kem-1024.c ****         if (offset >= MLKEM_CTBYTES) {
 201:simpleserial-ml-kem-1024.c ****             return 0;
 202:simpleserial-ml-kem-1024.c ****         }
 203:simpleserial-ml-kem-1024.c ****         
 204:simpleserial-ml-kem-1024.c ****         num_bytes = ((MLKEM_CTBYTES - offset) > CHUNK_SIZE) ? CHUNK_SIZE : (MLKEM_CTBYTES - offset)
 205:simpleserial-ml-kem-1024.c ****         memcpy(buf, ct + offset, num_bytes);
 206:simpleserial-ml-kem-1024.c ****         return 0;
 207:simpleserial-ml-kem-1024.c ****     }
 208:simpleserial-ml-kem-1024.c ****     else if (scmd == 0x10) {
 209:simpleserial-ml-kem-1024.c ****         /* Load pk chunk for encapsulation */
 210:simpleserial-ml-kem-1024.c ****         if (len < 1) return SS_ERR_LEN;
 211:simpleserial-ml-kem-1024.c ****         chunk = buf[0];
 212:simpleserial-ml-kem-1024.c ****         offset = chunk * CHUNK_SIZE;
 213:simpleserial-ml-kem-1024.c ****         
 214:simpleserial-ml-kem-1024.c ****         if (offset >= MLKEM_PKBYTES) {
 215:simpleserial-ml-kem-1024.c ****             return SS_ERR_LEN;
 216:simpleserial-ml-kem-1024.c ****         }
 217:simpleserial-ml-kem-1024.c ****         
 218:simpleserial-ml-kem-1024.c ****         num_bytes = len - 1;
 219:simpleserial-ml-kem-1024.c ****         if (num_bytes + offset > MLKEM_PKBYTES) {
 220:simpleserial-ml-kem-1024.c ****             num_bytes = MLKEM_PKBYTES - offset;
 221:simpleserial-ml-kem-1024.c ****         }
 222:simpleserial-ml-kem-1024.c ****         memcpy(pk + offset, buf + 1, num_bytes);
 223:simpleserial-ml-kem-1024.c ****         
 224:simpleserial-ml-kem-1024.c ****         if (offset + num_bytes >= MLKEM_PKBYTES) {
 225:simpleserial-ml-kem-1024.c ****             pk_loaded = 1;
 226:simpleserial-ml-kem-1024.c ****         }
 227:simpleserial-ml-kem-1024.c ****         return 0;
 228:simpleserial-ml-kem-1024.c ****     }
 229:simpleserial-ml-kem-1024.c ****     
 230:simpleserial-ml-kem-1024.c ****     return SS_ERR_CMD;
 231:simpleserial-ml-kem-1024.c **** }
 232:simpleserial-ml-kem-1024.c **** 
 233:simpleserial-ml-kem-1024.c **** /* Command 0x03: Decapsulation */
 234:simpleserial-ml-kem-1024.c **** uint8_t mlkem_decaps(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
 235:simpleserial-ml-kem-1024.c **** {
 236:simpleserial-ml-kem-1024.c ****     uint8_t chunk;
 237:simpleserial-ml-kem-1024.c ****     uint16_t offset;
 238:simpleserial-ml-kem-1024.c ****     uint8_t num_bytes;
 239:simpleserial-ml-kem-1024.c ****     
 240:simpleserial-ml-kem-1024.c ****     if (!sk_loaded) {
 241:simpleserial-ml-kem-1024.c ****         /* No sk loaded, cannot decapsulate */
 242:simpleserial-ml-kem-1024.c ****         return SS_ERR_CMD;
 243:simpleserial-ml-kem-1024.c ****     }
 244:simpleserial-ml-kem-1024.c ****     
 245:simpleserial-ml-kem-1024.c ****     if (scmd == 0x01) {
 246:simpleserial-ml-kem-1024.c ****         /* Need ct loaded */
 247:simpleserial-ml-kem-1024.c ****         if (!ct_loaded) {
 248:simpleserial-ml-kem-1024.c ****             return SS_ERR_CMD;
 249:simpleserial-ml-kem-1024.c ****         }
 250:simpleserial-ml-kem-1024.c ****         
 251:simpleserial-ml-kem-1024.c ****         /* Perform decapsulation */
 252:simpleserial-ml-kem-1024.c ****         trigger_high();
 253:simpleserial-ml-kem-1024.c ****         crypto_kem_dec(ss, ct, sk);
 254:simpleserial-ml-kem-1024.c ****         trigger_low();
 255:simpleserial-ml-kem-1024.c ****         
 256:simpleserial-ml-kem-1024.c ****         /* Return shared secret (32 bytes) */
 257:simpleserial-ml-kem-1024.c ****         memcpy(buf, ss, MLKEM_SSBYTES);
 258:simpleserial-ml-kem-1024.c ****         return 0;
 259:simpleserial-ml-kem-1024.c ****     }
 260:simpleserial-ml-kem-1024.c ****     else if (scmd == 0x10) {
 261:simpleserial-ml-kem-1024.c ****         /* Load ct chunk for decapsulation */
 262:simpleserial-ml-kem-1024.c ****         if (len < 1) return SS_ERR_LEN;
 263:simpleserial-ml-kem-1024.c ****         chunk = buf[0];
 264:simpleserial-ml-kem-1024.c ****         offset = chunk * CHUNK_SIZE;
 265:simpleserial-ml-kem-1024.c ****         
 266:simpleserial-ml-kem-1024.c ****         if (offset >= MLKEM_CTBYTES) {
 267:simpleserial-ml-kem-1024.c ****             return SS_ERR_LEN;
 268:simpleserial-ml-kem-1024.c ****         }
 269:simpleserial-ml-kem-1024.c ****         
 270:simpleserial-ml-kem-1024.c ****         num_bytes = len - 1;
 271:simpleserial-ml-kem-1024.c ****         if (num_bytes + offset > MLKEM_CTBYTES) {
 272:simpleserial-ml-kem-1024.c ****             num_bytes = MLKEM_CTBYTES - offset;
 273:simpleserial-ml-kem-1024.c ****         }
 274:simpleserial-ml-kem-1024.c ****         memcpy(ct + offset, buf + 1, num_bytes);
 275:simpleserial-ml-kem-1024.c ****         
 276:simpleserial-ml-kem-1024.c ****         if (offset + num_bytes >= MLKEM_CTBYTES) {
 277:simpleserial-ml-kem-1024.c ****             ct_loaded = 1;
 278:simpleserial-ml-kem-1024.c ****         }
 279:simpleserial-ml-kem-1024.c ****         return 0;
 280:simpleserial-ml-kem-1024.c ****     }
 281:simpleserial-ml-kem-1024.c ****     
 282:simpleserial-ml-kem-1024.c ****     return SS_ERR_CMD;
 283:simpleserial-ml-kem-1024.c **** }
 284:simpleserial-ml-kem-1024.c **** 
 285:simpleserial-ml-kem-1024.c **** /* Reset command for SS 2.1 */
 286:simpleserial-ml-kem-1024.c **** uint8_t mlkem_reset(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
 287:simpleserial-ml-kem-1024.c **** {
  28              	 .loc 1 287 1 view-0
  29              	 .cfi_startproc
  30              	 
  31              	 
  32              	 
 288:simpleserial-ml-kem-1024.c ****     pk_loaded = 0;
  33              	 .loc 1 288 5 view .LVU1
  34              	 .loc 1 288 15 is_stmt 0 view .LVU2
  35 0000 034B     	 ldr r3,.L2
  36              	.LVL1:
  37              	 .loc 1 288 15 view .LVU3
  38 0002 0020     	 movs r0,#0
  39              	.LVL2:
  40              	 .loc 1 288 15 view .LVU4
  41 0004 1860     	 str r0,[r3]
