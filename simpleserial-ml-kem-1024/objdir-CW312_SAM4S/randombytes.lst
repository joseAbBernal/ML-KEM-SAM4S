  10:randombytes.c **** int randombytes(uint8_t *obuf, size_t len)
  11:randombytes.c **** {
  12:randombytes.c ****     union
  13:randombytes.c ****     {
  14:randombytes.c ****         unsigned char aschar[4];
  15:randombytes.c ****         uint32_t asint;
  16:randombytes.c ****     } random;
  17:randombytes.c **** 
  18:randombytes.c ****     while (len > 4)
  19:randombytes.c ****     {
  20:randombytes.c ****         random.asint = rng_get_random_blocking();
  21:randombytes.c ****         *obuf++ = random.aschar[0];
  22:randombytes.c ****         *obuf++ = random.aschar[1];
  23:randombytes.c ****         *obuf++ = random.aschar[2];
  24:randombytes.c ****         *obuf++ = random.aschar[3];
  25:randombytes.c ****         len -= 4;
  26:randombytes.c ****     }
  27:randombytes.c ****     if (len > 0)
  28:randombytes.c ****     {
  29:randombytes.c ****         for (random.asint = rng_get_random_blocking(); len > 0; --len)
  30:randombytes.c ****         {
  31:randombytes.c ****             *obuf++ = random.aschar[len - 1];
  32:randombytes.c ****         }
  33:randombytes.c ****     }
  34:randombytes.c **** 
  35:randombytes.c ****     return 0;
  36:randombytes.c **** }
