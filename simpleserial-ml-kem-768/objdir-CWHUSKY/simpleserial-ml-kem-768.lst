  18:simpleserial-ml-kem-768.c **** 
  19:simpleserial-ml-kem-768.c **** #include "api.h"
  20:simpleserial-ml-kem-768.c **** #include "hal.h"
  21:simpleserial-ml-kem-768.c **** #include "simpleserial.h"
  22:simpleserial-ml-kem-768.c **** #include <stdint.h>
  23:simpleserial-ml-kem-768.c **** #include <stdlib.h>
  24:simpleserial-ml-kem-768.c **** #include <string.h>
  25:simpleserial-ml-kem-768.c **** 
  26:simpleserial-ml-kem-768.c **** // ML-KEM-768 key sizes
  27:simpleserial-ml-kem-768.c **** #define MLKEM768_PUBLIC_KEY_BYTES  1184
  28:simpleserial-ml-kem-768.c **** #define MLKEM768_SECRET_KEY_BYTES   2400
  29:simpleserial-ml-kem-768.c **** #define MLKEM768_CIPHERTEXT_BYTES  1088
  30:simpleserial-ml-kem-768.c **** #define MLKEM768_SHARED_SECRET_BYTES 32
  31:simpleserial-ml-kem-768.c **** 
  32:simpleserial-ml-kem-768.c **** static uint8_t sk[MLKEM768_SECRET_KEY_BYTES];
  33:simpleserial-ml-kem-768.c **** static uint8_t pk[MLKEM768_PUBLIC_KEY_BYTES];
  34:simpleserial-ml-kem-768.c **** 
  35:simpleserial-ml-kem-768.c **** /**
  36:simpleserial-ml-kem-768.c ****  * Generate keypair - command 'k'
  37:simpleserial-ml-kem-768.c ****  * Input: None
  38:simpleserial-ml-kem-768.c ****  * Output: Public key (pk) and stores secret key internally
  39:simpleserial-ml-kem-768.c ****  */
  40:simpleserial-ml-kem-768.c **** uint8_t get_key(uint8_t* k, uint8_t len)
  41:simpleserial-ml-kem-768.c **** {
  42:simpleserial-ml-kem-768.c ****     (void)len;
  43:simpleserial-ml-kem-768.c ****     (void)k;
  44:simpleserial-ml-kem-768.c ****     
  45:simpleserial-ml-kem-768.c ****     // Generate keypair
  46:simpleserial-ml-kem-768.c ****     crypto_kem_keypair(pk, sk);
  47:simpleserial-ml-kem-768.c ****     
  48:simpleserial-ml-kem-768.c ****     // Return public key
  49:simpleserial-ml-kem-768.c ****     simpleserial_put('r', MLKEM768_PUBLIC_KEY_BYTES, pk);
  50:simpleserial-ml-kem-768.c ****     return 0x00;
  51:simpleserial-ml-kem-768.c **** }
  52:simpleserial-ml-kem-768.c **** 
  53:simpleserial-ml-kem-768.c **** /**
  54:simpleserial-ml-kem-768.c ****  * Set secret key - command 's' 
  55:simpleserial-ml-kem-768.c ****  * Input: Secret key (sk)
  56:simpleserial-ml-kem-768.c ****  * Output: None
  57:simpleserial-ml-kem-768.c ****  */
  58:simpleserial-ml-kem-768.c **** uint8_t set_sk(uint8_t* sk_in, uint8_t len)
  59:simpleserial-ml-kem-768.c **** {
  60:simpleserial-ml-kem-768.c ****     if(len != MLKEM768_SECRET_KEY_BYTES)
  61:simpleserial-ml-kem-768.c ****         return 0x01;
  62:simpleserial-ml-kem-768.c ****     
  63:simpleserial-ml-kem-768.c ****     memcpy(sk, sk_in, MLKEM768_SECRET_KEY_BYTES);
  64:simpleserial-ml-kem-768.c ****     return 0x00;
  65:simpleserial-ml-kem-768.c **** }
  66:simpleserial-ml-kem-768.c **** 
  67:simpleserial-ml-kem-768.c **** /**
  68:simpleserial-ml-kem-768.c ****  * Set public key - command 'p'
  69:simpleserial-ml-kem-768.c ****  * Input: Public key (pk)
  70:simpleserial-ml-kem-768.c ****  * Output: None
  71:simpleserial-ml-kem-768.c ****  */
  72:simpleserial-ml-kem-768.c **** uint8_t set_pk(uint8_t* pk_in, uint8_t len)
  73:simpleserial-ml-kem-768.c **** {
  74:simpleserial-ml-kem-768.c ****     if(len != MLKEM768_PUBLIC_KEY_BYTES)
  75:simpleserial-ml-kem-768.c ****         return 0x01;
  76:simpleserial-ml-kem-768.c ****     
  77:simpleserial-ml-kem-768.c ****     memcpy(pk, pk_in, MLKEM768_PUBLIC_KEY_BYTES);
  78:simpleserial-ml-kem-768.c ****     return 0x00;
  79:simpleserial-ml-kem-768.c **** }
  80:simpleserial-ml-kem-768.c **** 
  81:simpleserial-ml-kem-768.c **** /**
  82:simpleserial-ml-kem-768.c ****  * Encrypt - command 'e'
  83:simpleserial-ml-kem-768.c ****  * Input: Public key (already set via 'p')
  84:simpleserial-ml-kem-768.c ****  * Output: Ciphertext (ct) and shared secret (ss)
  85:simpleserial-ml-kem-768.c ****  */
  86:simpleserial-ml-kem-768.c **** uint8_t do_enc(uint8_t* pt, uint8_t len)
  87:simpleserial-ml-kem-768.c **** {
  88:simpleserial-ml-kem-768.c ****     uint8_t ct[MLKEM768_CIPHERTEXT_BYTES];
  89:simpleserial-ml-kem-768.c ****     uint8_t ss[MLKEM768_SHARED_SECRET_BYTES];
  90:simpleserial-ml-kem-768.c ****     
  91:simpleserial-ml-kem-768.c ****     if(len != 0)
  92:simpleserial-ml-kem-768.c ****         return 0x01;
  93:simpleserial-ml-kem-768.c ****     
  94:simpleserial-ml-kem-768.c ****     trigger_high();
  95:simpleserial-ml-kem-768.c ****     
  96:simpleserial-ml-kem-768.c ****     // Encrypt using public key
  97:simpleserial-ml-kem-768.c ****     crypto_kem_enc(ct, ss, pk);
  98:simpleserial-ml-kem-768.c ****     
  99:simpleserial-ml-kem-768.c ****     trigger_low();
 100:simpleserial-ml-kem-768.c ****     
 101:simpleserial-ml-kem-768.c ****     // Return ciphertext and shared secret
 102:simpleserial-ml-kem-768.c ****     simpleserial_put('c', MLKEM768_CIPHERTEXT_BYTES, ct);
 103:simpleserial-ml-kem-768.c ****     simpleserial_put('s', MLKEM768_SHARED_SECRET_BYTES, ss);
 104:simpleserial-ml-kem-768.c ****     return 0x00;
 105:simpleserial-ml-kem-768.c **** }
 106:simpleserial-ml-kem-768.c **** 
 107:simpleserial-ml-kem-768.c **** /**
 108:simpleserial-ml-kem-768.c ****  * Decrypt - command 'd'
 109:simpleserial-ml-kem-768.c ****  * Input: Ciphertext (ct)
 110:simpleserial-ml-kem-768.c ****  * Output: Shared secret (ss)
 111:simpleserial-ml-kem-768.c ****  */
 112:simpleserial-ml-kem-768.c **** uint8_t do_dec(uint8_t* ct, uint8_t len)
 113:simpleserial-ml-kem-768.c **** {
 114:simpleserial-ml-kem-768.c ****     uint8_t ss[MLKEM768_SHARED_SECRET_BYTES];
 115:simpleserial-ml-kem-768.c ****     
 116:simpleserial-ml-kem-768.c ****     if(len != MLKEM768_CIPHERTEXT_BYTES)
 117:simpleserial-ml-kem-768.c ****         return 0x01;
 118:simpleserial-ml-kem-768.c ****     
 119:simpleserial-ml-kem-768.c ****     trigger_high();
 120:simpleserial-ml-kem-768.c ****     
 121:simpleserial-ml-kem-768.c ****     // Decrypt using secret key
 122:simpleserial-ml-kem-768.c ****     crypto_kem_dec(ss, ct, sk);
 123:simpleserial-ml-kem-768.c ****     
 124:simpleserial-ml-kem-768.c ****     trigger_low();
 125:simpleserial-ml-kem-768.c ****     
 126:simpleserial-ml-kem-768.c ****     // Return shared secret
 127:simpleserial-ml-kem-768.c ****     simpleserial_put('r', MLKEM768_SHARED_SECRET_BYTES, ss);
 128:simpleserial-ml-kem-768.c ****     return 0x00;
 129:simpleserial-ml-kem-768.c **** }
 130:simpleserial-ml-kem-768.c **** 
 131:simpleserial-ml-kem-768.c **** /**
 132:simpleserial-ml-kem-768.c ****  * Reset - command 'x'
 133:simpleserial-ml-kem-768.c ****  */
 134:simpleserial-ml-kem-768.c **** uint8_t reset(uint8_t* x, uint8_t len)
 135:simpleserial-ml-kem-768.c **** {
 136:simpleserial-ml-kem-768.c ****     (void)x;
 137:simpleserial-ml-kem-768.c ****     (void)len;
 138:simpleserial-ml-kem-768.c ****     // Reset keys if needed
 139:simpleserial-ml-kem-768.c ****     return 0x00;
 140:simpleserial-ml-kem-768.c **** }
 141:simpleserial-ml-kem-768.c **** 
