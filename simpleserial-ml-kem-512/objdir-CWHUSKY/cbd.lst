   5:cbd.c         **** /*************************************************
   6:cbd.c         **** * Name:        load32_littleendian
   7:cbd.c         **** *
   8:cbd.c         **** * Description: load 4 bytes into a 32-bit integer
   9:cbd.c         **** *              in little-endian order
  10:cbd.c         **** *
  11:cbd.c         **** * Arguments:   - const uint8_t *x: pointer to input byte array
  12:cbd.c         **** *
  13:cbd.c         **** * Returns 32-bit unsigned integer loaded from x
  14:cbd.c         **** **************************************************/
  15:cbd.c         **** static uint32_t load32_littleendian(const uint8_t x[4]) {
  16:cbd.c         ****     uint32_t r;
  17:cbd.c         ****     r  = (uint32_t)x[0];
  18:cbd.c         ****     r |= (uint32_t)x[1] << 8;
  19:cbd.c         ****     r |= (uint32_t)x[2] << 16;
  20:cbd.c         ****     r |= (uint32_t)x[3] << 24;
  21:cbd.c         ****     return r;
  22:cbd.c         **** }
  23:cbd.c         **** 
  24:cbd.c         **** /*************************************************
  25:cbd.c         **** * Name:        load24_littleendian
  26:cbd.c         **** *
  27:cbd.c         **** * Description: load 3 bytes into a 32-bit integer
  28:cbd.c         **** *              in little-endian order.
  29:cbd.c         **** *              This function is only needed for Kyber-512
  30:cbd.c         **** *
  31:cbd.c         **** * Arguments:   - const uint8_t *x: pointer to input byte array
  32:cbd.c         **** *
  33:cbd.c         **** * Returns 32-bit unsigned integer loaded from x (most significant byte is zero)
  34:cbd.c         **** **************************************************/
  35:cbd.c         **** static uint32_t load24_littleendian(const uint8_t x[3]) {
  36:cbd.c         ****     uint32_t r;
  37:cbd.c         ****     r  = (uint32_t)x[0];
  38:cbd.c         ****     r |= (uint32_t)x[1] << 8;
  39:cbd.c         ****     r |= (uint32_t)x[2] << 16;
  40:cbd.c         ****     return r;
  41:cbd.c         **** }
  42:cbd.c         **** 
  43:cbd.c         **** 
  44:cbd.c         **** /*************************************************
  45:cbd.c         **** * Name:        cbd2
  46:cbd.c         **** *
  47:cbd.c         **** * Description: Given an array of uniformly random bytes, compute
  48:cbd.c         **** *              polynomial with coefficients distributed according to
  49:cbd.c         **** *              a centered binomial distribution with parameter eta=2
  50:cbd.c         **** *
  51:cbd.c         **** * Arguments:   - poly *r: pointer to output polynomial
  52:cbd.c         **** *              - const uint8_t *buf: pointer to input byte array
  53:cbd.c         **** **************************************************/
  54:cbd.c         **** static void cbd2(poly *r, const uint8_t buf[2 * KYBER_N / 4]) {
  55:cbd.c         ****     unsigned int i, j;
  56:cbd.c         ****     uint32_t t, d;
  57:cbd.c         ****     int16_t a, b;
  58:cbd.c         **** 
  59:cbd.c         ****     for (i = 0; i < KYBER_N / 8; i++) {
  60:cbd.c         ****         t  = load32_littleendian(buf + 4 * i);
  61:cbd.c         ****         d  = t & 0x55555555;
  62:cbd.c         ****         d += (t >> 1) & 0x55555555;
  63:cbd.c         **** 
  64:cbd.c         ****         for (j = 0; j < 8; j++) {
  65:cbd.c         ****             a = (d >> (4 * j + 0)) & 0x3;
  66:cbd.c         ****             b = (d >> (4 * j + 2)) & 0x3;
  67:cbd.c         ****             r->coeffs[8 * i + j] = a - b;
  68:cbd.c         ****         }
  69:cbd.c         ****     }
  70:cbd.c         **** }
  71:cbd.c         **** 
  72:cbd.c         **** /*************************************************
  73:cbd.c         **** * Name:        cbd3
  74:cbd.c         **** *
  75:cbd.c         **** * Description: Given an array of uniformly random bytes, compute
  76:cbd.c         **** *              polynomial with coefficients distributed according to
  77:cbd.c         **** *              a centered binomial distribution with parameter eta=3.
  78:cbd.c         **** *              This function is only needed for Kyber-512
  79:cbd.c         **** *
  80:cbd.c         **** * Arguments:   - poly *r: pointer to output polynomial
  81:cbd.c         **** *              - const uint8_t *buf: pointer to input byte array
  82:cbd.c         **** **************************************************/
  83:cbd.c         **** static void cbd3(poly *r, const uint8_t buf[3 * KYBER_N / 4]) {
  84:cbd.c         ****     unsigned int i, j;
  85:cbd.c         ****     uint32_t t, d;
  86:cbd.c         ****     int16_t a, b;
  87:cbd.c         **** 
  88:cbd.c         ****     for (i = 0; i < KYBER_N / 4; i++) {
  89:cbd.c         ****         t  = load24_littleendian(buf + 3 * i);
  90:cbd.c         ****         d  = t & 0x00249249;
  91:cbd.c         ****         d += (t >> 1) & 0x00249249;
  92:cbd.c         ****         d += (t >> 2) & 0x00249249;
  93:cbd.c         **** 
  94:cbd.c         ****         for (j = 0; j < 4; j++) {
  95:cbd.c         ****             a = (d >> (6 * j + 0)) & 0x7;
  96:cbd.c         ****             b = (d >> (6 * j + 3)) & 0x7;
  97:cbd.c         ****             r->coeffs[4 * i + j] = a - b;
  98:cbd.c         ****         }
  99:cbd.c         ****     }
 100:cbd.c         **** }
 101:cbd.c         **** 
