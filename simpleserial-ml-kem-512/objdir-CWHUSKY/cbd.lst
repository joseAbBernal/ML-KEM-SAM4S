   6:cbd.c         **** /*************************************************
   7:cbd.c         **** * Name:        load32_littleendian
   8:cbd.c         **** *
   9:cbd.c         **** * Description: load bytes into a 32-bit integer
  10:cbd.c         **** *              in little-endian order
  11:cbd.c         **** *
  12:cbd.c         **** * Arguments:   - const unsigned char *x: pointer to input byte array
  13:cbd.c         **** *
  14:cbd.c         **** * Returns 32-bit unsigned integer loaded from x
  15:cbd.c         **** **************************************************/
  16:cbd.c         **** static uint32_t load32_littleendian(const unsigned char *x) {
  17:cbd.c         ****     uint32_t r;
  18:cbd.c         ****     r  = (uint32_t)x[0];
  19:cbd.c         ****     r |= (uint32_t)x[1] << 8;
  20:cbd.c         ****     r |= (uint32_t)x[2] << 16;
  21:cbd.c         ****     r |= (uint32_t)x[3] << 24;
  22:cbd.c         ****     return r;
  23:cbd.c         **** }
  24:cbd.c         **** 
  25:cbd.c         **** /*************************************************
  26:cbd.c         **** * Name:        load24_littleendian
  27:cbd.c         **** *
  28:cbd.c         **** * Description: load 3 bytes into a 32-bit integer
  29:cbd.c         **** *              in little-endian order
  30:cbd.c         **** *              This function is only needed for Kyber-512
  31:cbd.c         **** *
  32:cbd.c         **** * Arguments:   - const uint8_t *x: pointer to input byte array
  33:cbd.c         **** *
  34:cbd.c         **** * Returns 32-bit unsigned integer loaded from x (most significant byte is zero)
  35:cbd.c         **** **************************************************/
  36:cbd.c         **** static uint32_t load24_littleendian(const uint8_t x[3])
  37:cbd.c         **** {
  38:cbd.c         ****   uint32_t r;
  39:cbd.c         ****   r  = (uint32_t)x[0];
  40:cbd.c         ****   r |= (uint32_t)x[1] << 8;
  41:cbd.c         ****   r |= (uint32_t)x[2] << 16;
  42:cbd.c         ****   return r;
  43:cbd.c         **** }
  44:cbd.c         **** 
