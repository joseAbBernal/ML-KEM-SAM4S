 142:.././hal//sam4s/inc/osc.h ****  * \brief Determine whether oscillator \a id is ready.
 143:.././hal//sam4s/inc/osc.h ****  * \retval true Oscillator \a id is running and ready to use as a clock
 144:.././hal//sam4s/inc/osc.h ****  * source.
 145:.././hal//sam4s/inc/osc.h ****  * \retval false Oscillator \a id is not running.
 146:.././hal//sam4s/inc/osc.h ****  */
 147:.././hal//sam4s/inc/osc.h **** /**
 148:.././hal//sam4s/inc/osc.h ****  * \fn uint32_t osc_get_rate(uint8_t id)
 149:.././hal//sam4s/inc/osc.h ****  * \brief Return the frequency of oscillator \a id in Hz
 150:.././hal//sam4s/inc/osc.h ****  */
