  85:.././hal//sam4s/inc/sam4s/osc.h **** //! \name Oscillator identifiers
  86:.././hal//sam4s/inc/sam4s/osc.h **** //@{
  87:.././hal//sam4s/inc/sam4s/osc.h **** #define OSC_SLCK_32K_RC             0    //!< Internal 32kHz RC oscillator.
  88:.././hal//sam4s/inc/sam4s/osc.h **** #define OSC_SLCK_32K_XTAL           1    //!< External 32kHz crystal oscillator.
  89:.././hal//sam4s/inc/sam4s/osc.h **** #define OSC_SLCK_32K_BYPASS         2    //!< External 32kHz bypass oscillator.
  90:.././hal//sam4s/inc/sam4s/osc.h **** #define OSC_MAINCK_4M_RC            3    //!< Internal 4MHz RC oscillator.
  91:.././hal//sam4s/inc/sam4s/osc.h **** #define OSC_MAINCK_8M_RC            4    //!< Internal 8MHz RC oscillator.
  92:.././hal//sam4s/inc/sam4s/osc.h **** #define OSC_MAINCK_12M_RC           5    //!< Internal 12MHz RC oscillator.
  93:.././hal//sam4s/inc/sam4s/osc.h **** #define OSC_MAINCK_XTAL             6    //!< External crystal oscillator.
  94:.././hal//sam4s/inc/sam4s/osc.h **** #define OSC_MAINCK_BYPASS           7    //!< External bypass oscillator.
  95:.././hal//sam4s/inc/sam4s/osc.h **** //@}
  96:.././hal//sam4s/inc/sam4s/osc.h **** 
  97:.././hal//sam4s/inc/sam4s/osc.h **** //! \name Oscillator clock speed in hertz
  98:.././hal//sam4s/inc/sam4s/osc.h **** //@{
  99:.././hal//sam4s/inc/sam4s/osc.h **** #define OSC_SLCK_32K_RC_HZ          CHIP_FREQ_SLCK_RC               //!< Internal 32kHz RC oscillat
