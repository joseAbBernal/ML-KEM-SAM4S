 109:.././hal//sam4s/inc/sam4s/osc.h **** static inline void osc_enable(uint32_t ul_id)
 110:.././hal//sam4s/inc/sam4s/osc.h **** {
 111:.././hal//sam4s/inc/sam4s/osc.h **** 	switch (ul_id) {
 112:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_SLCK_32K_RC:
 113:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 114:.././hal//sam4s/inc/sam4s/osc.h **** 
 115:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_SLCK_32K_XTAL:
 116:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_switch_sclk_to_32kxtal(PMC_OSC_XTAL);
 117:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 118:.././hal//sam4s/inc/sam4s/osc.h **** 
 119:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_SLCK_32K_BYPASS:
 120:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_switch_sclk_to_32kxtal(PMC_OSC_BYPASS);
 121:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 122:.././hal//sam4s/inc/sam4s/osc.h **** 
 123:.././hal//sam4s/inc/sam4s/osc.h **** 
 124:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_4M_RC:
 125:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_switch_mainck_to_fastrc(CKGR_MOR_MOSCRCF_4_MHz);
 126:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 127:.././hal//sam4s/inc/sam4s/osc.h **** 
 128:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_8M_RC:
 129:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_switch_mainck_to_fastrc(CKGR_MOR_MOSCRCF_8_MHz);
 130:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 131:.././hal//sam4s/inc/sam4s/osc.h **** 
 132:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_12M_RC:
 133:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_switch_mainck_to_fastrc(CKGR_MOR_MOSCRCF_12_MHz);
 134:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 135:.././hal//sam4s/inc/sam4s/osc.h **** 
 136:.././hal//sam4s/inc/sam4s/osc.h **** 
 137:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_XTAL:
 138:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_switch_mainck_to_xtal(PMC_OSC_XTAL,
 139:.././hal//sam4s/inc/sam4s/osc.h **** 			pmc_us_to_moscxtst(BOARD_OSC_STARTUP_US,
 140:.././hal//sam4s/inc/sam4s/osc.h **** 				OSC_SLCK_32K_RC_HZ));
 141:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 142:.././hal//sam4s/inc/sam4s/osc.h **** 
 143:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_BYPASS:
 144:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_switch_mainck_to_xtal(PMC_OSC_BYPASS,
 145:.././hal//sam4s/inc/sam4s/osc.h **** 			pmc_us_to_moscxtst(BOARD_OSC_STARTUP_US,
 146:.././hal//sam4s/inc/sam4s/osc.h **** 				OSC_SLCK_32K_RC_HZ));
 147:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 148:.././hal//sam4s/inc/sam4s/osc.h **** 	}
 149:.././hal//sam4s/inc/sam4s/osc.h **** }
 150:.././hal//sam4s/inc/sam4s/osc.h **** 
 151:.././hal//sam4s/inc/sam4s/osc.h **** static inline void osc_disable(uint32_t ul_id)
 152:.././hal//sam4s/inc/sam4s/osc.h **** {
 153:.././hal//sam4s/inc/sam4s/osc.h **** 	switch (ul_id) {
 154:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_SLCK_32K_RC:
 155:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_SLCK_32K_XTAL:
 156:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_SLCK_32K_BYPASS:
 157:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 158:.././hal//sam4s/inc/sam4s/osc.h **** 
 159:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_4M_RC:
 160:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_8M_RC:
 161:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_12M_RC:
 162:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_osc_disable_fastrc();
 163:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 164:.././hal//sam4s/inc/sam4s/osc.h **** 
 165:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_XTAL:
 166:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_osc_disable_xtal(PMC_OSC_XTAL);
 167:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 168:.././hal//sam4s/inc/sam4s/osc.h **** 
 169:.././hal//sam4s/inc/sam4s/osc.h **** 	case OSC_MAINCK_BYPASS:
 170:.././hal//sam4s/inc/sam4s/osc.h **** 		pmc_osc_disable_xtal(PMC_OSC_BYPASS);
 171:.././hal//sam4s/inc/sam4s/osc.h **** 		break;
 172:.././hal//sam4s/inc/sam4s/osc.h **** 	}
 173:.././hal//sam4s/inc/sam4s/osc.h **** }
