 130:.././hal//sam4s/inc/osc.h ****  * \fn void osc_enable(uint8_t id)
 131:.././hal//sam4s/inc/osc.h ****  * \brief Enable oscillator \a id
 132:.././hal//sam4s/inc/osc.h ****  *
 133:.././hal//sam4s/inc/osc.h ****  * The startup time and mode value is automatically determined based on
 134:.././hal//sam4s/inc/osc.h ****  * definitions in the board code.
 135:.././hal//sam4s/inc/osc.h ****  */
 136:.././hal//sam4s/inc/osc.h **** /**
 137:.././hal//sam4s/inc/osc.h ****  * \fn void osc_disable(uint8_t id)
 138:.././hal//sam4s/inc/osc.h ****  * \brief Disable oscillator \a id
 139:.././hal//sam4s/inc/osc.h ****  */
 140:.././hal//sam4s/inc/osc.h **** /**
