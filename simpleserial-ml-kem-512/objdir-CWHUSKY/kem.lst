  60:kem.c         **** /*************************************************
  61:kem.c         **** * Name:        crypto_kem_enc_derand
  62:kem.c         **** *
  63:kem.c         **** * Description: Generates cipher text and shared
  64:kem.c         **** *              secret for given public key
  65:kem.c         **** *
  66:kem.c         **** * Arguments:   - uint8_t *ct: pointer to output cipher text
  67:kem.c         **** *                (an already allocated array of KYBER_CIPHERTEXTBYTES bytes)
  68:kem.c         **** *              - uint8_t *ss: pointer to output shared secret
  69:kem.c         **** *                (an already allocated array of KYBER_SSBYTES bytes)
  70:kem.c         **** *              - const uint8_t *pk: pointer to input public key
  71:kem.c         **** *                (an already allocated array of KYBER_PUBLICKEYBYTES bytes)
  72:kem.c         **** *              - const uint8_t *coins: pointer to input randomness
  73:kem.c         **** *                (an already allocated array filled with KYBER_SYMBYTES random bytes)
  74:kem.c         **** **
  75:kem.c         **** * Returns 0 (success)
  76:kem.c         **** **************************************************/
  77:kem.c         **** static int crypto_kem_enc_derand(uint8_t *ct,
  78:kem.c         ****         uint8_t *ss,
  79:kem.c         ****         const uint8_t *pk,
  80:kem.c         ****         const uint8_t *coins) {
  81:kem.c         ****     uint8_t buf[2 * KYBER_SYMBYTES];
  82:kem.c         ****     /* Will contain key, coins */
  83:kem.c         ****     uint8_t kr[2 * KYBER_SYMBYTES];
  84:kem.c         **** 
  85:kem.c         ****     memcpy(buf, coins, KYBER_SYMBYTES);
  86:kem.c         **** 
  87:kem.c         ****     /* Multitarget countermeasure for coins + contributory KEM */
  88:kem.c         ****     hash_h(buf + KYBER_SYMBYTES, pk, KYBER_PUBLICKEYBYTES);
  89:kem.c         ****     hash_g(kr, buf, 2 * KYBER_SYMBYTES);
  90:kem.c         **** 
  91:kem.c         ****     /* coins are in kr+KYBER_SYMBYTES */
  92:kem.c         ****     indcpa_enc(ct, buf, pk, kr + KYBER_SYMBYTES);
  93:kem.c         **** 
  94:kem.c         ****     memcpy(ss, kr, KYBER_SYMBYTES);
  95:kem.c         ****     return 0;
  96:kem.c         **** }
