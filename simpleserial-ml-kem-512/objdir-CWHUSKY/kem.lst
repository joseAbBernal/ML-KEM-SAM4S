  15:kem.c         **** /*************************************************
  16:kem.c         **** * Name:        crypto_kem_keypair_derand
  17:kem.c         **** *
  18:kem.c         **** * Description: Generates public and private key
  19:kem.c         **** *              for CCA-secure Kyber key encapsulation mechanism
  20:kem.c         **** *
  21:kem.c         **** * Arguments:   - uint8_t *pk: pointer to output public key
  22:kem.c         **** *                (an already allocated array of KYBER_PUBLICKEYBYTES bytes)
  23:kem.c         **** *              - uint8_t *sk: pointer to output private key
  24:kem.c         **** *                (an already allocated array of KYBER_SECRETKEYBYTES bytes)
  25:kem.c         **** *              - uint8_t *coins: pointer to input randomness
  26:kem.c         **** *                (an already allocated array filled with 2*KYBER_SYMBYTES random bytes)
  27:kem.c         **** **
  28:kem.c         **** * Returns 0 (success)
  29:kem.c         **** **************************************************/
  30:kem.c         **** static int crypto_kem_keypair_derand(uint8_t *pk,
  31:kem.c         ****         uint8_t *sk,
  32:kem.c         ****         const uint8_t *coins) {
  33:kem.c         ****     indcpa_keypair_derand(pk, sk, coins);
  34:kem.c         ****     memcpy(sk + KYBER_INDCPA_SECRETKEYBYTES, pk, KYBER_PUBLICKEYBYTES);
  35:kem.c         ****     hash_h(sk + KYBER_SECRETKEYBYTES - 2 * KYBER_SYMBYTES, pk, KYBER_PUBLICKEYBYTES);
  36:kem.c         ****     /* Value z for pseudo-random output on reject */
  37:kem.c         ****     memcpy(sk + KYBER_SECRETKEYBYTES - KYBER_SYMBYTES, coins + KYBER_SYMBYTES, KYBER_SYMBYTES);
  38:kem.c         ****     return 0;
  39:kem.c         **** }
