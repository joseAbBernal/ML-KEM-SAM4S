 161:randombytes.c **** 
 162:randombytes.c **** static int randombytes_linux_randombytes_getrandom(void *buf, size_t n) {
 163:randombytes.c ****     /* I have thought about using a separate PRF, seeded by getrandom, but
 164:randombytes.c ****      * it turns out that the performance of getrandom is good enough
 165:randombytes.c ****      * (250 MB/s on my laptop).
 166:randombytes.c ****      */
 167:randombytes.c ****     size_t offset = 0, chunk;
 168:randombytes.c ****     int ret;
 169:randombytes.c ****     while (n > 0) {
 170:randombytes.c ****         /* getrandom does not allow chunks larger than 33554431 */
 171:randombytes.c ****         chunk = n <= 33554431 ? n : 33554431;
 172:randombytes.c ****         do {
 173:randombytes.c ****             ret = getrandom((char *)buf + offset, chunk, 0);
 174:randombytes.c ****         } while (ret == -1 && errno == EINTR);
 175:randombytes.c ****         if (ret < 0) {
 176:randombytes.c ****             return ret;
 177:randombytes.c ****         }
 178:randombytes.c ****         offset += ret;
 179:randombytes.c ****         n -= ret;
 180:randombytes.c ****     }
 181:randombytes.c ****     assert(n == 0);
 182:randombytes.c ****     return 0;
 183:randombytes.c **** }
 184:randombytes.c **** #endif // defined(__linux__) && (defined(USE_GLIBC) || defined(SYS_getrandom))
 185:randombytes.c **** 
 186:randombytes.c **** #if defined(__linux__) && !defined(SYS_getrandom)
 187:randombytes.c **** static int randombytes_linux_read_entropy_ioctl(int device, int *entropy) {
 188:randombytes.c ****     return ioctl(device, RNDGETENTCNT, entropy);
 189:randombytes.c **** }
 190:randombytes.c **** 
 191:randombytes.c **** static int randombytes_linux_read_entropy_proc(FILE *stream, int *entropy) {
 192:randombytes.c ****     int retcode;
 193:randombytes.c ****     do {
 194:randombytes.c ****         rewind(stream);
 195:randombytes.c ****         retcode = fscanf(stream, "%d", entropy);
 196:randombytes.c ****     } while (retcode != 1 && errno == EINTR);
 197:randombytes.c ****     if (retcode != 1) {
 198:randombytes.c ****         return -1;
 199:randombytes.c ****     }
 200:randombytes.c ****     return 0;
 201:randombytes.c **** }
 202:randombytes.c **** 
 203:randombytes.c **** static int randombytes_linux_wait_for_entropy(int device) {
 204:randombytes.c ****     /* We will block on /dev/random, because any increase in the OS' entropy
 205:randombytes.c ****      * level will unblock the request. I use poll here (as does libsodium),
 206:randombytes.c ****      * because we don't *actually* want to read from the device. */
 207:randombytes.c ****     enum { IOCTL, PROC } strategy = IOCTL;
 208:randombytes.c ****     const int bits = 128;
 209:randombytes.c ****     struct pollfd pfd;
 210:randombytes.c ****     int fd;
 211:randombytes.c ****     FILE *proc_file;
 212:randombytes.c ****     int retcode, retcode_error = 0; // Used as return codes throughout this function
 213:randombytes.c ****     int entropy = 0;
 214:randombytes.c **** 
 215:randombytes.c ****     /* If the device has enough entropy already, we will want to return early */
 216:randombytes.c ****     retcode = randombytes_linux_read_entropy_ioctl(device, &entropy);
 217:randombytes.c ****     // printf("errno: %d (%s)\n", errno, strerror(errno));
 218:randombytes.c ****     if (retcode != 0 && (errno == ENOTTY || errno == ENOSYS)) {
 219:randombytes.c ****         // The ioctl call on /dev/urandom has failed due to a
 220:randombytes.c ****         //   - ENOTTY (unsupported action), or
 221:randombytes.c ****         //   - ENOSYS (invalid ioctl; this happens on MIPS, see #22).
 222:randombytes.c ****         //
 223:randombytes.c ****         // We will fall back to reading from
 224:randombytes.c ****         // `/proc/sys/kernel/random/entropy_avail`.  This less ideal,
 225:randombytes.c ****         // because it allocates a file descriptor, and it may not work
 226:randombytes.c ****         // in a chroot.  But at this point it seems we have no better
 227:randombytes.c ****         // options left.
 228:randombytes.c ****         strategy = PROC;
 229:randombytes.c ****         // Open the entropy count file
 230:randombytes.c ****         proc_file = fopen("/proc/sys/kernel/random/entropy_avail", "r");
 231:randombytes.c ****     } else if (retcode != 0) {
 232:randombytes.c ****         // Unrecoverable ioctl error
 233:randombytes.c ****         return -1;
 234:randombytes.c ****     }
 235:randombytes.c ****     if (entropy >= bits) {
 236:randombytes.c ****         return 0;
 237:randombytes.c ****     }
 238:randombytes.c **** 
 239:randombytes.c ****     do {
 240:randombytes.c ****         fd = open("/dev/random", O_RDONLY);
 241:randombytes.c ****     } while (fd == -1 && errno == EINTR); /* EAGAIN will not occur */
 242:randombytes.c ****     if (fd == -1) {
 243:randombytes.c ****         /* Unrecoverable IO error */
 244:randombytes.c ****         return -1;
 245:randombytes.c ****     }
 246:randombytes.c **** 
 247:randombytes.c ****     pfd.fd = fd;
 248:randombytes.c ****     pfd.events = POLLIN;
 249:randombytes.c ****     for (;;) {
 250:randombytes.c ****         retcode = poll(&pfd, 1, -1);
 251:randombytes.c ****         if (retcode == -1 && (errno == EINTR || errno == EAGAIN)) {
 252:randombytes.c ****             continue;
 253:randombytes.c ****         } else if (retcode == 1) {
 254:randombytes.c ****             if (strategy == IOCTL) {
 255:randombytes.c ****                 retcode = randombytes_linux_read_entropy_ioctl(device, &entropy);
 256:randombytes.c ****             } else if (strategy == PROC) {
 257:randombytes.c ****                 retcode = randombytes_linux_read_entropy_proc(proc_file, &entropy);
 258:randombytes.c ****             } else {
 259:randombytes.c ****                 return -1; // Unreachable
 260:randombytes.c ****             }
 261:randombytes.c **** 
 262:randombytes.c ****             if (retcode != 0) {
 263:randombytes.c ****                 // Unrecoverable I/O error
 264:randombytes.c ****                 retcode_error = retcode;
 265:randombytes.c ****                 break;
 266:randombytes.c ****             }
 267:randombytes.c ****             if (entropy >= bits) {
 268:randombytes.c ****                 break;
 269:randombytes.c ****             }
 270:randombytes.c ****         } else {
 271:randombytes.c ****             // Unreachable: poll() should only return -1 or 1
 272:randombytes.c ****             retcode_error = -1;
 273:randombytes.c ****             break;
 274:randombytes.c ****         }
 275:randombytes.c ****     }
 276:randombytes.c ****     do {
 277:randombytes.c ****         retcode = close(fd);
 278:randombytes.c ****     } while (retcode == -1 && errno == EINTR);
 279:randombytes.c ****     if (strategy == PROC) {
 280:randombytes.c ****         do {
 281:randombytes.c ****             retcode = fclose(proc_file);
 282:randombytes.c ****         } while (retcode == -1 && errno == EINTR);
 283:randombytes.c ****     }
 284:randombytes.c ****     if (retcode_error != 0) {
 285:randombytes.c ****         return retcode_error;
 286:randombytes.c ****     }
 287:randombytes.c ****     return retcode;
 288:randombytes.c **** }
 289:randombytes.c **** 
 290:randombytes.c **** static int randombytes_linux_randombytes_urandom(void *buf, size_t n) {
 291:randombytes.c ****     int fd;
 292:randombytes.c ****     size_t offset = 0, count;
 293:randombytes.c ****     ssize_t tmp;
 294:randombytes.c ****     do {
 295:randombytes.c ****         fd = open("/dev/urandom", O_RDONLY);
 296:randombytes.c ****     } while (fd == -1 && errno == EINTR);
 297:randombytes.c ****     if (fd == -1) {
 298:randombytes.c ****         return -1;
 299:randombytes.c ****     }
 300:randombytes.c ****     if (randombytes_linux_wait_for_entropy(fd) == -1) {
 301:randombytes.c ****         return -1;
 302:randombytes.c ****     }
 303:randombytes.c **** 
 304:randombytes.c ****     while (n > 0) {
 305:randombytes.c ****         count = n <= SSIZE_MAX ? n : SSIZE_MAX;
 306:randombytes.c ****         tmp = read(fd, (char *)buf + offset, count);
 307:randombytes.c ****         if (tmp == -1 && (errno == EAGAIN || errno == EINTR)) {
 308:randombytes.c ****             continue;
 309:randombytes.c ****         }
 310:randombytes.c ****         if (tmp == -1) {
 311:randombytes.c ****             return -1;    /* Unrecoverable IO error */
 312:randombytes.c ****         }
 313:randombytes.c ****         offset += tmp;
 314:randombytes.c ****         n -= tmp;
 315:randombytes.c ****     }
 316:randombytes.c ****     close(fd);
 317:randombytes.c ****     assert(n == 0);
 318:randombytes.c ****     return 0;
 319:randombytes.c **** }
 320:randombytes.c **** #endif /* defined(__linux__) && !defined(SYS_getrandom) */
 321:randombytes.c **** 
