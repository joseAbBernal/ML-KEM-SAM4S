  91:randombytes.c **** /* ARM embedded platforms - use simple XORShift PRNG */
  92:randombytes.c **** #include <stdint.h>
  93:randombytes.c **** 
  94:randombytes.c **** static uint32_t random_state = 0x12345678;
  95:randombytes.c **** 
  96:randombytes.c **** static void randombytes_arm_init(void) {
  97:randombytes.c ****     /* Initialize with a non-zero seed */
  98:randombytes.c ****     if (random_state == 0) {
  99:randombytes.c ****         random_state = 0x12345678;
 100:randombytes.c ****     }
 101:randombytes.c **** }
 102:randombytes.c **** 
 103:randombytes.c **** static uint32_t xorshift32(uint32_t x) {
 104:randombytes.c ****     x ^= x << 13;
 105:randombytes.c ****     x ^= x >> 17;
 106:randombytes.c ****     x ^= x << 5;
 107:randombytes.c ****     return x;
 108:randombytes.c **** }
 109:randombytes.c **** 
 110:randombytes.c **** static int randombytes_arm_randombytes(void *buf, size_t n) {
 111:randombytes.c ****     uint8_t *p = (uint8_t *)buf;
 112:randombytes.c ****     randombytes_arm_init();
 113:randombytes.c ****     while (n--) {
 114:randombytes.c ****         random_state = xorshift32(random_state);
 115:randombytes.c ****         *p++ = random_state & 0xFF;
 116:randombytes.c ****     }
 117:randombytes.c ****     return 0;
 118:randombytes.c **** }
 119:randombytes.c **** #endif /* defined(__arm__) */
 120:randombytes.c **** 
 121:randombytes.c **** #if defined(_WIN32)
 122:randombytes.c **** static int randombytes_win32_randombytes(void *buf, const size_t n) {
 123:randombytes.c ****     HCRYPTPROV ctx;
 124:randombytes.c ****     BOOL tmp;
 125:randombytes.c **** 
 126:randombytes.c ****     tmp = CryptAcquireContext(&ctx, NULL, NULL, PROV_RSA_FULL,
 127:randombytes.c ****                               CRYPT_VERIFYCONTEXT);
 128:randombytes.c ****     if (tmp == FALSE) {
 129:randombytes.c ****         return -1;
 130:randombytes.c ****     }
 131:randombytes.c **** 
 132:randombytes.c ****     tmp = CryptGenRandom(ctx, (unsigned long)n, (BYTE *) buf);
 133:randombytes.c ****     if (tmp == FALSE) {
 134:randombytes.c ****         return -1;
 135:randombytes.c ****     }
 136:randombytes.c **** 
 137:randombytes.c ****     tmp = CryptReleaseContext(ctx, 0);
 138:randombytes.c ****     if (tmp == FALSE) {
 139:randombytes.c ****         return -1;
 140:randombytes.c ****     }
 141:randombytes.c **** 
 142:randombytes.c ****     return 0;
 143:randombytes.c **** }
 144:randombytes.c **** #endif /* defined(_WIN32) */
