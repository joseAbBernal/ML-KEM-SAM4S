 156:randombytes.c **** # elif defined(SYS_getrandom)
 157:randombytes.c **** static ssize_t getrandom(void *buf, size_t buflen, unsigned int flags) {
 158:randombytes.c ****     return syscall(SYS_getrandom, buf, buflen, flags);
 159:randombytes.c **** }
