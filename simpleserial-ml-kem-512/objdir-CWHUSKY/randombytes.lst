 329:randombytes.c **** #if defined(__EMSCRIPTEN__)
 330:randombytes.c **** static int randombytes_js_randombytes_nodejs(void *buf, size_t n) {
 331:randombytes.c ****     const int ret = EM_ASM_INT({
 332:randombytes.c ****         var crypto;
 333:randombytes.c ****         try {
 334:randombytes.c ****             crypto = require('crypto');
 335:randombytes.c ****         } catch (error) {
 336:randombytes.c ****             return -2;
 337:randombytes.c ****         }
 338:randombytes.c ****         try {
 339:randombytes.c ****             writeArrayToMemory(crypto.randomBytes($1), $0);
 340:randombytes.c ****             return 0;
 341:randombytes.c ****         } catch (error) {
 342:randombytes.c ****             return -1;
 343:randombytes.c ****         }
 344:randombytes.c ****     }, buf, n);
 345:randombytes.c ****     switch (ret) {
 346:randombytes.c ****     case 0:
 347:randombytes.c ****         return 0;
 348:randombytes.c ****     case -1:
 349:randombytes.c ****         errno = EINVAL;
 350:randombytes.c ****         return -1;
 351:randombytes.c ****     case -2:
 352:randombytes.c ****         errno = ENOSYS;
 353:randombytes.c ****         return -1;
 354:randombytes.c ****     }
 355:randombytes.c ****     assert(false); // Unreachable
 356:randombytes.c **** }
 357:randombytes.c **** #endif /* defined(__EMSCRIPTEN__) */
