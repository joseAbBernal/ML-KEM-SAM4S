  46:randombytes.c **** // We would need to include <linux/random.h>, but not every target has access
  47:randombytes.c **** // to the linux headers. We only need RNDGETENTCNT, so we instead inline it.
  48:randombytes.c **** // RNDGETENTCNT is originally defined in `include/uapi/linux/random.h` in the
  49:randombytes.c **** // linux repo.
  50:randombytes.c **** # define RNDGETENTCNT 0x80045200
  51:randombytes.c **** 
