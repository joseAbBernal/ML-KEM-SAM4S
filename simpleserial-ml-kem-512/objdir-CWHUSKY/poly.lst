 357:poly.c        **** /*************************************************
 358:poly.c        **** * Name:        poly_tobytes
 359:poly.c        **** *
 360:poly.c        **** * Description: Serialization of a polynomial
 361:poly.c        **** *
 362:poly.c        **** * Arguments:   - unsigned char *r: pointer to output byte array (needs space for KYBER_POLYBYTES by
 363:poly.c        **** *              - const poly *a:    pointer to input polynomial
 364:poly.c        **** **************************************************/
 365:poly.c        **** void poly_tobytes(unsigned char *r, poly *a) {
 915              	 .loc 1 365 46 is_stmt 1 view-0
 916              	 .cfi_startproc
 917              	 
 918              	 
 366:poly.c        ****     int i;
 919              	 .loc 1 366 5 view .LVU344
 367:poly.c        ****     uint16_t t0, t1;
 920              	 .loc 1 367 5 view .LVU345
 368:poly.c        **** 
 369:poly.c        ****     poly_reduce(a);
 921              	 .loc 1 369 5 view .LVU346
 922              	.LBB6:
 923              	.LBI6:
 370:poly.c        ****     poly_reduce(a);
 371:poly.c        **** 
 372:poly.c        ****     for (i = 0; i < KYBER_N / 2; i++) {
 373:poly.c        ****         t0 = a->coeffs[2 * i];
 374:poly.c        ****         t1 = a->coeffs[2 * i + 1];
 375:poly.c        ****         r[3 * i] = t0 & 0xff;
 376:poly.c        ****         r[3 * i + 1] = (t0 >> 8) | ((t1 & 0xf) << 4);
 377:poly.c        ****         r[3 * i + 2] = (t1 >> 4) & 0xff;
 378:poly.c        ****     }
 379:poly.c        **** }
