 428:poly.c        **** /*************************************************
 429:poly.c        **** * Name:        poly_getnoise_eta1
 430:poly.c        **** *
 431:poly.c        **** * Description: Sample a polynomial deterministically from a seed and a nonce,
 432:poly.c        **** *              with output polynomial close to centered binomial distribution
 433:poly.c        **** *              with parameter KYBER_ETA1
 434:poly.c        **** *
 435:poly.c        **** * Arguments:   - poly *r:                   pointer to output polynomial
 436:poly.c        **** *              - const unsigned char *seed: pointer to input seed (pointing to array of length KYBE
 437:poly.c        **** *              - unsigned char nonce:       one-byte input nonce
 438:poly.c        **** *              - int add:                   boolean to indicate to accumulate into r
 439:poly.c        **** **************************************************/
 440:poly.c        **** void poly_noise_eta1(poly *r, const unsigned char *seed, unsigned char nonce, int add) {
 441:poly.c        ****     unsigned char buf[KYBER_ETA1 * KYBER_N / 4];
 442:poly.c        **** 
 443:poly.c        ****     prf(buf, KYBER_ETA1 * KYBER_N / 4, seed, nonce);
 444:poly.c        ****     cbd_eta1(r, buf, add);
 445:poly.c        **** }
 446:poly.c        **** 
 447:poly.c        **** /*************************************************
 448:poly.c        **** * Name:        poly_getnoise_eta2
 449:poly.c        **** *
 450:poly.c        **** * Description: Sample a polynomial deterministically from a seed and a nonce,
 451:poly.c        **** *              with output polynomial close to centered binomial distribution
 452:poly.c        **** *              with parameter KYBER_ETA2
 453:poly.c        **** *
 454:poly.c        **** * Arguments:   - poly *r:                   pointer to output polynomial
 455:poly.c        **** *              - const unsigned char *seed: pointer to input seed (pointing to array of length KYBE
 456:poly.c        **** *              - unsigned char nonce:       one-byte input nonce
 457:poly.c        **** *              - int add:                   boolean to indicate to accumulate into r
 458:poly.c        **** **************************************************/
 459:poly.c        **** void poly_noise_eta2(poly *r, const unsigned char *seed, unsigned char nonce, int add) {
 460:poly.c        ****     unsigned char buf[KYBER_ETA2 * KYBER_N / 4];
 461:poly.c        **** 
 462:poly.c        ****     prf(buf, KYBER_ETA2 * KYBER_N / 4, seed, nonce);
 463:poly.c        ****     cbd_eta2(r, buf, add);
 464:poly.c        **** }
