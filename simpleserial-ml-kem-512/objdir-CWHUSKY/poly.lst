 466:poly.c        **** /*************************************************
 467:poly.c        **** * Name:        poly_ntt
 468:poly.c        **** *
 469:poly.c        **** * Description: Computes negacyclic number-theoretic transform (NTT) of
 470:poly.c        **** *              a polynomial in place;
 471:poly.c        **** *              inputs assumed to be in normal order, output in bitreversed order
 472:poly.c        **** *
 473:poly.c        **** * Arguments:   - uint16_t *r: pointer to in/output polynomial
 474:poly.c        **** **************************************************/
 475:poly.c        **** void poly_ntt(poly *r) {
 476:poly.c        ****     ntt(r->coeffs);
 477:poly.c        **** }
 478:poly.c        **** 
 479:poly.c        **** /*************************************************
 480:poly.c        **** * Name:        poly_invntt
 481:poly.c        **** *
 482:poly.c        **** * Description: Computes inverse of negacyclic number-theoretic transform (NTT) of
 483:poly.c        **** *              a polynomial in place;
 484:poly.c        **** *              inputs assumed to be in bitreversed order, output in normal order
 485:poly.c        **** *
 486:poly.c        **** * Arguments:   - uint16_t *a: pointer to in/output polynomial
 487:poly.c        **** **************************************************/
 488:poly.c        **** void poly_invntt(poly *r) {
 489:poly.c        ****     invntt(r->coeffs);
 490:poly.c        **** }
