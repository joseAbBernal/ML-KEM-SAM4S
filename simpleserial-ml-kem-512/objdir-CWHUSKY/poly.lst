 381:poly.c        **** /*************************************************
 382:poly.c        **** * Name:        poly_frombytes
 383:poly.c        **** *
 384:poly.c        **** * Description: De-serialization of a polynomial;
 385:poly.c        **** *              inverse of poly_tobytes
 386:poly.c        **** *
 387:poly.c        **** * Arguments:   - poly *r:                pointer to output polynomial
 388:poly.c        **** *              - const unsigned char *a: pointer to input byte array (of KYBER_POLYBYTES bytes)
 389:poly.c        **** **************************************************/
 390:poly.c        **** void poly_frombytes(poly *r, const unsigned char *a) {
 391:poly.c        ****     int i;
 392:poly.c        **** 
 393:poly.c        ****     for (i = 0; i < KYBER_N / 2; i++) {
 394:poly.c        ****         r->coeffs[2 * i]     = a[3 * i]          | ((uint16_t)a[3 * i + 1] & 0x0f) << 8;
 395:poly.c        ****         r->coeffs[2 * i + 1] = a[3 * i + 1] >> 4 | ((uint16_t)a[3 * i + 2] & 0xff) << 4;
 396:poly.c        ****     }
 397:poly.c        **** }
