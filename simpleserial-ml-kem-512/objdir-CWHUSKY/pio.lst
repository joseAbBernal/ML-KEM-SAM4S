 747:.././hal//sam4s/pio.c **** 		p_pio->PIO_CODR = 1 << (ul_pin & 0x1F);
 748:.././hal//sam4s/pio.c **** 	} else {
 749:.././hal//sam4s/pio.c **** 		/* Value to be driven on the I/O line: 1. */
 750:.././hal//sam4s/pio.c **** 		p_pio->PIO_SODR = 1 << (ul_pin & 0x1F);
 751:.././hal//sam4s/pio.c **** 	}
