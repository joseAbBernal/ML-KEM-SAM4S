 829:.././hal//sam4s/pio.c ****  */
 830:.././hal//sam4s/pio.c **** void pio_set_pin_group_low(Pio *p_pio, uint32_t ul_mask)
 831:.././hal//sam4s/pio.c **** {
 832:.././hal//sam4s/pio.c **** 	/* Value to be driven on the I/O line: 0. */
