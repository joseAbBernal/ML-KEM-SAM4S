 292:simpleserial-ml-kem-512.c **** /*Led functions*/
 293:simpleserial-ml-kem-512.c **** /* LED Control Functions for CW313/SAM4S (CWHUSKY)
 294:simpleserial-ml-kem-512.c ****    Pins: 14, 15, 16 correspond to LED3, LED2, LED1 on the board */
 295:simpleserial-ml-kem-512.c **** /* Using direct pin numbers instead of PIO_PA*_IDX to avoid header issues */
 296:simpleserial-ml-kem-512.c **** #define LED1    16  /* Pin 16 on port A */
 297:simpleserial-ml-kem-512.c **** #define LED2    15  /* Pin 15 on port A */
 298:simpleserial-ml-kem-512.c **** #define LED3    14  /* Pin 14 on port A */
 299:simpleserial-ml-kem-512.c **** 
 300:simpleserial-ml-kem-512.c **** /* LED State variables to track on/off status */
 301:simpleserial-ml-kem-512.c **** static volatile uint8_t LED1State = 0;  /* 0 = off, 1 = on */
 302:simpleserial-ml-kem-512.c **** static volatile uint8_t LED2State = 0;
 303:simpleserial-ml-kem-512.c **** static volatile uint8_t LED3State = 0;
 304:simpleserial-ml-kem-512.c **** 
 305:simpleserial-ml-kem-512.c **** /* function to delay almost a second */
 306:simpleserial-ml-kem-512.c **** static void delay_seconds(uint32_t seconds)
 307:simpleserial-ml-kem-512.c **** {
 308:simpleserial-ml-kem-512.c ****     const uint32_t loops_per_sec = 7000000u;
 309:simpleserial-ml-kem-512.c ****     for (uint32_t s = 0; s < seconds; s++) {
 310:simpleserial-ml-kem-512.c ****         for (volatile uint32_t i = 0; i < loops_per_sec; i++) {
 311:simpleserial-ml-kem-512.c ****             __asm__ volatile ("nop");
 312:simpleserial-ml-kem-512.c ****         }
 313:simpleserial-ml-kem-512.c ****     }
 314:simpleserial-ml-kem-512.c **** }
