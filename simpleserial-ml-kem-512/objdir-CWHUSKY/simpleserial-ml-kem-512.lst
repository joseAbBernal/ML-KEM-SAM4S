  99:simpleserial-ml-kem-512.c **** /* LED GPIO utilities kept as generic board controls (not tied to ML-KEM flow). */
 100:simpleserial-ml-kem-512.c **** #define LED1    16
 101:simpleserial-ml-kem-512.c **** #define LED2    15
 102:simpleserial-ml-kem-512.c **** #define LED3    14
 103:simpleserial-ml-kem-512.c **** 
 104:simpleserial-ml-kem-512.c **** static volatile uint8_t LED1State = 0;
 105:simpleserial-ml-kem-512.c **** static volatile uint8_t LED2State = 0;
 106:simpleserial-ml-kem-512.c **** static volatile uint8_t LED3State = 0;
 107:simpleserial-ml-kem-512.c **** 
 108:simpleserial-ml-kem-512.c **** static uint8_t led_on_cmd(uint8_t* m, uint8_t len)
 109:simpleserial-ml-kem-512.c **** {
 110:simpleserial-ml-kem-512.c ****     int led;
 111:simpleserial-ml-kem-512.c **** 
 112:simpleserial-ml-kem-512.c ****     if (len != 1u) {
 113:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 114:simpleserial-ml-kem-512.c ****     }
 115:simpleserial-ml-kem-512.c **** 
 116:simpleserial-ml-kem-512.c ****     led = m[0];
 117:simpleserial-ml-kem-512.c ****     gpio_set_pin_high(led);
 118:simpleserial-ml-kem-512.c ****     if (led == LED1) LED1State = 1;
 119:simpleserial-ml-kem-512.c ****     else if (led == LED2) LED2State = 1;
 120:simpleserial-ml-kem-512.c ****     else if (led == LED3) LED3State = 1;
 121:simpleserial-ml-kem-512.c ****     return 0;
 122:simpleserial-ml-kem-512.c **** }
 123:simpleserial-ml-kem-512.c **** 
 124:simpleserial-ml-kem-512.c **** static uint8_t led_off_cmd(uint8_t* m, uint8_t len)
 125:simpleserial-ml-kem-512.c **** {
 126:simpleserial-ml-kem-512.c ****     int led;
 127:simpleserial-ml-kem-512.c **** 
 128:simpleserial-ml-kem-512.c ****     if (len != 1u) {
 129:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 130:simpleserial-ml-kem-512.c ****     }
 131:simpleserial-ml-kem-512.c **** 
 132:simpleserial-ml-kem-512.c ****     led = m[0];
 133:simpleserial-ml-kem-512.c ****     gpio_set_pin_low(led);
 134:simpleserial-ml-kem-512.c ****     if (led == LED1) LED1State = 0;
 135:simpleserial-ml-kem-512.c ****     else if (led == LED2) LED2State = 0;
 136:simpleserial-ml-kem-512.c ****     else if (led == LED3) LED3State = 0;
 137:simpleserial-ml-kem-512.c ****     return 0;
 138:simpleserial-ml-kem-512.c **** }
 139:simpleserial-ml-kem-512.c **** 
 140:simpleserial-ml-kem-512.c **** static uint8_t led_toggle(uint8_t* m, uint8_t len)
 141:simpleserial-ml-kem-512.c **** {
 142:simpleserial-ml-kem-512.c ****     int led;
 143:simpleserial-ml-kem-512.c ****     uint8_t state = 0;
 144:simpleserial-ml-kem-512.c **** 
 145:simpleserial-ml-kem-512.c ****     if (len != 1u) {
 146:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 147:simpleserial-ml-kem-512.c ****     }
 148:simpleserial-ml-kem-512.c **** 
 149:simpleserial-ml-kem-512.c ****     led = m[0];
 150:simpleserial-ml-kem-512.c ****     if (led == LED1) state = LED1State;
 151:simpleserial-ml-kem-512.c ****     else if (led == LED2) state = LED2State;
 152:simpleserial-ml-kem-512.c ****     else if (led == LED3) state = LED3State;
 153:simpleserial-ml-kem-512.c **** 
 154:simpleserial-ml-kem-512.c ****     if (state) {
 155:simpleserial-ml-kem-512.c ****         gpio_set_pin_low(led);
 156:simpleserial-ml-kem-512.c ****         if (led == LED1) LED1State = 0;
 157:simpleserial-ml-kem-512.c ****         else if (led == LED2) LED2State = 0;
 158:simpleserial-ml-kem-512.c ****         else if (led == LED3) LED3State = 0;
 159:simpleserial-ml-kem-512.c ****     } else {
 160:simpleserial-ml-kem-512.c ****         gpio_set_pin_high(led);
 161:simpleserial-ml-kem-512.c ****         if (led == LED1) LED1State = 1;
 162:simpleserial-ml-kem-512.c ****         else if (led == LED2) LED2State = 1;
 163:simpleserial-ml-kem-512.c ****         else if (led == LED3) LED3State = 1;
 164:simpleserial-ml-kem-512.c ****     }
 165:simpleserial-ml-kem-512.c **** 
 166:simpleserial-ml-kem-512.c ****     return 0;
 167:simpleserial-ml-kem-512.c **** }
 168:simpleserial-ml-kem-512.c **** 
 169:simpleserial-ml-kem-512.c **** /* ML-KEM-512 Decapsulation: Complete with indcpa_dec, hash_g, verify, cmov */
 170:simpleserial-ml-kem-512.c **** uint8_t ml_kem_512_decap(uint8_t* k, uint8_t len)
 171:simpleserial-ml-kem-512.c **** {
 172:simpleserial-ml-kem-512.c ****     int fail;  /* Global fail variable for cmov comparison */
 173:simpleserial-ml-kem-512.c ****     (void)k;
 174:simpleserial-ml-kem-512.c ****     (void)len;
 175:simpleserial-ml-kem-512.c **** 
 176:simpleserial-ml-kem-512.c ****     /* Decrypt ciphertext using secret key */
 177:simpleserial-ml-kem-512.c ****     PQCLEAN_MLKEM512_CLEAN_indcpa_dec(decap_decrypted_buf, ct, sk);
 178:simpleserial-ml-kem-512.c ****     
 179:simpleserial-ml-kem-512.c ****     /* Prepare buffer for hash_g (decrypted_msg || secret_seed) */
 180:simpleserial-ml-kem-512.c ****     memcpy(decap_buf, decap_decrypted_buf, KYBER_SYMBYTES);
 181:simpleserial-ml-kem-512.c ****     memcpy(decap_buf + KYBER_SYMBYTES, sk + KYBER_SECRETKEYBYTES - 2 * KYBER_SYMBYTES, KYBER_SYMBYT
 182:simpleserial-ml-kem-512.c ****     
 183:simpleserial-ml-kem-512.c ****     /* Compute hash_g(kr, buf, 2 * KYBER_SYMBYTES) */
 184:simpleserial-ml-kem-512.c ****     hash_g(decap_kr, decap_buf, 2 * KYBER_SYMBYTES);
 185:simpleserial-ml-kem-512.c **** 
 186:simpleserial-ml-kem-512.c ****     /* coins are in kr+KYBER_SYMBYTES */
 187:simpleserial-ml-kem-512.c ****     //PQCLEAN_MLKEM512_CLEAN_indcpa_enc(cmp, decrypted_buf, pk, kr + KYBER_SYMBYTES);
 188:simpleserial-ml-kem-512.c **** 
 189:simpleserial-ml-kem-512.c ****     /* Verify: compare input ct with re-encrypted cmp */
 190:simpleserial-ml-kem-512.c ****     fail = PQCLEAN_MLKEM512_CLEAN_verify(ct, ct, KYBER_CIPHERTEXTBYTES);
 191:simpleserial-ml-kem-512.c **** 
 192:simpleserial-ml-kem-512.c ****     /* Compute rejection key for invalid ciphertexts */
 193:simpleserial-ml-kem-512.c ****     rkprf(ss_result, sk + KYBER_SECRETKEYBYTES - KYBER_SYMBYTES, ct);
 194:simpleserial-ml-kem-512.c **** 
 195:simpleserial-ml-kem-512.c ****     /* CONDITIONAL MOVE: Copy true key if fail==0 (valid), else keep rejection key */
 196:simpleserial-ml-kem-512.c ****     trigger_high();
 197:simpleserial-ml-kem-512.c ****     PQCLEAN_MLKEM512_CLEAN_cmov(ss_result, decap_kr, KYBER_SYMBYTES, (uint8_t)(1 - fail));
 198:simpleserial-ml-kem-512.c ****     trigger_low();
 199:simpleserial-ml-kem-512.c **** 
 200:simpleserial-ml-kem-512.c ****     /* Send shared secret back */
 201:simpleserial-ml-kem-512.c ****     /* (gpio_set_pin_high(LED1) removido: trigger_high/low ya marcan la ventana) */
 202:simpleserial-ml-kem-512.c ****     //simpleserial_put('r', PQCLEAN_MLKEM512_CLEAN_CRYPTO_BYTES, ss);
 203:simpleserial-ml-kem-512.c **** 
 204:simpleserial-ml-kem-512.c **** 	return 0x00;
 205:simpleserial-ml-kem-512.c **** }
 206:simpleserial-ml-kem-512.c **** 
 207:simpleserial-ml-kem-512.c **** #if SS_VER == SS_VER_2_1
 208:simpleserial-ml-kem-512.c **** static uint8_t v21_copy_chunk(uint8_t *dst, size_t dst_len, uint8_t chunk_len,
 209:simpleserial-ml-kem-512.c ****                               uint8_t chunk_index, uint8_t total_chunks,
 210:simpleserial-ml-kem-512.c ****                               uint8_t len, const uint8_t *buf)
 211:simpleserial-ml-kem-512.c **** {
 212:simpleserial-ml-kem-512.c ****     size_t offset;
 213:simpleserial-ml-kem-512.c **** 
 214:simpleserial-ml-kem-512.c ****     if ((chunk_index >= total_chunks) || (len != chunk_len)) {
 215:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 216:simpleserial-ml-kem-512.c ****     }
 217:simpleserial-ml-kem-512.c **** 
 218:simpleserial-ml-kem-512.c ****     offset = (size_t)chunk_index * chunk_len;
 219:simpleserial-ml-kem-512.c ****     if ((offset + chunk_len) > dst_len) {
 220:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 221:simpleserial-ml-kem-512.c ****     }
 222:simpleserial-ml-kem-512.c **** 
 223:simpleserial-ml-kem-512.c ****     memcpy(dst + offset, buf, chunk_len);
 224:simpleserial-ml-kem-512.c ****     return SS_ERR_OK;
 225:simpleserial-ml-kem-512.c **** }
 226:simpleserial-ml-kem-512.c **** 
 227:simpleserial-ml-kem-512.c **** static void v21_sync_pk_into_sk(void)
 228:simpleserial-ml-kem-512.c **** {
 229:simpleserial-ml-kem-512.c ****     memcpy(sk + KYBER_INDCPA_SECRETKEYBYTES, pk, KYBER_PUBLICKEYBYTES);
 230:simpleserial-ml-kem-512.c ****     hash_h(sk + KYBER_SECRETKEYBYTES - 2 * KYBER_SYMBYTES, pk, KYBER_PUBLICKEYBYTES);
 231:simpleserial-ml-kem-512.c **** }
 232:simpleserial-ml-kem-512.c **** 
 233:simpleserial-ml-kem-512.c **** static uint8_t v21_handle_vector_write(uint8_t scmd, uint8_t len, const uint8_t *buf)
 234:simpleserial-ml-kem-512.c **** {
 235:simpleserial-ml-kem-512.c ****     uint8_t chunk_index;
 236:simpleserial-ml-kem-512.c ****     uint8_t err;
 237:simpleserial-ml-kem-512.c **** 
 238:simpleserial-ml-kem-512.c ****     if ((scmd >= MLKEM_SS_V21_SCMD_SK_BASE) &&
 239:simpleserial-ml-kem-512.c ****         (scmd < (MLKEM_SS_V21_SCMD_SK_BASE + MLKEM_SS_V21_SK_CHUNKS))) {
 240:simpleserial-ml-kem-512.c ****         chunk_index = scmd - MLKEM_SS_V21_SCMD_SK_BASE;
 241:simpleserial-ml-kem-512.c ****         err = v21_copy_chunk(sk, sizeof(sk), MLKEM_SS_V21_CHUNK_SK, chunk_index,
 242:simpleserial-ml-kem-512.c ****                              MLKEM_SS_V21_SK_CHUNKS, len, buf);
 243:simpleserial-ml-kem-512.c ****         if (err == SS_ERR_OK) {
 244:simpleserial-ml-kem-512.c ****             sk_chunks_loaded |= (uint8_t)(1u << chunk_index);
 245:simpleserial-ml-kem-512.c ****         }
 246:simpleserial-ml-kem-512.c ****         return err;
 247:simpleserial-ml-kem-512.c ****     }
 248:simpleserial-ml-kem-512.c **** 
 249:simpleserial-ml-kem-512.c ****     if ((scmd >= MLKEM_SS_V21_SCMD_PK_BASE) &&
 250:simpleserial-ml-kem-512.c ****         (scmd < (MLKEM_SS_V21_SCMD_PK_BASE + MLKEM_SS_V21_PK_CHUNKS))) {
 251:simpleserial-ml-kem-512.c ****         chunk_index = scmd - MLKEM_SS_V21_SCMD_PK_BASE;
 252:simpleserial-ml-kem-512.c ****         err = v21_copy_chunk(pk, sizeof(pk), MLKEM_SS_V21_CHUNK_PK, chunk_index,
 253:simpleserial-ml-kem-512.c ****                              MLKEM_SS_V21_PK_CHUNKS, len, buf);
 254:simpleserial-ml-kem-512.c ****         if (err == SS_ERR_OK) {
 255:simpleserial-ml-kem-512.c ****             pk_chunks_loaded |= (uint8_t)(1u << chunk_index);
 256:simpleserial-ml-kem-512.c ****             memcpy(sk + KYBER_INDCPA_SECRETKEYBYTES + ((size_t)chunk_index * MLKEM_SS_V21_CHUNK_PK)
 257:simpleserial-ml-kem-512.c ****                    buf,
 258:simpleserial-ml-kem-512.c ****                    MLKEM_SS_V21_CHUNK_PK);
 259:simpleserial-ml-kem-512.c ****             if (pk_chunks_loaded == MLKEM_SS_V21_PK_MASK) {
 260:simpleserial-ml-kem-512.c ****                 v21_sync_pk_into_sk();
 261:simpleserial-ml-kem-512.c ****             }
 262:simpleserial-ml-kem-512.c ****         }
 263:simpleserial-ml-kem-512.c ****         return err;
 264:simpleserial-ml-kem-512.c ****     }
 265:simpleserial-ml-kem-512.c **** 
 266:simpleserial-ml-kem-512.c ****     if ((scmd >= MLKEM_SS_V21_SCMD_CT_BASE) &&
