 189:simpleserial-ml-kem-512.c **** /* ML-KEM-512 Decapsulation: Complete with indcpa_dec, hash_g, verify, cmov */
 190:simpleserial-ml-kem-512.c **** uint8_t ml_kem_512_decap(uint8_t* k, uint8_t len)
 191:simpleserial-ml-kem-512.c **** {
 192:simpleserial-ml-kem-512.c ****     int fail;  /* Global fail variable for cmov comparison */
 193:simpleserial-ml-kem-512.c ****     (void)k;
 194:simpleserial-ml-kem-512.c ****     (void)len;
 195:simpleserial-ml-kem-512.c ****     
 196:simpleserial-ml-kem-512.c ****     set_led_pattern(1, 0, 0);  /* Stage 1: entering indcpa_dec */
 197:simpleserial-ml-kem-512.c ****     
 198:simpleserial-ml-kem-512.c ****     
 199:simpleserial-ml-kem-512.c ****     /* Decrypt ciphertext using secret key */
 200:simpleserial-ml-kem-512.c ****     PQCLEAN_MLKEM512_CLEAN_indcpa_dec(decap_decrypted_buf, ct, sk);
 201:simpleserial-ml-kem-512.c ****     
 202:simpleserial-ml-kem-512.c ****     /* Prepare buffer for hash_g (decrypted_msg || secret_seed) */
 203:simpleserial-ml-kem-512.c ****     memcpy(decap_buf, decap_decrypted_buf, KYBER_SYMBYTES);
 204:simpleserial-ml-kem-512.c ****     memcpy(decap_buf + KYBER_SYMBYTES, sk + KYBER_SECRETKEYBYTES - 2 * KYBER_SYMBYTES, KYBER_SYMBYT
 205:simpleserial-ml-kem-512.c ****     
 206:simpleserial-ml-kem-512.c ****     /* Compute hash_g(kr, buf, 2 * KYBER_SYMBYTES) */
 207:simpleserial-ml-kem-512.c ****     hash_g(decap_kr, decap_buf, 2 * KYBER_SYMBYTES);
 208:simpleserial-ml-kem-512.c ****     
 209:simpleserial-ml-kem-512.c ****     set_led_pattern(0, 1, 0);  /* Stage 2: hash_g done */
 210:simpleserial-ml-kem-512.c ****     
 211:simpleserial-ml-kem-512.c ****     /* coins are in kr+KYBER_SYMBYTES */
 212:simpleserial-ml-kem-512.c ****     //PQCLEAN_MLKEM512_CLEAN_indcpa_enc(cmp, decrypted_buf, pk, kr + KYBER_SYMBYTES);
 213:simpleserial-ml-kem-512.c ****     
 214:simpleserial-ml-kem-512.c ****     /* Verify: compare input ct with re-encrypted cmp */
 215:simpleserial-ml-kem-512.c ****     set_led_pattern(1, 1, 0);  /* Stage 3: entering verify */
 216:simpleserial-ml-kem-512.c ****     fail = PQCLEAN_MLKEM512_CLEAN_verify(ct, ct, KYBER_CIPHERTEXTBYTES);
 217:simpleserial-ml-kem-512.c ****     
 218:simpleserial-ml-kem-512.c ****     /* Compute rejection key for invalid ciphertexts */
 219:simpleserial-ml-kem-512.c ****     set_led_pattern(0, 1, 1);  /* Stage 4: entering rkprf */
 220:simpleserial-ml-kem-512.c ****     rkprf(ss_result, sk + KYBER_SECRETKEYBYTES - KYBER_SYMBYTES, ct);
 221:simpleserial-ml-kem-512.c **** 
 222:simpleserial-ml-kem-512.c ****     set_led_pattern(1, 0, 1);  /* Stage 5: entering cmov */
 223:simpleserial-ml-kem-512.c ****     
 224:simpleserial-ml-kem-512.c ****     /* CONDITIONAL MOVE: Copy true key if fail==0 (valid), else keep rejection key */
 225:simpleserial-ml-kem-512.c ****     trigger_high();
 226:simpleserial-ml-kem-512.c ****     PQCLEAN_MLKEM512_CLEAN_cmov(ss_result, decap_kr, KYBER_SYMBYTES, (uint8_t)(1 - fail));
 227:simpleserial-ml-kem-512.c ****     trigger_low();
 228:simpleserial-ml-kem-512.c **** 
 229:simpleserial-ml-kem-512.c ****     set_led_pattern(0, 0, 1);  /* Stage 6: decap finished */
 230:simpleserial-ml-kem-512.c ****     
 231:simpleserial-ml-kem-512.c ****     /* Send shared secret back */
 232:simpleserial-ml-kem-512.c ****     //simpleserial_put('r', PQCLEAN_MLKEM512_CLEAN_CRYPTO_BYTES, ss);
 233:simpleserial-ml-kem-512.c ****     
 234:simpleserial-ml-kem-512.c **** 	return 0x00;
 235:simpleserial-ml-kem-512.c **** }
