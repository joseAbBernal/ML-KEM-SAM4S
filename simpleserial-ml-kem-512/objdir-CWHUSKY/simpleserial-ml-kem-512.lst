 321:simpleserial-ml-kem-512.c **** static uint8_t v21_readback_bounds(uint8_t scmd, const uint8_t **src, uint8_t *out_len)
 322:simpleserial-ml-kem-512.c **** {
 323:simpleserial-ml-kem-512.c ****     uint8_t chunk_index;
 324:simpleserial-ml-kem-512.c ****     size_t offset;
 325:simpleserial-ml-kem-512.c **** 
 326:simpleserial-ml-kem-512.c ****     if ((scmd >= MLKEM_SS_V21_SCMD_SK_BASE) &&
 327:simpleserial-ml-kem-512.c ****         (scmd < (MLKEM_SS_V21_SCMD_SK_BASE + MLKEM_SS_V21_SK_CHUNKS))) {
 328:simpleserial-ml-kem-512.c ****         chunk_index = scmd - MLKEM_SS_V21_SCMD_SK_BASE;
