 413:simpleserial-ml-kem-512.c ****         err = ml_kem_512_decap(NULL, 0);
 414:simpleserial-ml-kem-512.c ****         if (err != SS_ERR_OK) {
 415:simpleserial-ml-kem-512.c ****             return err;
 416:simpleserial-ml-kem-512.c ****         }
 417:simpleserial-ml-kem-512.c ****         return PQCLEAN_MLKEM512_CLEAN_verify(ss, ss_result, KYBER_SSBYTES);
 418:simpleserial-ml-kem-512.c ****     }
