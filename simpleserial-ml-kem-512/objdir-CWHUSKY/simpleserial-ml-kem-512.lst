 343:simpleserial-ml-kem-512.c **** 
 344:simpleserial-ml-kem-512.c ****     if ((scmd >= MLKEM_SS_V21_SCMD_CT_BASE) &&
 345:simpleserial-ml-kem-512.c ****         (scmd < (MLKEM_SS_V21_SCMD_CT_BASE + MLKEM_SS_V21_CT_CHUNKS))) {
 346:simpleserial-ml-kem-512.c ****         chunk_index = scmd - MLKEM_SS_V21_SCMD_CT_BASE;
 347:simpleserial-ml-kem-512.c ****         offset = (size_t)chunk_index * MLKEM_SS_V21_CHUNK_CT;
 348:simpleserial-ml-kem-512.c ****         *src = ct + offset;
 349:simpleserial-ml-kem-512.c ****         *out_len = MLKEM_SS_V21_CHUNK_CT;
 350:simpleserial-ml-kem-512.c ****         return SS_ERR_OK;
 351:simpleserial-ml-kem-512.c ****     }
 352:simpleserial-ml-kem-512.c **** 
 353:simpleserial-ml-kem-512.c ****     if (scmd == MLKEM_SS_V21_SCMD_SS) {
 354:simpleserial-ml-kem-512.c ****         *src = ss;
 355:simpleserial-ml-kem-512.c ****         *out_len = KYBER_SSBYTES;
 356:simpleserial-ml-kem-512.c ****         return SS_ERR_OK;
 357:simpleserial-ml-kem-512.c ****     }
 358:simpleserial-ml-kem-512.c **** 
 359:simpleserial-ml-kem-512.c ****     return SS_ERR_CMD;
 360:simpleserial-ml-kem-512.c **** }
