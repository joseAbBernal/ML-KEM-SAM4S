 133:simpleserial-ml-kem-512.c **** 
 134:simpleserial-ml-kem-512.c **** // Serial command callbacks for LED control
 135:simpleserial-ml-kem-512.c **** uint8_t led_on_cmd(uint8_t* m, uint8_t len){
 136:simpleserial-ml-kem-512.c ****     int led = m[0];  // Get LED number from input byte
 137:simpleserial-ml-kem-512.c ****     gpio_set_pin_high(led);
 138:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 1;
 139:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 1;
 140:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 1;
 141:simpleserial-ml-kem-512.c ****     return 0;
 142:simpleserial-ml-kem-512.c **** }
 143:simpleserial-ml-kem-512.c **** 
 144:simpleserial-ml-kem-512.c **** uint8_t led_off_cmd(uint8_t* m, uint8_t len){
 145:simpleserial-ml-kem-512.c ****     int led = m[0];  // Get LED number from input byte
 146:simpleserial-ml-kem-512.c ****     gpio_set_pin_low(led);
 147:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 0;
 148:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 0;
 149:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 0;
 150:simpleserial-ml-kem-512.c ****     return 0;
 151:simpleserial-ml-kem-512.c **** }
 152:simpleserial-ml-kem-512.c **** 
 153:simpleserial-ml-kem-512.c **** // Helper functions for direct LED control in code (not via serial)
 154:simpleserial-ml-kem-512.c **** void led_on(int led) {
 155:simpleserial-ml-kem-512.c ****     gpio_set_pin_high(led);
 156:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 1;
 157:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 1;
 158:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 1;
 159:simpleserial-ml-kem-512.c **** }
 160:simpleserial-ml-kem-512.c **** 
 161:simpleserial-ml-kem-512.c **** void led_off(int led) {
 162:simpleserial-ml-kem-512.c ****     gpio_set_pin_low(led);
 163:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 0;
 164:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 0;
 165:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 0;
 166:simpleserial-ml-kem-512.c **** }
 167:simpleserial-ml-kem-512.c **** 
 168:simpleserial-ml-kem-512.c **** static void set_led_pattern(uint8_t led1_on, uint8_t led2_on, uint8_t led3_on)
 169:simpleserial-ml-kem-512.c **** {
 170:simpleserial-ml-kem-512.c ****     if (led1_on) led_on(LED1);
 171:simpleserial-ml-kem-512.c ****     else led_off(LED1);
 172:simpleserial-ml-kem-512.c **** 
 173:simpleserial-ml-kem-512.c ****     if (led2_on) led_on(LED2);
 174:simpleserial-ml-kem-512.c ****     else led_off(LED2);
 175:simpleserial-ml-kem-512.c **** 
 176:simpleserial-ml-kem-512.c ****     if (led3_on) led_on(LED3);
 177:simpleserial-ml-kem-512.c ****     else led_off(LED3);
 178:simpleserial-ml-kem-512.c **** }
 179:simpleserial-ml-kem-512.c **** 
 180:simpleserial-ml-kem-512.c **** // Get LED state - returns 1 if LED is on, 0 if off
 181:simpleserial-ml-kem-512.c **** uint8_t get_led_state(int led) {
 182:simpleserial-ml-kem-512.c ****     if(led == LED1) return LED1State;
 183:simpleserial-ml-kem-512.c ****     else if(led == LED2) return LED2State;
 184:simpleserial-ml-kem-512.c ****     else if(led == LED3) return LED3State;
 185:simpleserial-ml-kem-512.c ****     return 0;
 186:simpleserial-ml-kem-512.c **** }
 187:simpleserial-ml-kem-512.c **** /*Led functions done*/
