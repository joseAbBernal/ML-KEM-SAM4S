 334:simpleserial-ml-kem-512.c **** 
 335:simpleserial-ml-kem-512.c ****     if ((scmd >= MLKEM_SS_V21_SCMD_PK_BASE) &&
 336:simpleserial-ml-kem-512.c ****         (scmd < (MLKEM_SS_V21_SCMD_PK_BASE + MLKEM_SS_V21_PK_CHUNKS))) {
 337:simpleserial-ml-kem-512.c ****         chunk_index = scmd - MLKEM_SS_V21_SCMD_PK_BASE;
 338:simpleserial-ml-kem-512.c ****         offset = (size_t)chunk_index * MLKEM_SS_V21_CHUNK_PK;
 339:simpleserial-ml-kem-512.c ****         *src = pk + offset;
