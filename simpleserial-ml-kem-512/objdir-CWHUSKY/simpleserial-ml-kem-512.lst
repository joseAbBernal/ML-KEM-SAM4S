 257:simpleserial-ml-kem-512.c **** static void v21_sync_pk_into_sk(void)
 258:simpleserial-ml-kem-512.c **** {
 259:simpleserial-ml-kem-512.c ****     memcpy(sk + KYBER_INDCPA_SECRETKEYBYTES, pk, KYBER_PUBLICKEYBYTES);
 260:simpleserial-ml-kem-512.c ****     hash_h(sk + KYBER_SECRETKEYBYTES - 2 * KYBER_SYMBYTES, pk, KYBER_PUBLICKEYBYTES);
 261:simpleserial-ml-kem-512.c **** }
