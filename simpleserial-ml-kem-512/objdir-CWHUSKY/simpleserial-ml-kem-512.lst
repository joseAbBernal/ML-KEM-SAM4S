  85:simpleserial-ml-kem-512.c **** /*Led functions*/
  86:simpleserial-ml-kem-512.c **** /* LED Control Functions for CW313/SAM4S (CWHUSKY)
  87:simpleserial-ml-kem-512.c ****    Pins: 14, 15, 16 correspond to LED3, LED2, LED1 on the board */
  88:simpleserial-ml-kem-512.c **** /* Using direct pin numbers instead of PIO_PA*_IDX to avoid header issues */
  89:simpleserial-ml-kem-512.c **** #define LED1    16  /* Pin 16 on port A */
  90:simpleserial-ml-kem-512.c **** #define LED2    15  /* Pin 15 on port A */
  91:simpleserial-ml-kem-512.c **** #define LED3    14  /* Pin 14 on port A */
  92:simpleserial-ml-kem-512.c **** 
  93:simpleserial-ml-kem-512.c **** /* LED State variables to track on/off status */
  94:simpleserial-ml-kem-512.c **** static volatile uint8_t LED1State = 0;  /* 0 = off, 1 = on */
  95:simpleserial-ml-kem-512.c **** static volatile uint8_t LED2State = 0;
  96:simpleserial-ml-kem-512.c **** static volatile uint8_t LED3State = 0;
  97:simpleserial-ml-kem-512.c **** 
  98:simpleserial-ml-kem-512.c **** /* function to delay almost a second */
  99:simpleserial-ml-kem-512.c **** static void delay_seconds(uint32_t seconds)
 100:simpleserial-ml-kem-512.c **** {
 101:simpleserial-ml-kem-512.c ****     const uint32_t loops_per_sec = 7000000u;
 102:simpleserial-ml-kem-512.c ****     for (uint32_t s = 0; s < seconds; s++) {
 103:simpleserial-ml-kem-512.c ****         for (volatile uint32_t i = 0; i < loops_per_sec; i++) {
 104:simpleserial-ml-kem-512.c ****             __asm__ volatile ("nop");
 105:simpleserial-ml-kem-512.c ****         }
 106:simpleserial-ml-kem-512.c ****     }
 107:simpleserial-ml-kem-512.c **** }
