  87:simpleserial-ml-kem-512.c **** /*Led functions*/
  88:simpleserial-ml-kem-512.c **** /* LED Control Functions for CW313/SAM4S (CWHUSKY)
  89:simpleserial-ml-kem-512.c ****    Pins: 14, 15, 16 correspond to LED3, LED2, LED1 on the board */
  90:simpleserial-ml-kem-512.c **** /* Using direct pin numbers instead of PIO_PA*_IDX to avoid header issues */
  91:simpleserial-ml-kem-512.c **** #define LED1    16  /* Pin 16 on port A */
  92:simpleserial-ml-kem-512.c **** #define LED2    15  /* Pin 15 on port A */
  93:simpleserial-ml-kem-512.c **** #define LED3    14  /* Pin 14 on port A */
  94:simpleserial-ml-kem-512.c **** 
  95:simpleserial-ml-kem-512.c **** /* LED State variables to track on/off status */
  96:simpleserial-ml-kem-512.c **** static volatile uint8_t LED1State = 0;  /* 0 = off, 1 = on */
  97:simpleserial-ml-kem-512.c **** static volatile uint8_t LED2State = 0;
  98:simpleserial-ml-kem-512.c **** static volatile uint8_t LED3State = 0;
  99:simpleserial-ml-kem-512.c **** 
 100:simpleserial-ml-kem-512.c **** /* function to delay almost a second */
 101:simpleserial-ml-kem-512.c **** static void delay_seconds(uint32_t seconds)
 102:simpleserial-ml-kem-512.c **** {
 103:simpleserial-ml-kem-512.c ****     const uint32_t loops_per_sec = 7000000u;
 104:simpleserial-ml-kem-512.c ****     for (uint32_t s = 0; s < seconds; s++) {
 105:simpleserial-ml-kem-512.c ****         for (volatile uint32_t i = 0; i < loops_per_sec; i++) {
 106:simpleserial-ml-kem-512.c ****             __asm__ volatile ("nop");
 107:simpleserial-ml-kem-512.c ****         }
 108:simpleserial-ml-kem-512.c ****     }
 109:simpleserial-ml-kem-512.c **** }
 110:simpleserial-ml-kem-512.c **** 
 111:simpleserial-ml-kem-512.c **** uint8_t led_toggle(uint8_t* m, uint8_t len){
 112:simpleserial-ml-kem-512.c ****     int led = m[0];  // Get LED number from input byte (14=LED3, 15=LED2, 16=LED1)
 113:simpleserial-ml-kem-512.c ****     uint8_t current_state = 0;
 114:simpleserial-ml-kem-512.c ****     
 115:simpleserial-ml-kem-512.c ****     // Get current state
 116:simpleserial-ml-kem-512.c ****     if(led == LED1) current_state = LED1State;
 117:simpleserial-ml-kem-512.c ****     else if(led == LED2) current_state = LED2State;
 118:simpleserial-ml-kem-512.c ****     else if(led == LED3) current_state = LED3State;
 119:simpleserial-ml-kem-512.c ****     
 120:simpleserial-ml-kem-512.c ****     // Toggle: if on, turn off; if off, turn on
 121:simpleserial-ml-kem-512.c ****     if(current_state == 1){
 122:simpleserial-ml-kem-512.c ****         gpio_set_pin_low(led);
 123:simpleserial-ml-kem-512.c ****         if(led == LED1) LED1State = 0;
 124:simpleserial-ml-kem-512.c ****         else if(led == LED2) LED2State = 0;
 125:simpleserial-ml-kem-512.c ****         else if(led == LED3) LED3State = 0;
 126:simpleserial-ml-kem-512.c ****     } else {
 127:simpleserial-ml-kem-512.c ****         gpio_set_pin_high(led);
 128:simpleserial-ml-kem-512.c ****         if(led == LED1) LED1State = 1;
 129:simpleserial-ml-kem-512.c ****         else if(led == LED2) LED2State = 1;
 130:simpleserial-ml-kem-512.c ****         else if(led == LED3) LED3State = 1;
 131:simpleserial-ml-kem-512.c ****     }
 132:simpleserial-ml-kem-512.c ****     
 133:simpleserial-ml-kem-512.c ****     return 0;
 134:simpleserial-ml-kem-512.c **** }
 135:simpleserial-ml-kem-512.c **** 
 136:simpleserial-ml-kem-512.c **** // Serial command callbacks for LED control
 137:simpleserial-ml-kem-512.c **** uint8_t led_on_cmd(uint8_t* m, uint8_t len){
 138:simpleserial-ml-kem-512.c ****     int led = m[0];  // Get LED number from input byte
 139:simpleserial-ml-kem-512.c ****     gpio_set_pin_high(led);
 140:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 1;
 141:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 1;
 142:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 1;
 143:simpleserial-ml-kem-512.c ****     return 0;
 144:simpleserial-ml-kem-512.c **** }
 145:simpleserial-ml-kem-512.c **** 
 146:simpleserial-ml-kem-512.c **** uint8_t led_off_cmd(uint8_t* m, uint8_t len){
 147:simpleserial-ml-kem-512.c ****     int led = m[0];  // Get LED number from input byte
 148:simpleserial-ml-kem-512.c ****     gpio_set_pin_low(led);
 149:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 0;
 150:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 0;
 151:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 0;
 152:simpleserial-ml-kem-512.c ****     return 0;
 153:simpleserial-ml-kem-512.c **** }
 154:simpleserial-ml-kem-512.c **** 
 155:simpleserial-ml-kem-512.c **** // Helper functions for direct LED control in code (not via serial)
 156:simpleserial-ml-kem-512.c **** void led_on(int led) {
 157:simpleserial-ml-kem-512.c ****     gpio_set_pin_high(led);
 158:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 1;
 159:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 1;
 160:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 1;
 161:simpleserial-ml-kem-512.c **** }
 162:simpleserial-ml-kem-512.c **** 
 163:simpleserial-ml-kem-512.c **** void led_off(int led) {
 164:simpleserial-ml-kem-512.c ****     gpio_set_pin_low(led);
 165:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 0;
 166:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 0;
 167:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 0;
 168:simpleserial-ml-kem-512.c **** }
 169:simpleserial-ml-kem-512.c **** 
 170:simpleserial-ml-kem-512.c **** static void set_led_pattern(uint8_t led1_on, uint8_t led2_on, uint8_t led3_on)
 171:simpleserial-ml-kem-512.c **** {
 172:simpleserial-ml-kem-512.c ****     if (led1_on) led_on(LED1);
 173:simpleserial-ml-kem-512.c ****     else led_off(LED1);
 174:simpleserial-ml-kem-512.c **** 
 175:simpleserial-ml-kem-512.c ****     if (led2_on) led_on(LED2);
 176:simpleserial-ml-kem-512.c ****     else led_off(LED2);
 177:simpleserial-ml-kem-512.c **** 
 178:simpleserial-ml-kem-512.c ****     if (led3_on) led_on(LED3);
 179:simpleserial-ml-kem-512.c ****     else led_off(LED3);
 180:simpleserial-ml-kem-512.c **** }
 181:simpleserial-ml-kem-512.c **** 
 182:simpleserial-ml-kem-512.c **** // Get LED state - returns 1 if LED is on, 0 if off
 183:simpleserial-ml-kem-512.c **** uint8_t get_led_state(int led) {
 184:simpleserial-ml-kem-512.c ****     if(led == LED1) return LED1State;
 185:simpleserial-ml-kem-512.c ****     else if(led == LED2) return LED2State;
 186:simpleserial-ml-kem-512.c ****     else if(led == LED3) return LED3State;
 187:simpleserial-ml-kem-512.c ****     return 0;
 188:simpleserial-ml-kem-512.c **** }
 189:simpleserial-ml-kem-512.c **** /*Led functions done*/
 190:simpleserial-ml-kem-512.c **** 
 191:simpleserial-ml-kem-512.c **** /* ML-KEM-512 Decapsulation: Complete with indcpa_dec, hash_g, verify, cmov */
 192:simpleserial-ml-kem-512.c **** uint8_t ml_kem_512_decap(uint8_t* k, uint8_t len)
 193:simpleserial-ml-kem-512.c **** {
 194:simpleserial-ml-kem-512.c ****     int fail;  /* Global fail variable for cmov comparison */
 195:simpleserial-ml-kem-512.c ****     (void)k;
 196:simpleserial-ml-kem-512.c ****     (void)len;
 197:simpleserial-ml-kem-512.c ****     
 198:simpleserial-ml-kem-512.c ****     set_led_pattern(1, 0, 0);  /* Stage 1: entering indcpa_dec */
 199:simpleserial-ml-kem-512.c ****     
 200:simpleserial-ml-kem-512.c ****     
 201:simpleserial-ml-kem-512.c ****     /* Decrypt ciphertext using secret key */
 202:simpleserial-ml-kem-512.c ****     PQCLEAN_MLKEM512_CLEAN_indcpa_dec(decap_decrypted_buf, ct, sk);
 203:simpleserial-ml-kem-512.c ****     
 204:simpleserial-ml-kem-512.c ****     /* Prepare buffer for hash_g (decrypted_msg || secret_seed) */
 205:simpleserial-ml-kem-512.c ****     memcpy(decap_buf, decap_decrypted_buf, KYBER_SYMBYTES);
 206:simpleserial-ml-kem-512.c ****     memcpy(decap_buf + KYBER_SYMBYTES, sk + KYBER_SECRETKEYBYTES - 2 * KYBER_SYMBYTES, KYBER_SYMBYT
 207:simpleserial-ml-kem-512.c ****     
 208:simpleserial-ml-kem-512.c ****     /* Compute hash_g(kr, buf, 2 * KYBER_SYMBYTES) */
 209:simpleserial-ml-kem-512.c ****     hash_g(decap_kr, decap_buf, 2 * KYBER_SYMBYTES);
 210:simpleserial-ml-kem-512.c ****     
 211:simpleserial-ml-kem-512.c ****     set_led_pattern(0, 1, 0);  /* Stage 2: hash_g done */
 212:simpleserial-ml-kem-512.c ****     
 213:simpleserial-ml-kem-512.c ****     /* coins are in kr+KYBER_SYMBYTES */
 214:simpleserial-ml-kem-512.c ****     //PQCLEAN_MLKEM512_CLEAN_indcpa_enc(cmp, decrypted_buf, pk, kr + KYBER_SYMBYTES);
 215:simpleserial-ml-kem-512.c ****     
 216:simpleserial-ml-kem-512.c ****     /* Verify: compare input ct with re-encrypted cmp */
 217:simpleserial-ml-kem-512.c ****     set_led_pattern(1, 1, 0);  /* Stage 3: entering verify */
 218:simpleserial-ml-kem-512.c ****     fail = PQCLEAN_MLKEM512_CLEAN_verify(ct, ct, KYBER_CIPHERTEXTBYTES);
 219:simpleserial-ml-kem-512.c ****     
 220:simpleserial-ml-kem-512.c ****     /* Compute rejection key for invalid ciphertexts */
 221:simpleserial-ml-kem-512.c ****     set_led_pattern(0, 1, 1);  /* Stage 4: entering rkprf */
 222:simpleserial-ml-kem-512.c ****     rkprf(ss_result, sk + KYBER_SECRETKEYBYTES - KYBER_SYMBYTES, ct);
 223:simpleserial-ml-kem-512.c **** 
 224:simpleserial-ml-kem-512.c ****     set_led_pattern(1, 0, 1);  /* Stage 5: entering cmov */
 225:simpleserial-ml-kem-512.c ****     
 226:simpleserial-ml-kem-512.c ****     /* CONDITIONAL MOVE: Copy true key if fail==0 (valid), else keep rejection key */
 227:simpleserial-ml-kem-512.c ****     trigger_high();
 228:simpleserial-ml-kem-512.c ****     PQCLEAN_MLKEM512_CLEAN_cmov(ss_result, decap_kr, KYBER_SYMBYTES, (uint8_t)(1 - fail));
 229:simpleserial-ml-kem-512.c ****     trigger_low();
 230:simpleserial-ml-kem-512.c **** 
 231:simpleserial-ml-kem-512.c ****     set_led_pattern(0, 0, 1);  /* Stage 6: decap finished */
 232:simpleserial-ml-kem-512.c ****     
 233:simpleserial-ml-kem-512.c ****     /* Send shared secret back */
 234:simpleserial-ml-kem-512.c ****     //simpleserial_put('r', PQCLEAN_MLKEM512_CLEAN_CRYPTO_BYTES, ss);
 235:simpleserial-ml-kem-512.c ****     
 236:simpleserial-ml-kem-512.c **** 	return 0x00;
 237:simpleserial-ml-kem-512.c **** }
 238:simpleserial-ml-kem-512.c **** 
 239:simpleserial-ml-kem-512.c **** #if SS_VER == SS_VER_2_1
 240:simpleserial-ml-kem-512.c **** static uint8_t v21_copy_chunk(uint8_t *dst, size_t dst_len, uint8_t chunk_len,
 241:simpleserial-ml-kem-512.c ****                               uint8_t chunk_index, uint8_t total_chunks,
 242:simpleserial-ml-kem-512.c ****                               uint8_t len, const uint8_t *buf)
 243:simpleserial-ml-kem-512.c **** {
 244:simpleserial-ml-kem-512.c ****     size_t offset;
 245:simpleserial-ml-kem-512.c **** 
 246:simpleserial-ml-kem-512.c ****     if ((chunk_index >= total_chunks) || (len != chunk_len)) {
 247:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 248:simpleserial-ml-kem-512.c ****     }
 249:simpleserial-ml-kem-512.c **** 
 250:simpleserial-ml-kem-512.c ****     offset = (size_t)chunk_index * chunk_len;
 251:simpleserial-ml-kem-512.c ****     if ((offset + chunk_len) > dst_len) {
 252:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 253:simpleserial-ml-kem-512.c ****     }
 254:simpleserial-ml-kem-512.c **** 
 255:simpleserial-ml-kem-512.c ****     memcpy(dst + offset, buf, chunk_len);
 256:simpleserial-ml-kem-512.c ****     return SS_ERR_OK;
 257:simpleserial-ml-kem-512.c **** }
 258:simpleserial-ml-kem-512.c **** 
 259:simpleserial-ml-kem-512.c **** static void v21_sync_pk_into_sk(void)
 260:simpleserial-ml-kem-512.c **** {
 261:simpleserial-ml-kem-512.c ****     memcpy(sk + KYBER_INDCPA_SECRETKEYBYTES, pk, KYBER_PUBLICKEYBYTES);
 262:simpleserial-ml-kem-512.c ****     hash_h(sk + KYBER_SECRETKEYBYTES - 2 * KYBER_SYMBYTES, pk, KYBER_PUBLICKEYBYTES);
 263:simpleserial-ml-kem-512.c **** }
 264:simpleserial-ml-kem-512.c **** 
 265:simpleserial-ml-kem-512.c **** static uint8_t v21_handle_vector_write(uint8_t scmd, uint8_t len, const uint8_t *buf)
 266:simpleserial-ml-kem-512.c **** {
 267:simpleserial-ml-kem-512.c ****     uint8_t chunk_index;
 268:simpleserial-ml-kem-512.c ****     uint8_t err;
 269:simpleserial-ml-kem-512.c **** 
 270:simpleserial-ml-kem-512.c ****     if ((scmd >= MLKEM_SS_V21_SCMD_SK_BASE) &&
