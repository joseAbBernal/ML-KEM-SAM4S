 237:simpleserial-ml-kem-512.c **** #if SS_VER == SS_VER_2_1
 238:simpleserial-ml-kem-512.c **** static uint8_t v21_copy_chunk(uint8_t *dst, size_t dst_len, uint8_t chunk_len,
 239:simpleserial-ml-kem-512.c ****                               uint8_t chunk_index, uint8_t total_chunks,
 240:simpleserial-ml-kem-512.c ****                               uint8_t len, const uint8_t *buf)
 241:simpleserial-ml-kem-512.c **** {
 242:simpleserial-ml-kem-512.c ****     size_t offset;
 243:simpleserial-ml-kem-512.c **** 
 244:simpleserial-ml-kem-512.c ****     if ((chunk_index >= total_chunks) || (len != chunk_len)) {
 245:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 246:simpleserial-ml-kem-512.c ****     }
 247:simpleserial-ml-kem-512.c **** 
 248:simpleserial-ml-kem-512.c ****     offset = (size_t)chunk_index * chunk_len;
 249:simpleserial-ml-kem-512.c ****     if ((offset + chunk_len) > dst_len) {
 250:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 251:simpleserial-ml-kem-512.c ****     }
 252:simpleserial-ml-kem-512.c **** 
 253:simpleserial-ml-kem-512.c ****     memcpy(dst + offset, buf, chunk_len);
 254:simpleserial-ml-kem-512.c ****     return SS_ERR_OK;
 255:simpleserial-ml-kem-512.c **** }
