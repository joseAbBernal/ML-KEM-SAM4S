 341:simpleserial-ml-kem-512.c **** // Serial command callbacks for LED control
 342:simpleserial-ml-kem-512.c **** uint8_t led_on_cmd(uint8_t* m, uint8_t len){
 343:simpleserial-ml-kem-512.c ****     int led = m[0];  // Get LED number from input byte
 344:simpleserial-ml-kem-512.c ****     gpio_set_pin_high(led);
 345:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 1;
 346:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 1;
 347:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 1;
 348:simpleserial-ml-kem-512.c ****     return 0;
 349:simpleserial-ml-kem-512.c **** }
 350:simpleserial-ml-kem-512.c **** 
 351:simpleserial-ml-kem-512.c **** uint8_t led_off_cmd(uint8_t* m, uint8_t len){
 352:simpleserial-ml-kem-512.c ****     int led = m[0];  // Get LED number from input byte
 353:simpleserial-ml-kem-512.c ****     gpio_set_pin_low(led);
 354:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 0;
 355:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 0;
 356:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 0;
 357:simpleserial-ml-kem-512.c ****     return 0;
 358:simpleserial-ml-kem-512.c **** }
 359:simpleserial-ml-kem-512.c **** 
 360:simpleserial-ml-kem-512.c **** // Helper functions for direct LED control in code (not via serial)
 361:simpleserial-ml-kem-512.c **** void led_on(int led) {
 362:simpleserial-ml-kem-512.c ****     gpio_set_pin_high(led);
 363:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 1;
 364:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 1;
 365:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 1;
 366:simpleserial-ml-kem-512.c **** }
 367:simpleserial-ml-kem-512.c **** 
 368:simpleserial-ml-kem-512.c **** void led_off(int led) {
 369:simpleserial-ml-kem-512.c ****     gpio_set_pin_low(led);
 370:simpleserial-ml-kem-512.c ****     if(led == LED1) LED1State = 0;
 371:simpleserial-ml-kem-512.c ****     else if(led == LED2) LED2State = 0;
 372:simpleserial-ml-kem-512.c ****     else if(led == LED3) LED3State = 0;
 373:simpleserial-ml-kem-512.c **** }
 374:simpleserial-ml-kem-512.c **** 
 375:simpleserial-ml-kem-512.c **** // Get LED state - returns 1 if LED is on, 0 if off
 376:simpleserial-ml-kem-512.c **** uint8_t get_led_state(int led) {
 377:simpleserial-ml-kem-512.c ****     if(led == LED1) return LED1State;
 378:simpleserial-ml-kem-512.c ****     else if(led == LED2) return LED2State;
 379:simpleserial-ml-kem-512.c ****     else if(led == LED3) return LED3State;
 380:simpleserial-ml-kem-512.c ****     return 0;
 381:simpleserial-ml-kem-512.c **** }
 382:simpleserial-ml-kem-512.c **** /*Led functions done*/
 383:simpleserial-ml-kem-512.c **** 
 384:simpleserial-ml-kem-512.c **** /* ML-KEM-512 Decapsulation: Complete with indcpa_dec, hash_g, verify, cmov */
 385:simpleserial-ml-kem-512.c **** uint8_t ml_kem_512_decap(uint8_t* k, uint8_t len)
 386:simpleserial-ml-kem-512.c **** {
 387:simpleserial-ml-kem-512.c ****     uint8_t buf[2 * KYBER_SYMBYTES];
 388:simpleserial-ml-kem-512.c ****     uint8_t kr[2 * KYBER_SYMBYTES];
 389:simpleserial-ml-kem-512.c ****     uint8_t cmp[KYBER_CIPHERTEXTBYTES + KYBER_SYMBYTES];
 390:simpleserial-ml-kem-512.c ****     uint8_t decrypted_buf[KYBER_SYMBYTES];
 391:simpleserial-ml-kem-512.c ****     int fail;  /* Global fail variable for cmov comparison */
 392:simpleserial-ml-kem-512.c ****     const uint8_t *pk = sk + KYBER_INDCPA_SECRETKEYBYTES;
 393:simpleserial-ml-kem-512.c ****     
 394:simpleserial-ml-kem-512.c ****     led_off(LED3);  /* Ensure LED3 is off at the start of decapsulation */
 395:simpleserial-ml-kem-512.c ****     led_on(LED1);  /* Step 1: indcpa_dec starting */
 396:simpleserial-ml-kem-512.c ****     
 397:simpleserial-ml-kem-512.c ****     
 398:simpleserial-ml-kem-512.c ****     /* Decrypt ciphertext using secret key */
 399:simpleserial-ml-kem-512.c ****     PQCLEAN_MLKEM512_CLEAN_indcpa_dec(decrypted_buf, ct, sk);
 400:simpleserial-ml-kem-512.c ****     
 401:simpleserial-ml-kem-512.c ****     /* Prepare buffer for hash_g (decrypted_msg || secret_seed) */
 402:simpleserial-ml-kem-512.c ****     memcpy(buf, decrypted_buf, KYBER_SYMBYTES);
 403:simpleserial-ml-kem-512.c ****     memcpy(buf + KYBER_SYMBYTES, sk + KYBER_SECRETKEYBYTES - 2 * KYBER_SYMBYTES, KYBER_SYMBYTES);
 404:simpleserial-ml-kem-512.c ****     
 405:simpleserial-ml-kem-512.c ****     /* Compute hash_g(kr, buf, 2 * KYBER_SYMBYTES) */
 406:simpleserial-ml-kem-512.c ****     hash_g(kr, buf, 2 * KYBER_SYMBYTES);
 407:simpleserial-ml-kem-512.c ****     
 408:simpleserial-ml-kem-512.c ****     led_off(LED1);
 409:simpleserial-ml-kem-512.c ****     led_on(LED2);  /* Step 2: hash_g done, coins extraction */
 410:simpleserial-ml-kem-512.c ****     
 411:simpleserial-ml-kem-512.c ****     /* coins are in kr+KYBER_SYMBYTES */
 412:simpleserial-ml-kem-512.c ****     //PQCLEAN_MLKEM512_CLEAN_indcpa_enc(cmp, decrypted_buf, pk, kr + KYBER_SYMBYTES);
 413:simpleserial-ml-kem-512.c ****     
 414:simpleserial-ml-kem-512.c ****     /* Verify: compare input ct with re-encrypted cmp */
 415:simpleserial-ml-kem-512.c ****     fail = PQCLEAN_MLKEM512_CLEAN_verify(ct, ct, KYBER_CIPHERTEXTBYTES);
 416:simpleserial-ml-kem-512.c ****     
 417:simpleserial-ml-kem-512.c ****     /* Compute rejection key for invalid ciphertexts */
 418:simpleserial-ml-kem-512.c ****     rkprf(ss_result, sk + KYBER_SECRETKEYBYTES - KYBER_SYMBYTES, ct);
 419:simpleserial-ml-kem-512.c **** 
 420:simpleserial-ml-kem-512.c ****     led_off(LED2);
 421:simpleserial-ml-kem-512.c ****     
 422:simpleserial-ml-kem-512.c ****     /* CONDITIONAL MOVE: Copy true key if fail==0 (valid), else keep rejection key */
 423:simpleserial-ml-kem-512.c ****     trigger_high();
 424:simpleserial-ml-kem-512.c ****     PQCLEAN_MLKEM512_CLEAN_cmov(ss_result, kr, KYBER_SYMBYTES, (uint8_t)(1 - fail));
 425:simpleserial-ml-kem-512.c ****     trigger_low();
 426:simpleserial-ml-kem-512.c **** 
 427:simpleserial-ml-kem-512.c **** 
 428:simpleserial-ml-kem-512.c ****     led_on(LED3);  /* Step 3: verify done, computing rejection key */
 429:simpleserial-ml-kem-512.c ****     
 430:simpleserial-ml-kem-512.c ****     /* Send shared secret back */
 431:simpleserial-ml-kem-512.c ****     //simpleserial_put('r', PQCLEAN_MLKEM512_CLEAN_CRYPTO_BYTES, ss);
 432:simpleserial-ml-kem-512.c ****     
 433:simpleserial-ml-kem-512.c **** 	return 0x00;
 434:simpleserial-ml-kem-512.c **** }
 435:simpleserial-ml-kem-512.c **** 
 436:simpleserial-ml-kem-512.c **** #if SS_VER == SS_VER_2_1
 437:simpleserial-ml-kem-512.c **** static uint8_t v21_copy_chunk(uint8_t *dst, size_t dst_len, uint8_t chunk_len,
 438:simpleserial-ml-kem-512.c ****                               uint8_t chunk_index, uint8_t total_chunks,
 439:simpleserial-ml-kem-512.c ****                               uint8_t len, const uint8_t *buf)
 440:simpleserial-ml-kem-512.c **** {
 441:simpleserial-ml-kem-512.c ****     size_t offset;
 442:simpleserial-ml-kem-512.c **** 
 443:simpleserial-ml-kem-512.c ****     if ((chunk_index >= total_chunks) || (len != chunk_len)) {
 444:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 445:simpleserial-ml-kem-512.c ****     }
 446:simpleserial-ml-kem-512.c **** 
 447:simpleserial-ml-kem-512.c ****     offset = (size_t)chunk_index * chunk_len;
 448:simpleserial-ml-kem-512.c ****     if ((offset + chunk_len) > dst_len) {
 449:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 450:simpleserial-ml-kem-512.c ****     }
 451:simpleserial-ml-kem-512.c **** 
 452:simpleserial-ml-kem-512.c ****     memcpy(dst + offset, buf, chunk_len);
 453:simpleserial-ml-kem-512.c ****     return SS_ERR_OK;
 454:simpleserial-ml-kem-512.c **** }
 455:simpleserial-ml-kem-512.c **** 
 456:simpleserial-ml-kem-512.c **** static void v21_sync_pk_into_sk(void)
 457:simpleserial-ml-kem-512.c **** {
 458:simpleserial-ml-kem-512.c ****     memcpy(sk + KYBER_INDCPA_SECRETKEYBYTES, pk, KYBER_PUBLICKEYBYTES);
 459:simpleserial-ml-kem-512.c ****     hash_h(sk + KYBER_SECRETKEYBYTES - 2 * KYBER_SYMBYTES, pk, KYBER_PUBLICKEYBYTES);
 460:simpleserial-ml-kem-512.c **** }
