  18:simpleserial-ml-kem-512.c **** 
  19:simpleserial-ml-kem-512.c **** #include "api.h"
  20:simpleserial-ml-kem-512.c **** #include "hal.h"
  21:simpleserial-ml-kem-512.c **** #include "simpleserial.h"
  22:simpleserial-ml-kem-512.c **** #include <stdint.h>
  23:simpleserial-ml-kem-512.c **** #include <stdlib.h>
  24:simpleserial-ml-kem-512.c **** #include <string.h>
  25:simpleserial-ml-kem-512.c **** 
  26:simpleserial-ml-kem-512.c **** // ML-KEM-512 key sizes
  27:simpleserial-ml-kem-512.c **** #define KEM_PUBLIC_KEY_BYTES  KYBER_PUBLICKEYBYTES   // 800 bytes
  28:simpleserial-ml-kem-512.c **** #define KEM_SECRET_KEY_BYTES  KYBER_SECRETKEYBYTES   // 1632 bytes  
  29:simpleserial-ml-kem-512.c **** #define KEM_CIPHERTEXT_BYTES  KYBER_CIPHERTEXTBYTES  // 768 bytes
  30:simpleserial-ml-kem-512.c **** #define KEM_SHARED_SECRET_BYTES KYBER_SSBYTES         // 32 bytes
  31:simpleserial-ml-kem-512.c **** 
  32:simpleserial-ml-kem-512.c **** // Storage for KEM keys (static to avoid stack issues)
  33:simpleserial-ml-kem-512.c **** static uint8_t kem_public_key[KEM_PUBLIC_KEY_BYTES];
  34:simpleserial-ml-kem-512.c **** static uint8_t kem_secret_key[KEM_SECRET_KEY_BYTES];
  35:simpleserial-ml-kem-512.c **** static uint8_t kem_ciphertext[KEM_CIPHERTEXT_BYTES];
  36:simpleserial-ml-kem-512.c **** static uint8_t kem_shared_secret[KEM_SHARED_SECRET_BYTES];
  37:simpleserial-ml-kem-512.c **** 
  38:simpleserial-ml-kem-512.c **** // Key generation command
  39:simpleserial-ml-kem-512.c **** uint8_t kem_keygen(uint8_t* x, uint8_t len)
  40:simpleserial-ml-kem-512.c **** {
  41:simpleserial-ml-kem-512.c ****     (void)len;
  42:simpleserial-ml-kem-512.c ****     (void)x;
  43:simpleserial-ml-kem-512.c ****     
  44:simpleserial-ml-kem-512.c ****     // Generate key pair
  45:simpleserial-ml-kem-512.c ****     crypto_kem_keypair(kem_public_key, kem_secret_key);
  46:simpleserial-ml-kem-512.c ****     
  47:simpleserial-ml-kem-512.c ****     // Return public key
  48:simpleserial-ml-kem-512.c ****     simpleserial_put('p', KEM_PUBLIC_KEY_BYTES, kem_public_key);
  49:simpleserial-ml-kem-512.c ****     return 0x00;
  50:simpleserial-ml-kem-512.c **** }
  51:simpleserial-ml-kem-512.c **** 
  52:simpleserial-ml-kem-512.c **** // Encapsulation command (using public key)
  53:simpleserial-ml-kem-512.c **** uint8_t kem_encaps(uint8_t* pt, uint8_t len)
  54:simpleserial-ml-kem-512.c **** {
  55:simpleserial-ml-kem-512.c ****     // Input should be public key (or use stored public key if empty)
  56:simpleserial-ml-kem-512.c ****     if (len == KEM_PUBLIC_KEY_BYTES) {
  57:simpleserial-ml-kem-512.c ****         memcpy(kem_public_key, pt, KEM_PUBLIC_KEY_BYTES);
  58:simpleserial-ml-kem-512.c ****     } else if (len != 0) {
  59:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
  60:simpleserial-ml-kem-512.c ****     }
  61:simpleserial-ml-kem-512.c ****     
  62:simpleserial-ml-kem-512.c ****     trigger_high();
  63:simpleserial-ml-kem-512.c ****     
  64:simpleserial-ml-kem-512.c ****     // Encapsulate: generates ciphertext and shared secret
  65:simpleserial-ml-kem-512.c ****     crypto_kem_enc(kem_ciphertext, kem_shared_secret, kem_public_key);
  66:simpleserial-ml-kem-512.c ****     
  67:simpleserial-ml-kem-512.c ****     trigger_low();
  68:simpleserial-ml-kem-512.c ****     
  69:simpleserial-ml-kem-512.c ****     // Return ciphertext + shared secret (for capture)
  70:simpleserial-ml-kem-512.c ****     simpleserial_put('c', KEM_CIPHERTEXT_BYTES + KEM_SHARED_SECRET_BYTES, kem_ciphertext);
  71:simpleserial-ml-kem-512.c ****     return 0x00;
  72:simpleserial-ml-kem-512.c **** }
  73:simpleserial-ml-kem-512.c **** 
  74:simpleserial-ml-kem-512.c **** // Decapsulation command (using secret key and ciphertext)
  75:simpleserial-ml-kem-512.c **** uint8_t kem_decaps(uint8_t* ct, uint8_t len)
  76:simpleserial-ml-kem-512.c **** {
  77:simpleserial-ml-kem-512.c ****     // Input should be ciphertext
  78:simpleserial-ml-kem-512.c ****     if (len != KEM_CIPHERTEXT_BYTES) {
  79:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
  80:simpleserial-ml-kem-512.c ****     }
  81:simpleserial-ml-kem-512.c ****     
  82:simpleserial-ml-kem-512.c ****     memcpy(kem_ciphertext, ct, KEM_CIPHERTEXT_BYTES);
  83:simpleserial-ml-kem-512.c ****     
  84:simpleserial-ml-kem-512.c ****     trigger_high();
  85:simpleserial-ml-kem-512.c ****     
  86:simpleserial-ml-kem-512.c ****     // Decapsulate: uses secret key and ciphertext to recover shared secret
  87:simpleserial-ml-kem-512.c ****     crypto_kem_dec(kem_shared_secret, kem_ciphertext, kem_secret_key);
  88:simpleserial-ml-kem-512.c ****     
  89:simpleserial-ml-kem-512.c ****     trigger_low();
  90:simpleserial-ml-kem-512.c ****     
  91:simpleserial-ml-kem-512.c ****     // Return shared secret
  92:simpleserial-ml-kem-512.c ****     simpleserial_put('s', KEM_SHARED_SECRET_BYTES, kem_shared_secret);
  93:simpleserial-ml-kem-512.c ****     return 0x00;
  94:simpleserial-ml-kem-512.c **** }
  95:simpleserial-ml-kem-512.c **** 
  96:simpleserial-ml-kem-512.c **** // Set public key command
  97:simpleserial-ml-kem-512.c **** uint8_t get_pk(uint8_t* pk, uint8_t len)
  98:simpleserial-ml-kem-512.c **** {
  99:simpleserial-ml-kem-512.c ****     if (len != KEM_PUBLIC_KEY_BYTES) {
 100:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 101:simpleserial-ml-kem-512.c ****     }
 102:simpleserial-ml-kem-512.c ****     memcpy(kem_public_key, pk, KEM_PUBLIC_KEY_BYTES);
 103:simpleserial-ml-kem-512.c ****     return 0x00;
 104:simpleserial-ml-kem-512.c **** }
 105:simpleserial-ml-kem-512.c **** 
 106:simpleserial-ml-kem-512.c **** // Set secret key command
 107:simpleserial-ml-kem-512.c **** uint8_t get_sk(uint8_t* sk, uint8_t len)
 108:simpleserial-ml-kem-512.c **** {
 109:simpleserial-ml-kem-512.c ****     if (len != KEM_SECRET_KEY_BYTES) {
 110:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 111:simpleserial-ml-kem-512.c ****     }
 112:simpleserial-ml-kem-512.c ****     memcpy(kem_secret_key, sk, KEM_SECRET_KEY_BYTES);
 113:simpleserial-ml-kem-512.c ****     return 0x00;
 114:simpleserial-ml-kem-512.c **** }
 115:simpleserial-ml-kem-512.c **** 
 116:simpleserial-ml-kem-512.c **** // Reset command
 117:simpleserial-ml-kem-512.c **** uint8_t reset(uint8_t* x, uint8_t len)
 118:simpleserial-ml-kem-512.c **** {
 119:simpleserial-ml-kem-512.c ****     (void)x;
 120:simpleserial-ml-kem-512.c ****     (void)len;
 121:simpleserial-ml-kem-512.c ****     // Clear keys on reset
 122:simpleserial-ml-kem-512.c ****     memset(kem_public_key, 0, KEM_PUBLIC_KEY_BYTES);
 123:simpleserial-ml-kem-512.c ****     memset(kem_secret_key, 0, KEM_SECRET_KEY_BYTES);
 124:simpleserial-ml-kem-512.c ****     memset(kem_ciphertext, 0, KEM_CIPHERTEXT_BYTES);
 125:simpleserial-ml-kem-512.c ****     memset(kem_shared_secret, 0, KEM_SHARED_SECRET_BYTES);
 126:simpleserial-ml-kem-512.c ****     return 0x00;
 127:simpleserial-ml-kem-512.c **** }
 128:simpleserial-ml-kem-512.c **** 
 129:simpleserial-ml-kem-512.c **** // SS_VER_2_1 unified command handler
 130:simpleserial-ml-kem-512.c **** // Supports combined operations via subcommand flags:
 131:simpleserial-ml-kem-512.c **** // 0x01: Generate new keypair
 132:simpleserial-ml-kem-512.c **** // 0x02: Set public key (pk must be in buffer)
 133:simpleserial-ml-kem-512.c **** // 0x04: Set secret key (sk must be in buffer)
 134:simpleserial-ml-kem-512.c **** // 0x08: Encapsulate (requires pk in buffer or uses stored pk)
 135:simpleserial-ml-kem-512.c **** // 0x10: Decapsulate (requires sk and ct in buffer)
 136:simpleserial-ml-kem-512.c **** #if SS_VER == SS_VER_2_1
