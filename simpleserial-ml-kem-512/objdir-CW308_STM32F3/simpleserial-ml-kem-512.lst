 334:simpleserial-ml-kem-512.c ****     size_t remaining;
 335:simpleserial-ml-kem-512.c **** 
 336:simpleserial-ml-kem-512.c ****     if ((v21_chunk_sz == 0u) || (len == 0u) || (len > v21_chunk_sz)) {
 337:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 338:simpleserial-ml-kem-512.c ****     }
 339:simpleserial-ml-kem-512.c **** 
