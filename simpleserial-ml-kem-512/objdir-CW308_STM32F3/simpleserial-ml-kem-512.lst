 330:simpleserial-ml-kem-512.c **** static uint8_t v21_rx_vector_chunk(uint8_t *dst, size_t dst_len, uint8_t scmd,
 331:simpleserial-ml-kem-512.c ****                                    uint8_t len, const uint8_t *buf)
 332:simpleserial-ml-kem-512.c **** {
