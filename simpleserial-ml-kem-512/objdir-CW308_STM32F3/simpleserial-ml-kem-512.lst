 511:simpleserial-ml-kem-512.c ****     err = v21_handle_vector_write(scmd, len, buf);
 512:simpleserial-ml-kem-512.c ****     if (err != SS_ERR_CMD) {
 513:simpleserial-ml-kem-512.c ****         return err;
 514:simpleserial-ml-kem-512.c ****     }
 515:simpleserial-ml-kem-512.c **** 
