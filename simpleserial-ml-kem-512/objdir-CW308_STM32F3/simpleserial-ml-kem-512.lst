 465:simpleserial-ml-kem-512.c **** static uint8_t ml_kem_512_do_decap(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
 466:simpleserial-ml-kem-512.c **** {
 467:simpleserial-ml-kem-512.c ****     uint8_t err;
 468:simpleserial-ml-kem-512.c ****     (void)cmd; (void)scmd; (void)buf;
 469:simpleserial-ml-kem-512.c ****     if (len != 0) return SS_ERR_LEN;
 470:simpleserial-ml-kem-512.c ****     /* No bitmask check: the rx commands (0x05/0x07/0x09) use v21_rx_vector_chunk
 471:simpleserial-ml-kem-512.c ****      * which does not update chunk_loaded bitmasks. If vectors are unloaded the
 472:simpleserial-ml-kem-512.c ****      * verify at the end will return 0x01 (mismatch), which is the correct result. */
 473:simpleserial-ml-kem-512.c ****     err = ml_kem_512_decap(NULL, 0);
 474:simpleserial-ml-kem-512.c ****     if (err != SS_ERR_OK) return err;
 475:simpleserial-ml-kem-512.c ****     return PQCLEAN_MLKEM512_CLEAN_verify(ss, ss_result, KYBER_SSBYTES);
 476:simpleserial-ml-kem-512.c **** }
 477:simpleserial-ml-kem-512.c **** 
 478:simpleserial-ml-kem-512.c **** static uint8_t ml_kem_512_cmov_sk_probe(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
 479:simpleserial-ml-kem-512.c **** {
 480:simpleserial-ml-kem-512.c ****     uint8_t repeat;
 481:simpleserial-ml-kem-512.c **** 
 482:simpleserial-ml-kem-512.c ****     (void)cmd;
 483:simpleserial-ml-kem-512.c ****     (void)scmd;
 484:simpleserial-ml-kem-512.c ****     (void)buf;
 485:simpleserial-ml-kem-512.c **** 
 486:simpleserial-ml-kem-512.c ****     if (len != 0u) {
 487:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 488:simpleserial-ml-kem-512.c ****     }
 489:simpleserial-ml-kem-512.c **** 
 490:simpleserial-ml-kem-512.c ****     /*
 491:simpleserial-ml-kem-512.c ****      * Dedicated leakage probe: copy the complete secret key with cmov under a
 492:simpleserial-ml-kem-512.c ****      * single trigger so the capture covers the whole operation, not only a
 493:simpleserial-ml-kem-512.c ****      * narrow window around the no-fail decapsulation path.
 494:simpleserial-ml-kem-512.c ****      */
 495:simpleserial-ml-kem-512.c ****     trigger_high();
 496:simpleserial-ml-kem-512.c ****     for (repeat = 0; repeat < 4u; repeat++) {
 497:simpleserial-ml-kem-512.c ****         memset(cmov_probe_buf, 0, sizeof(cmov_probe_buf));
 498:simpleserial-ml-kem-512.c ****         PQCLEAN_MLKEM512_CLEAN_cmov(cmov_probe_buf, sk, sizeof(sk), 1u);
 499:simpleserial-ml-kem-512.c ****     }
 500:simpleserial-ml-kem-512.c ****     trigger_low();
 501:simpleserial-ml-kem-512.c **** 
 502:simpleserial-ml-kem-512.c ****     return SS_ERR_OK;
 503:simpleserial-ml-kem-512.c **** }
