 354:simpleserial-ml-kem-512.c **** static uint8_t v21_tx_vector_chunk(uint8_t tag, const uint8_t *src, size_t src_len,
 355:simpleserial-ml-kem-512.c ****                                    uint8_t scmd, uint8_t len)
 356:simpleserial-ml-kem-512.c **** {
 357:simpleserial-ml-kem-512.c ****     size_t offset;
 358:simpleserial-ml-kem-512.c ****     size_t remaining;
 359:simpleserial-ml-kem-512.c ****     uint8_t out_len;
 360:simpleserial-ml-kem-512.c **** 
 361:simpleserial-ml-kem-512.c ****     if ((v21_chunk_sz == 0u) || (len != 0u)) {
 362:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 363:simpleserial-ml-kem-512.c ****     }
 364:simpleserial-ml-kem-512.c **** 
 365:simpleserial-ml-kem-512.c ****     offset = (size_t)scmd * (size_t)v21_chunk_sz;
 366:simpleserial-ml-kem-512.c ****     if (offset >= src_len) {
 367:simpleserial-ml-kem-512.c ****         return SS_ERR_LEN;
 368:simpleserial-ml-kem-512.c ****     }
 369:simpleserial-ml-kem-512.c **** 
 370:simpleserial-ml-kem-512.c ****     remaining = src_len - offset;
 371:simpleserial-ml-kem-512.c ****     out_len = (remaining > (size_t)v21_chunk_sz) ? v21_chunk_sz : (uint8_t)remaining;
