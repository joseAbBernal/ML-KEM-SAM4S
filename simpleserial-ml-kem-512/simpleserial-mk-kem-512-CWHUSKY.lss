// Barrett reduction - simple C implementation
uint16_t asm_barrett_reduce(uint16_t a) {
    uint32_t t;
    const uint16_t q = KYBER_Q;
    const uint32_t mu = (1 << 26) / q; // (2^26)/q
    t = (uint32_t)a * mu;
