// RFC 7748: Curve25519 / X25519 en Magma CAS
// E: v^2 = u^3 + A*u^2 + u sobre GF(2^255 - 19)
// ============================================================
// PARÁMETROS RFC 7748
// ============================================================
p := 2^255 - 19;                              // Primo del campo
A := 486662;                                  // Coeficiente Montgomery
Fp := GF(p);                                   // Campo finito

// Punto base (u=9, v=147816194...)
u := 9;
//v := 14781619447589544791020593568409986887264606134616475288964881837755586237401;
v := 43114425171068552920764898935933967039370386198203806730763910166200978582548;


E25519 := EllipticCurve([Fp|0, A,0,1,0]);

//testing
//v^2 eq u^3 + A*u^2 + u
"(v^2 mod p) = u^3 + A*u^2 + u", (v^2 mod p) eq u^3 + A*u^2 + u;

G:= E25519![u,v];

//Alicia  : key gen
a:= Random([1..p-1]);
KA := a*G;

//Bob  : key gen
b:= Random([1..p-1]);
KB := b*G;

//Alicia secreto compartido
KAB := a*KB;

//Beto secreto compartido
KBA := KA*b;

//test
KAB eq KBA;

//eva keygen
e := Random([1..p-1]);
KE := e*G;

//alice - eva
KAE := e*KA;    //alice
KEA := a*KE;    //eve

//Eve Bob
KBE := e*KB;
KEB := b*KE;

// Curva de Montgomery: v^2 = x^3 + A*x^2 + x
f := (v^3 mod p) + (A*v^2 + v);
// Campo finito y curva de Montgomery
P25519<x> := PolynomialRing(Fp);

a24 := (486662 - 2) / 4;
//a241 := 121665;

//"((486662 - 2) / 4) = 121665;", a24 eq a241;
// ============================================================
// FUNCIÓN cswap (Intercambio condicional)
// ============================================================
cswap := function(x2, z2, x3, z3)
        // Intercambiar (x2,z2) con (x3,z3)
        tmp := x2;
        x2 := x3;
        x3 := tmp;
        //x2, x3 := x3, x2;  // Alternativa más compacta
        tmp := z2;
        z2 := z3;
        z3 := tmp;        
        //z2, z3 := z3, z2;  // Alternativa más compacta
    return x2, z2, x3, z3;
end function;

// ============================================================
// FUNCIÓN Clamp (Aplica la máscara de seguridad del RFC 7748)
// ============================================================
Clamp := function(bytes)
    // bytes es una lista de 32 enteros (0..255) en orden Little-Endian
    // 1. Limpiar los 3 bits menos significativos del primer byte
    //"bytes:= ",bytes:Hex;
    //"bytes[1]:= ",bytes[1]:Hex;
    bytes[1] := BitwiseAnd(bytes[1], 248);  // 248 = 0xF8
    //"bytes[1]:= ",bytes[1]:Hex;
    // 2. Limpiar el bit más significativo del último byte
    //"bytes[32] := ", bytes[32]:Hex;
    bytes[32] := BitwiseAnd(bytes[32], 127); // 127 = 0x7F
    //"bytes[32] := ", bytes[32]:Hex;
    // 3. Forzar el bit 254 a 1 (el segundo bit del último byte)
    //"bytes[32] := ", bytes[32]:Hex;
    bytes[32] := BitwiseOr(bytes[32], 64);   // 64 = 0x40
    //"bytes[32] := ", bytes[32]:Hex;
    //"bytes final: ",bytes:Hex;
    //"\n";
    return bytes;
end function;

// ============================================================
// FUNCIÓN decodeScalar25519 (Convierte bytes a escalar válido)
// ============================================================
decodeScalar25519 := function(bytes)
    // 1. Aplicar la máscara de seguridad (Clamping) RFC 7748
    bytes_clamped := Clamp(bytes);
    // 2. ¡Optimizado! Reconstruye el entero little-endian desde los bytes
    bytes := Seqint(bytes_clamped, 2^8);
    return bytes;
end function;

// ============================================================
// FUNCIÓN X25519 (Optimizada y SIN función cswap)
// ============================================================
X25519 := function(scalar, u_coord)    
    // Precomputamos los bits (MSB -> LSB)
    scalarbits := Reverse(Intseq(scalar, 2));
    while #scalarbits lt 255 do
        scalarbits := [0] cat scalarbits;
    end while;
    
    // Estado inicial de la escalera
    x2 := Fp!1;    z2 := Fp!0;
    x3 := Fp!u_coord; z3 := Fp!1;
    swap := 0;
    for t in [1..255] do
        k_t := scalarbits[t];
        swap := BitwiseXor(swap, k_t);
        
        // Conditional swap INLINE (La clave del éxito en Magma)
        // Si swap es 1, intercambiamos (x2,z2) con (x3,z3)
        if swap eq 1 then
            x2, z2, x3, z3 := cswap(x2, z2, x3, z3);
        end if;
        // Fórmulas diferenciales de Montgomery (Estándar RFC)
        A1 := x2 + z2;
        AA := A1^2;
        B1 := x2 - z2;
        BB := B1^2;
        E  := Fp!(AA - BB); // <-- Forzamos que E sea elemento de F
        
        C  := x3 + z3;
        D  := x3 - z3;
        DA := Fp!D * Fp!A1;  // <-- Aseguramos que todo sea FldFinElt
        CB := Fp!C * Fp!B1;
        
        x3 := (DA + CB)^2;
        z3 := Fp!u_coord * (DA - CB)^2; // <-- u_coord forzado a F
        x2 := AA * BB;
        z2 := E * (Fp!AA + Fp!a24 * E); // <-- a24 también debe estar en F
        
        swap := k_t; // Actualiza el swap para la siguiente iteración
    end for;
    
    // Último swap final (Inline también)
    if swap eq 1 then
        x2, z2, x3, z3 := cswap(x2, z2, x3, z3);
    end if;
    
    // Retorna u = x2 / z2
    return x2 * (z2^(p-2));
end function;

// ============================================================
// EJEMPLO: Test Vector RFC 7748
// ============================================================
// 1. Definimos los HEXADECIMALES completos (como los da el RFC)
alice_hex := 0xa546e36bf0527c9d3b16154b82465edd62144c0ac1fc5a18506a2244ba449ac4;
bob_hex   := 0x5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb;
// 2. Los convertimos a LISTA DE BYTES (Little-Endian, 32 bytes)
alice_bytes := Intseq(alice_hex, 2^8);
bob_bytes   := Intseq(bob_hex, 2^8);
// 3. ¡AQUÍ ESTÁ EL CAMBIO! Aplicamos "decodeScalar25519" 
//    (que limpia bits y convierte a número).
alice_scalar := decodeScalar25519(alice_bytes);
bob_scalar   := decodeScalar25519(bob_bytes);
// 4. Ejecutamos el algoritmo
u9 := Fp!9;
u_cord := 0xe6db6867583030db3594c1a424b15f7c726624ec26b3353b10a903a6d0ab1c4c;

A_alice := X25519(alice_scalar, u_cord);
printf "Alice public key: %o\n", A_alice;
B_bob := X25519(bob_scalar, u_cord);
printf "Bob public key: %o\n", B_bob;
secret_alice := X25519(alice_scalar, B_bob);
printf "Alice shared secret: %o\n", secret_alice;
secret_bob := X25519(bob_scalar, A_alice);
printf "Bob shared secret: %o\n", secret_bob;
// Verificación
assert secret_alice eq secret_bob;
printf "✅ Secreto compartido interno verificado!\n";
// Test Vector Oficial
expected := 0xc3da55379de9c6908e94ea4df28d084f32eccf03491c71f754b4075577a28552;
printf "Expected RFC 7748: %o\n", expected;
// ¡AHORA ESTO DEBE SER TRUE!
"secret_alice := ",secret_alice:Hex;
"expected := ", expected;
//assert secret_alice eq expected;
//printf "✅ ¡El test vector oficial es CORRECTO!\n";


