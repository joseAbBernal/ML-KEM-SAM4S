  19:simpleserial-base.c **** #include "hal.h"
  20:simpleserial-base.c **** #include <stdint.h>
  21:simpleserial-base.c **** #include <stdlib.h>
  22:simpleserial-base.c **** #include <string.h>
  23:simpleserial-base.c **** 
  24:simpleserial-base.c **** #include "simpleserial.h"
  25:simpleserial-base.c **** 
  26:simpleserial-base.c **** #define SK_LEN 1632
  27:simpleserial-base.c **** #define PK_LEN 800
  28:simpleserial-base.c **** #define CT_LEN 768
  29:simpleserial-base.c **** #define SS_LEN 32
  30:simpleserial-base.c **** 
  31:simpleserial-base.c **** uint16_t CHUNK_SZ = 248;  // Tamaño de chunk por defecto (1-249)
  32:simpleserial-base.c **** 
  33:simpleserial-base.c **** static uint8_t sk[SK_LEN] = {0};
  34:simpleserial-base.c **** static uint8_t pk[PK_LEN] = {0};
  35:simpleserial-base.c **** static uint8_t ct[CT_LEN] = {0};
  36:simpleserial-base.c **** static uint8_t ss[SS_LEN] = {0};
  37:simpleserial-base.c **** 
  38:simpleserial-base.c **** uint8_t get_key(uint8_t* k, uint8_t len)
  39:simpleserial-base.c **** {
  40:simpleserial-base.c **** 	// Load key here
  41:simpleserial-base.c **** 	return 0x00;
  42:simpleserial-base.c **** }
  43:simpleserial-base.c **** 
  44:simpleserial-base.c **** uint8_t get_pt(uint8_t* pt, uint8_t len)
  45:simpleserial-base.c **** {
  46:simpleserial-base.c **** 	/**********************************
  47:simpleserial-base.c **** 	* Start user-specific code here. */
  48:simpleserial-base.c **** 	trigger_high();
  49:simpleserial-base.c **** 
  50:simpleserial-base.c **** 	//16 hex bytes held in 'pt' were sent
  51:simpleserial-base.c **** 	//from the computer. Store your response
  52:simpleserial-base.c **** 	//back into 'pt', which will send 16 bytes
  53:simpleserial-base.c **** 	//back to computer. Can ignore of course if
  54:simpleserial-base.c **** 	//not needed
  55:simpleserial-base.c **** 
  56:simpleserial-base.c **** 	trigger_low();
  57:simpleserial-base.c **** 	/* End user-specific code here. *
  58:simpleserial-base.c **** 	********************************/
  59:simpleserial-base.c **** 	simpleserial_put('r', 16, pt);
  60:simpleserial-base.c **** 	return 0x00;
  61:simpleserial-base.c **** }
  62:simpleserial-base.c **** 
  63:simpleserial-base.c **** uint8_t reset(uint8_t* x, uint8_t len)
  64:simpleserial-base.c **** {
  65:simpleserial-base.c **** 	// Reset key here if needed
  66:simpleserial-base.c **** 	return 0x00;
  67:simpleserial-base.c **** }
  68:simpleserial-base.c **** 
  69:simpleserial-base.c **** uint8_t rx_key(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
  70:simpleserial-base.c **** {
  71:simpleserial-base.c ****     uint16_t offset = scmd * CHUNK_SZ;
  72:simpleserial-base.c ****     // Validar que no sobrepasamos los límites
  73:simpleserial-base.c ****     if (offset >= SK_LEN) return SS_ERR_LEN;
  74:simpleserial-base.c ****     // Limitar la cantidad a copiar al espacio disponible
  75:simpleserial-base.c ****     uint16_t to_copy = (offset + len > SK_LEN) ? SK_LEN - offset : len;
  76:simpleserial-base.c ****     memcpy(sk + offset, buf, to_copy);
  77:simpleserial-base.c ****     // Debug: retornar el primer byte del buffer para verificar
  78:simpleserial-base.c ****     trigger_high();
  79:simpleserial-base.c ****     trigger_low();
  80:simpleserial-base.c ****     return 0x00;
  81:simpleserial-base.c **** }
