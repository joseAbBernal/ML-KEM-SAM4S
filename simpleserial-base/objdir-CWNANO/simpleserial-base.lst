  18:simpleserial-base.c **** 
  19:simpleserial-base.c **** #include "hal.h"
  20:simpleserial-base.c **** #include <stdint.h>
  21:simpleserial-base.c **** #include <stdlib.h>
  22:simpleserial-base.c **** #include <string.h>
  23:simpleserial-base.c **** 
  24:simpleserial-base.c **** #include "simpleserial.h"
  25:simpleserial-base.c **** 
  26:simpleserial-base.c **** #define KEY_LEN 2000
  27:simpleserial-base.c **** #define CHUNK_SZ 200
  28:simpleserial-base.c **** static uint8_t key_buf[KEY_LEN];
  29:simpleserial-base.c **** 
  30:simpleserial-base.c **** uint8_t get_key(uint8_t* k, uint8_t len)
  31:simpleserial-base.c **** {
  32:simpleserial-base.c **** 	// Load key here
  33:simpleserial-base.c **** 	return 0x00;
  34:simpleserial-base.c **** }
  35:simpleserial-base.c **** 
  36:simpleserial-base.c **** uint8_t get_pt(uint8_t* pt, uint8_t len)
  37:simpleserial-base.c **** {
  38:simpleserial-base.c **** 	/**********************************
  39:simpleserial-base.c **** 	* Start user-specific code here. */
  40:simpleserial-base.c **** 	trigger_high();
  41:simpleserial-base.c **** 
  42:simpleserial-base.c **** 	//16 hex bytes held in 'pt' were sent
  43:simpleserial-base.c **** 	//from the computer. Store your response
  44:simpleserial-base.c **** 	//back into 'pt', which will send 16 bytes
  45:simpleserial-base.c **** 	//back to computer. Can ignore of course if
  46:simpleserial-base.c **** 	//not needed
  47:simpleserial-base.c **** 
  48:simpleserial-base.c **** 	trigger_low();
  49:simpleserial-base.c **** 	/* End user-specific code here. *
  50:simpleserial-base.c **** 	********************************/
  51:simpleserial-base.c **** 	simpleserial_put('r', 16, pt);
  52:simpleserial-base.c **** 	return 0x00;
  53:simpleserial-base.c **** }
  54:simpleserial-base.c **** 
  55:simpleserial-base.c **** uint8_t reset(uint8_t* x, uint8_t len)
  56:simpleserial-base.c **** {
  57:simpleserial-base.c **** 	// Reset key here if needed
  58:simpleserial-base.c **** 	return 0x00;
  59:simpleserial-base.c **** }
  60:simpleserial-base.c **** 
  61:simpleserial-base.c **** #if SS_VER == SS_VER_2_1
  62:simpleserial-base.c **** uint8_t aes(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
  63:simpleserial-base.c **** {
  64:simpleserial-base.c ****     uint8_t req_len = 0;
  65:simpleserial-base.c ****     uint8_t err = 0;
  66:simpleserial-base.c **** 
  67:simpleserial-base.c ****     if (scmd & 0x02) {
  68:simpleserial-base.c ****         req_len += 16;
  69:simpleserial-base.c ****         if (req_len > len) {
  70:simpleserial-base.c ****             return SS_ERR_LEN;
  71:simpleserial-base.c ****         }
  72:simpleserial-base.c ****         err = get_key(buf + req_len - 16, 16);
  73:simpleserial-base.c ****         if (err)
  74:simpleserial-base.c ****             return err;
  75:simpleserial-base.c ****     }
  76:simpleserial-base.c ****     if (scmd & 0x01) {
  77:simpleserial-base.c ****         req_len += 16;
  78:simpleserial-base.c ****         if (req_len > len) {
  79:simpleserial-base.c ****             return SS_ERR_LEN;
  80:simpleserial-base.c ****         }
  81:simpleserial-base.c ****         err = get_pt(buf + req_len - 16, 16);
  82:simpleserial-base.c ****         if (err)
  83:simpleserial-base.c ****             return err;
  84:simpleserial-base.c ****     }
  85:simpleserial-base.c **** 
  86:simpleserial-base.c ****     if (len != req_len) {
  87:simpleserial-base.c ****         return SS_ERR_LEN;
  88:simpleserial-base.c ****     }
  89:simpleserial-base.c **** 
  90:simpleserial-base.c ****     return 0x00;
  91:simpleserial-base.c **** }
  92:simpleserial-base.c ****  
  93:simpleserial-base.c **** uint8_t rx_key(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
  94:simpleserial-base.c **** {
  95:simpleserial-base.c ****     uint16_t offset = scmd * CHUNK_SZ;
  96:simpleserial-base.c ****     if (offset + len > KEY_LEN) return SS_ERR_LEN;
  97:simpleserial-base.c ****     memcpy(key_buf + offset, buf, len);
  98:simpleserial-base.c ****     return 0x00;
  99:simpleserial-base.c **** }
 100:simpleserial-base.c **** 
