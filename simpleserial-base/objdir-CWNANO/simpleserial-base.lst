  24:simpleserial-base.c **** #include "simpleserial.h"
  25:simpleserial-base.c **** 
  26:simpleserial-base.c **** #define KEY_LEN 1632
  27:simpleserial-base.c **** uint16_t CHUNK_SZ = 248;  // Tamaño de chunk por defecto (1-249)
  28:simpleserial-base.c **** 
  29:simpleserial-base.c **** static uint8_t key_buf[KEY_LEN] = {0};
  30:simpleserial-base.c **** 
  31:simpleserial-base.c **** uint8_t get_key(uint8_t* k, uint8_t len)
  32:simpleserial-base.c **** {
  33:simpleserial-base.c **** 	// Load key here
  34:simpleserial-base.c **** 	return 0x00;
  35:simpleserial-base.c **** }
  36:simpleserial-base.c **** 
  37:simpleserial-base.c **** uint8_t get_pt(uint8_t* pt, uint8_t len)
  38:simpleserial-base.c **** {
  39:simpleserial-base.c **** 	/**********************************
  40:simpleserial-base.c **** 	* Start user-specific code here. */
  41:simpleserial-base.c **** 	trigger_high();
  42:simpleserial-base.c **** 
  43:simpleserial-base.c **** 	//16 hex bytes held in 'pt' were sent
  44:simpleserial-base.c **** 	//from the computer. Store your response
  45:simpleserial-base.c **** 	//back into 'pt', which will send 16 bytes
  46:simpleserial-base.c **** 	//back to computer. Can ignore of course if
  47:simpleserial-base.c **** 	//not needed
  48:simpleserial-base.c **** 
  49:simpleserial-base.c **** 	trigger_low();
  50:simpleserial-base.c **** 	/* End user-specific code here. *
  51:simpleserial-base.c **** 	********************************/
  52:simpleserial-base.c **** 	simpleserial_put('r', 16, pt);
  53:simpleserial-base.c **** 	return 0x00;
  54:simpleserial-base.c **** }
  55:simpleserial-base.c **** 
  56:simpleserial-base.c **** uint8_t reset(uint8_t* x, uint8_t len)
  57:simpleserial-base.c **** {
  58:simpleserial-base.c **** 	// Reset key here if needed
  59:simpleserial-base.c **** 	return 0x00;
  60:simpleserial-base.c **** }
  61:simpleserial-base.c **** 
  62:simpleserial-base.c **** uint8_t rx_key(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
  63:simpleserial-base.c **** {
  64:simpleserial-base.c ****     uint16_t offset = scmd * CHUNK_SZ;
  65:simpleserial-base.c ****     // Validar que no sobrepasamos los límites
  66:simpleserial-base.c ****     if (offset >= KEY_LEN) return SS_ERR_LEN;
  67:simpleserial-base.c ****     // Limitar la cantidad a copiar al espacio disponible
  68:simpleserial-base.c ****     uint16_t to_copy = (offset + len > KEY_LEN) ? KEY_LEN - offset : len;
  69:simpleserial-base.c ****     memcpy(key_buf + offset, buf, to_copy);
  70:simpleserial-base.c ****     // Debug: retornar el primer byte del buffer para verificar
  71:simpleserial-base.c ****     trigger_high();
  72:simpleserial-base.c ****     trigger_low();
  73:simpleserial-base.c ****     return 0x00;
  74:simpleserial-base.c **** }
