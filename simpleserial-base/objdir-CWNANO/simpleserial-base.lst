  19:simpleserial-base.c **** #include "hal.h"
  20:simpleserial-base.c **** #include <stdint.h>
  21:simpleserial-base.c **** #include <stdlib.h>
  22:simpleserial-base.c **** #include <string.h>
  23:simpleserial-base.c **** 
  24:simpleserial-base.c **** #include "simpleserial.h"
  25:simpleserial-base.c **** 
  26:simpleserial-base.c **** #define SK_LEN 1632
  27:simpleserial-base.c **** #define PK_LEN 800
  28:simpleserial-base.c **** #define SS_LEN 32
  29:simpleserial-base.c **** 
  30:simpleserial-base.c **** uint16_t CHUNK_SZ = 248;  // Tamaño de chunk por defecto (1-249)
  31:simpleserial-base.c **** 
  32:simpleserial-base.c **** static uint8_t sk[SK_LEN] = {0};
  33:simpleserial-base.c **** static uint8_t pk[PK_LEN] = {0};
  34:simpleserial-base.c **** static uint8_t ss[SS_LEN] = {0};
  35:simpleserial-base.c **** 
  36:simpleserial-base.c **** uint8_t get_key(uint8_t* k, uint8_t len)
  37:simpleserial-base.c **** {
  38:simpleserial-base.c **** 	// Load key here
  39:simpleserial-base.c **** 	return 0x00;
  40:simpleserial-base.c **** }
  41:simpleserial-base.c **** 
  42:simpleserial-base.c **** uint8_t get_pt(uint8_t* pt, uint8_t len)
  43:simpleserial-base.c **** {
  44:simpleserial-base.c **** 	/**********************************
  45:simpleserial-base.c **** 	* Start user-specific code here. */
  46:simpleserial-base.c **** 	trigger_high();
  47:simpleserial-base.c **** 
  48:simpleserial-base.c **** 	//16 hex bytes held in 'pt' were sent
  49:simpleserial-base.c **** 	//from the computer. Store your response
  50:simpleserial-base.c **** 	//back into 'pt', which will send 16 bytes
  51:simpleserial-base.c **** 	//back to computer. Can ignore of course if
  52:simpleserial-base.c **** 	//not needed
  53:simpleserial-base.c **** 
  54:simpleserial-base.c **** 	trigger_low();
  55:simpleserial-base.c **** 	/* End user-specific code here. *
  56:simpleserial-base.c **** 	********************************/
  57:simpleserial-base.c **** 	simpleserial_put('r', 16, pt);
  58:simpleserial-base.c **** 	return 0x00;
  59:simpleserial-base.c **** }
  60:simpleserial-base.c **** 
  61:simpleserial-base.c **** uint8_t reset(uint8_t* x, uint8_t len)
  62:simpleserial-base.c **** {
  63:simpleserial-base.c **** 	// Reset key here if needed
  64:simpleserial-base.c **** 	return 0x00;
  65:simpleserial-base.c **** }
  66:simpleserial-base.c **** 
  67:simpleserial-base.c **** uint8_t rx_key(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *buf)
  68:simpleserial-base.c **** {
  69:simpleserial-base.c ****     uint16_t offset = scmd * CHUNK_SZ;
  70:simpleserial-base.c ****     // Validar que no sobrepasamos los límites
  71:simpleserial-base.c ****     if (offset >= SK_LEN) return SS_ERR_LEN;
  72:simpleserial-base.c ****     // Limitar la cantidad a copiar al espacio disponible
  73:simpleserial-base.c ****     uint16_t to_copy = (offset + len > SK_LEN) ? SK_LEN - offset : len;
  74:simpleserial-base.c ****     memcpy(sk + offset, buf, to_copy);
  75:simpleserial-base.c ****     // Debug: retornar el primer byte del buffer para verificar
  76:simpleserial-base.c ****     trigger_high();
  77:simpleserial-base.c ****     trigger_low();
  78:simpleserial-base.c ****     return 0x00;
  79:simpleserial-base.c **** }
